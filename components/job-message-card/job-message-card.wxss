.job-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06);
  padding: 24rpx;
}

.job-card-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.job-card-icon {
  font-size: 28rpx;
}

.job-card-label {
  font-size: 22rpx;
  color: #8a9aa8;
}

.job-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-card-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.job-card-salary {
  font-size: 30rpx;
  font-weight: 700;
  color: #ff5c39;
}

.job-card-location {
  font-size: 24rpx;
  color: #8a9aa8;
  background: #f5f5f5;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.job-card-company {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.job-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.job-card-tag {
  font-size: 22rpx;
  color: #607d8b;
  background: #e8f5e9;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

.job-card-footer {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.job-card-btn {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.job-card-btn.secondary {
  background: #f5f7fa;
}

.job-card-btn.secondary text {
  color: #666;
}

.job-card-btn.primary {
  background: linear-gradient(135deg, #299ff0, #1a8fe0);
}

.job-card-btn.primary text {
  color: #fff;
}

.job-card-btn.applied {
  background: #e8ecf0;
}

.job-card-btn.applied text {
  color: #8a9aa8;
}