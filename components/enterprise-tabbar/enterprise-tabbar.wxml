<view class="tabbar">
  <view 
    wx:for="{{tabs}}" 
    wx:key="id" 
    class="tab-item {{current === item.id ? 'active' : ''}}" 
    bindtap="switchTab" 
    data-id="{{item.id}}"
  >
    <view class="tab-icon">{{item.icon}}</view>
    <view class="tab-text">{{item.text}}</view>
  </view>
</view>