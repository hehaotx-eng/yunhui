.tabbar {
  display: flex;
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 48rpx;
  height: 100rpx;
  background: rgba(255,255,255,.35);
  backdrop-filter: blur(50rpx) saturate(180%);
  -webkit-backdrop-filter: blur(50rpx) saturate(180%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,.06);
  box-sizing: border-box;
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3rpx;
  padding: 6px 0;
  position: relative;
}

.tab-icon-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-icon-img {
  width: 44rpx;
  height: 44rpx;
  display: block;
  opacity: 0.5;
  transition: all .2s ease;
}

.tab-badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 28rpx;
  height: 28rpx;
  background: #ff3b30;
  color: #fff;
  font-size: 18rpx;
  font-weight: 600;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
  box-sizing: border-box;
  border: 2rpx solid #fff;
}

.tab-text {
  font-size: 10px;
  color: #9ca3af;
  line-height: 1.2;
  font-weight: 500;
  transition: all .2s ease;
}

.tab-item.active .tab-icon-img {
  opacity: 1;
  transform: scale(1.1);
}

.tab-item.active .tab-text {
  color: #1A2332;
  font-weight: 700;
}
