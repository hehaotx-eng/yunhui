.tabbar {
  display: flex;
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 48rpx;
  height: 100rpx;
  background: rgba(255,255,255,.35);
  backdrop-filter: blur(50rpx) saturate(180%);
  -webkit-backdrop-filter: blur(50rpx) saturate(180%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,.06);
  box-sizing: border-box;
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3rpx;
  padding: 6px 0;
  position: relative;
}

.tab-icon {
  font-size: 22px;
  line-height: 1;
  color: #9ca3af;
  transition: all .2s ease;
}

.tab-text {
  font-size: 10px;
  color: #9ca3af;
  line-height: 1.2;
  font-weight: 500;
  transition: all .2s ease;
}

.tab-item.active .tab-icon {
  color: #299ff0;
  transform: scale(1.1);
}

.tab-item.active .tab-text {
  color: #299ff0;
  font-weight: 700;
}
