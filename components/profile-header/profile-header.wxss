.profile-header {
  background: var(--c-card, #fff);
  border-radius: 0 0 32rpx 32rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.header-cover { height: 240rpx; background: linear-gradient(135deg, #1a1a2e, #2d2d44); }
.cover-img { width: 100%; height: 100%; }
.cover-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, #1a1a2e, #2d2d44); }

.header-body {
  display: flex;
  align-items: flex-start;
  padding: 0 28rpx;
  margin-top: -48rpx;
  position: relative;
  z-index: 1;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  background: #f3f4f6;
  border: 6rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,.1);
}

.profile-avatar image { width: 100%; height: 100%; }
.profile-avatar text { font-size: 48rpx; font-weight: 700; color: var(--c-text); }

.profile-info { flex: 1; padding-top: 56rpx; }
.profile-name { font-size: 36rpx; font-weight: 800; color: var(--c-text); display: block; }
.profile-desc { font-size: 24rpx; color: var(--c-text-2); line-height: 1.6; margin-top: 8rpx; }

.profile-stats {
  display: flex;
  gap: 32rpx;
  margin-top: 16rpx;
}

.stat-item { display: flex; align-items: baseline; gap: 6rpx; }
.stat-num { font-size: 30rpx; font-weight: 700; color: var(--c-text); }
.stat-label { font-size: 22rpx; color: var(--c-text-3); }

.profile-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding: 16rpx 28rpx;
}

.p-tag {
  padding: 6rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: var(--c-text-2);
}

.profile-actions {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 28rpx 24rpx;
}

.action-btn {
  height: 64rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}

.action-follow {
  flex: 1;
  background: var(--c-accent, #ff5c39);
  color: #fff;
}

.action-chat {
  flex: 1;
  background: var(--c-text, #1a1a2e);
  color: #fff;
}

.action-share {
  width: 64rpx;
  background: #f5f5f5;
  color: var(--c-text-2);
}
