.empty {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 120rpx 40rpx;
}
.empty-icon { margin-bottom: 24rpx; }
.empty-icon-inner {
  width: 120rpx; height: 120rpx;
  border-radius: 50%; background: #f5f5f5;
}
.empty-title {
  font-size: 30rpx; color: #999;
  margin-bottom: 12rpx;
}
.empty-subtitle {
  font-size: 24rpx; color: #ccc;
  margin-bottom: 32rpx;
}
.empty-action {
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  background: #00a2ff; color: #fff;
  font-size: 28rpx;
}
