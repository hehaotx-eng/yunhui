<view class="empty">
  <view class="empty-icon">
    <view class="empty-icon-inner"></view>
  </view>
  <view class="empty-title">{{title}}</view>
  <view class="empty-subtitle" wx:if="{{subtitle}}">{{subtitle}}</view>
  <view class="empty-action" wx:if="{{actionText}}" bindtap="onAction">{{actionText}}</view>
</view>
