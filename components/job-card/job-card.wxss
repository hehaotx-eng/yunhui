.card {
  padding: 24rpx; margin-bottom: 20rpx;
  background: #fff; border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.card-header {
  display: flex; justify-content: space-between;
  align-items: flex-start; margin-bottom: 12rpx;
}
.card-title {
  font-size: 32rpx; font-weight: 600;
  color: #1a1a1a; flex: 1;
  overflow: hidden; text-overflow: ellipsis;
  white-space: nowrap; margin-right: 16rpx;
}
.card-salary {
  font-size: 30rpx; font-weight: 600;
  color: #ff6b35; flex-shrink: 0;
}
.card-meta {
  display: flex; align-items: center;
  font-size: 24rpx; color: #999;
  margin-bottom: 16rpx;
}
.meta-dot { margin: 0 8rpx; }
.card-tags {
  display: flex; flex-wrap: wrap;
  gap: 12rpx; margin-bottom: 16rpx;
}
.tag {
  padding: 4rpx 16rpx; border-radius: 6rpx;
  font-size: 22rpx; color: #666;
  background: #f5f5f5;
}
.card-footer {
  display: flex; align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}
.company { display: flex; align-items: center; }
.company-logo {
  width: 48rpx; height: 48rpx;
  border-radius: 8rpx; overflow: hidden;
  margin-right: 12rpx;
}
.company-logo image { width: 100%; height: 100%; }
.company-logo-placeholder {
  display: flex; align-items: center;
  justify-content: center;
  background: #e8f4ff; color: #00a2ff;
  font-size: 24rpx; font-weight: 600;
}
.company-name {
  font-size: 24rpx; color: #666;
  overflow: hidden; text-overflow: ellipsis;
  white-space: nowrap;
}
