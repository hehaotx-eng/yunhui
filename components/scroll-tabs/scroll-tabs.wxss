.scroll-tabs {
  position: relative;
  padding: 12rpx 0;
  background: #fff;
  border-bottom: 1rpx solid var(--c-border, #f0f0f0);
}

.tab-scroll {
  white-space: nowrap;
}

.tab-list {
  display: inline-flex;
  padding: 0 16rpx;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 28rpx;
  margin: 0 6rpx;
  position: relative;
  z-index: 1;
}

.tab-text {
  font-size: 28rpx;
  color: #6b7280;
  font-weight: 500;
  white-space: nowrap;
  transition: color .25s ease;
}

.tab-item.active .tab-text {
  color: #007aff;
  font-weight: 700;
}

.tab-indicator {
  position: absolute;
  top: 8rpx;
  bottom: 8rpx;
  background: rgba(0,122,255,.12);
  border-radius: 32rpx;
  z-index: 0;
}

.tab-indicator.animate {
  transition: left .3s cubic-bezier(.34,1.56,.64,1), width .3s cubic-bezier(.34,1.56,.64,1);
}
