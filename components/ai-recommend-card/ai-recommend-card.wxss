/* AI 推荐卡片 - 干净现代版 */
.feed-card-base {
  background: var(--c-card, #fff);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(99,102,241,.06);
  transition: transform .2s ease;
}

.feed-card-base:active {
  transform: scale(.98);
}

/* 头部 */
.feed-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.feed-header-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, var(--c-ai, #6366f1), #8b5cf6);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.feed-header-avatar text {
  font-size: 20rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1rpx;
}

.feed-header-avatar image {
  width: 100%;
  height: 100%;
}

.feed-header-info {
  flex: 1;
  min-width: 0;
}

.feed-header-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text, #111827);
  display: block;
}

.feed-header-meta {
  font-size: 20rpx;
  color: var(--c-text-3, #94a3b8);
  display: block;
  margin-top: 2rpx;
}

/* 高匹配徽章 */
.match-score-badge {
  padding: 4rpx 14rpx;
  background: linear-gradient(135deg, var(--c-success, #22c55e), #4ade80);
  border-radius: 20rpx;
}

.match-score-badge text {
  font-size: 18rpx;
  font-weight: 600;
  color: #fff;
}

/* 匹配分数明细 - 轻量行 */
.score-breakdown {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
  font-size: 20rpx;
  color: var(--c-text-3, #94a3b8);
}

.score-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.score-label {
  color: var(--c-text-2, #64748b);
}

.score-value {
  font-weight: 700;
  color: var(--c-ai, #6366f1);
}

.score-divider {
  color: var(--c-border, #e2e8f0);
}

/* 内容区 */
.feed-body {
  margin-bottom: 20rpx;
}

.feed-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text, #111827);
  margin-bottom: 8rpx;
}

.salary {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--c-accent, #f97316);
  margin-bottom: 16rpx;
  display: block;
}

/* AI 推荐理由 - 简洁引语 */
.ai-reason {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  border-left: 4rpx solid var(--c-ai, #6366f1);
}

.reason-badge {
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, var(--c-ai, #6366f1), #8b5cf6);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.reason-badge text {
  font-size: 18rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1rpx;
}

.reason-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--c-text-2, #64748b);
  line-height: 1.6;
}

/* 技能匹配标签 */
.feed-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.feed-tag {
  padding: 6rpx 16rpx;
  background: var(--c-ai-light, rgba(99,102,241,.08));
  border-radius: 20rpx;
  font-size: 20rpx;
  color: var(--c-ai, #6366f1);
  font-weight: 500;
}

/* 风险提示 */
.risk-note {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: var(--c-warn-light, rgba(245,158,11,.08));
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.risk-icon {
  font-size: 20rpx;
  flex-shrink: 0;
}

.risk-text {
  font-size: 20rpx;
  color: #92400e;
  line-height: 1.5;
}

/* 企业行 */
.company-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--c-border, #e2e8f0);
}

.company-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  background: var(--c-bg, #f8fafc);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.company-avatar text {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--c-text, #111827);
}

.company-avatar image {
  width: 100%;
  height: 100%;
}

.company-info {
  flex: 1;
  min-width: 0;
}

.company-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text, #111827);
  display: block;
}

.company-meta {
  font-size: 20rpx;
  color: var(--c-text-3, #94a3b8);
  display: block;
  margin-top: 2rpx;
}

/* 操作按钮 */
.feed-card-base .card-actions {
  display: flex;
  gap: 12rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--c-border, #e2e8f0);
}

.feed-card-base .card-btn {
  height: 68rpx;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  transition: all .2s ease;
}

.feed-card-base .card-btn:active {
  transform: scale(.96);
}

.feed-card-base .card-btn--primary {
  flex: 1.4;
  background: linear-gradient(135deg, var(--c-ai, #6366f1), #8b5cf6);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(99,102,241,.25);
}

.feed-card-base .card-btn--dark {
  flex: 1;
  background: transparent;
  color: var(--c-ai, #6366f1);
  border: 2rpx solid var(--c-ai-border, rgba(99,102,241,.15));
}

.feed-card-base .card-btn--ghost {
  flex: 0.8;
  background: transparent;
  color: var(--c-text-3, #94a3b8);
}
