<wxs src="../../utils/wxs.wxs" module="wxs" />
<view class="feed-card-base card--ai" bindtap="onTap">
  <!-- HEADER -->
  <view class="feed-header">
    <view class="feed-header-avatar">
      <text>AI</text>
    </view>
    <view class="feed-header-info">
      <text class="feed-header-name">智能推荐</text>
      <text class="feed-header-meta">综合匹配 {{item.match_score}}%</text>
    </view>
    <view class="match-score-badge" wx:if="{{item.match_score >= 80}}">
      <text>高匹配</text>
    </view>
  </view>

  <!-- 匹配分数明细 -->
  <view class="score-breakdown">
    <view class="score-item">
      <text class="score-label">语义匹配</text>
      <text class="score-value">{{item.ai_score || 0}}</text>
    </view>
    <view class="score-divider">+</view>
    <view class="score-item">
      <text class="score-label">关键词匹配</text>
      <text class="score-value">{{item.keyword_score || 0}}</text>
    </view>
  </view>

  <!-- BODY -->
  <view class="feed-body">
    <view class="feed-title line-clamp-1">{{item.title || '职位'}}</view>
    <view class="salary">{{item.salary || '面议'}}</view>

    <!-- AI 推荐理由 -->
    <view class="ai-reason" wx:if="{{item.reason}}">
      <view class="reason-badge">
        <text>AI</text>
      </view>
      <text class="reason-text line-clamp-2">{{item.reason}}</text>
    </view>

    <!-- 技能匹配标签 -->
    <view class="feed-tags" wx:if="{{item.match_tags && item.match_tags.length > 0}}">
      <text class="feed-tag" wx:for="{{item.match_tags}}" wx:key="*this" wx:if="{{index < 5}}">{{item}}</text>
    </view>

    <!-- 风险提示 -->
    <view class="risk-note" wx:if="{{item.risk_note}}">
      <text class="risk-icon">⚠️</text>
      <text class="risk-text">{{item.risk_note}}</text>
    </view>

    <!-- 企业行 -->
    <view class="company-row">
      <view class="company-avatar" catchtap="onCompanyTap" data-id="{{item.company_id || item.enterprise_id}}">
        <image wx:if="{{item.company_logo || item.enterprise_logo}}" src="{{item.company_logo || item.enterprise_logo}}" mode="aspectFill" />
        <text wx:else>{{wxs.firstChar(item.company_name || item.enterprise_name)}}</text>
      </view>
      <view class="company-info">
        <text class="company-name">{{item.company_name || item.enterprise_name || '企业'}}</text>
        <text class="company-meta">{{item.location || '地点不限'}} · {{item.experience || '经验不限'}}</text>
      </view>
    </view>
  </view>

  <!-- ACTIONS -->
  <view class="card-actions">
    <view class="card-btn card-btn--primary" data-action="apply" catchtap="onAction">
      <text>感兴趣</text>
    </view>
    <view class="card-btn card-btn--dark" data-action="chat" catchtap="onAction">
      <text>聊聊</text>
    </view>
    <view class="card-btn card-btn--ghost" data-action="skip" catchtap="onAction">
      <text>不感兴趣</text>
    </view>
  </view>
</view>
