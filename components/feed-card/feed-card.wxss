.job-card {
  background: var(--c-card, #fff);
  border-radius: var(--card-radius, 24rpx);
  box-shadow: var(--card-shadow, 0 2rpx 12rpx rgba(15,23,42,.04));
  margin: 0 var(--sp-24, 24rpx) var(--card-gap, 20rpx);
  padding: var(--sp-24, 24rpx);
}

/* Row 1: title + salary */
.card-row-top {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: var(--sp-16, 16rpx);
}

.card-title {
  font-size: var(--fs-lg, 32rpx);
  font-weight: var(--fw-bold, 700);
  color: var(--c-text, #1a1a2e);
  flex: 1;
  margin-right: var(--sp-16, 16rpx);
}

.card-salary {
  font-size: var(--fs-lg, 32rpx);
  font-weight: var(--fw-bold, 700);
  color: #ff5c39;
  flex-shrink: 0;
}

/* Row 2: tags */
.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-10, 10rpx);
  margin-bottom: var(--sp-20, 20rpx);
}

.card-tag {
  font-size: var(--fs-xxs, 22rpx);
  color: var(--c-text-2, #6b7280);
  background: #f5f6f8;
  padding: var(--sp-8, 8rpx) var(--sp-16, 16rpx);
  border-radius: var(--sp-8, 8rpx);
}

/* Row 3: company */
.card-company {
  display: flex;
  align-items: center;
  margin-bottom: var(--sp-12, 12rpx);
}

.company-logo {
  width: 40rpx;
  height: 40rpx;
  border-radius: var(--sp-8, 8rpx);
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--sp-12, 12rpx);
  flex-shrink: 0;
  overflow: hidden;
}

.company-logo image { width: 100%; height: 100%; }
.company-logo text {
  font-size: var(--fs-xxs, 22rpx);
  font-weight: var(--fw-bold, 700);
  color: var(--c-text, #1a1a2e);
}

.company-name {
  font-size: var(--fs-sm, 26rpx);
  color: var(--c-text, #1a1a2e);
  max-width: 380rpx;
  flex-shrink: 0;
}

.online-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--c-success, #22c55e);
  margin: 0 var(--sp-8, 8rpx) 0 var(--sp-12, 12rpx);
  flex-shrink: 0;
}

.online-text {
  font-size: var(--fs-xxs, 22rpx);
  color: var(--c-success, #22c55e);
  flex-shrink: 0;
}

/* Row 3: bottom info — 公司 + 地区 */
.card-row-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.company-info-left {
  display: flex;
  align-items: center;
  gap: var(--sp-12, 12rpx);
  flex: 1;
  min-width: 0;
}

.info-text {
  font-size: var(--fs-xs, 24rpx);
  color: var(--c-text-3, #9ca3af);
}

.card-info-right {
  display: flex;
  align-items: center;
  gap: var(--sp-8, 8rpx);
}

.info-location {
  font-size: var(--fs-xs, 24rpx);
  color: var(--c-text-3, #9ca3af);
}

.close-btn {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-text-3, #9ca3af);
  font-size: var(--fs-md, 28rpx);
}
