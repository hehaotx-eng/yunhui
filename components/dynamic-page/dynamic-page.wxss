.dp-page { min-height: 100vh; background: #f6f7f9; }

/* Phase states */
.dp-phase { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; padding: 40rpx; }
.dp-loading-spinner { width: 60rpx; height: 60rpx; border: 4rpx solid #e0e0e0; border-top-color: #409eff; border-radius: 50%; animation: dp-spin 0.8s linear infinite; margin-bottom: 20rpx; }
@keyframes dp-spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
.dp-loading-text { font-size: 26rpx; color: #999; }
.dp-empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.dp-error-bar { background: #fff3f3; padding: 16rpx 24rpx; text-align: center; }
.dp-error-text { font-size: 24rpx; color: #e74c3c; }

/* Search */
.dp-search { display: flex; align-items: center; gap: 10rpx; margin: 0 24rpx; padding: 0 20rpx; height: 64rpx; background: #f3f4f6; border-radius: 32rpx; }
.dp-search-icon { width: 32rpx; height: 32rpx; flex-shrink: 0; }
.dp-search-text { font-size: 24rpx; color: #9ca3af; flex: 1; }

/* Banner */
.dp-banner-wrap { height: 350rpx; padding: 0 24rpx; margin-bottom: 0; background: linear-gradient(135deg, rgba(41,159,240,.16) 0%, rgba(41,159,240,.04) 60%, rgba(41,159,240,0) 100%), linear-gradient(180deg, rgba(246,247,249,0) 0%, #f6f7f9 150px); }
.dp-banner-swiper { height: 330rpx; border-radius: 24rpx; overflow: hidden; margin-top: 20rpx; }
.dp-banner-item { width: 100%; height: 100%; border-radius: 24rpx; overflow: hidden; }
.dp-banner-img { width: 100%; height: 100%; }

/* Quick Links */
.dp-quick-links { display: flex; justify-content: center; align-items: flex-start; padding: 20rpx 0 10rpx; gap: 24rpx; }
.dp-ql-item { display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.dp-ql-icon { width: 56rpx; height: 56rpx; }
.dp-ql-label { font-size: 24rpx; color: #333; }

/* Notice Bar */
.dp-notice-bar { display: flex; align-items: center; background: #fff8f0; padding: 14rpx 24rpx; }
.dp-notice-icon { width: 32rpx; height: 32rpx; margin-right: 12rpx; flex-shrink: 0; }
.dp-notice-swiper { flex: 1; height: 32rpx; }
.dp-notice-text { font-size: 24rpx; color: #b8860b; line-height: 32rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.dp-notice-more { font-size: 22rpx; color: #b8860b; margin-left: 12rpx; flex-shrink: 0; }

/* Category Tabs */
.dp-cat-scroll { background: #fff; white-space: nowrap; padding: 16rpx 24rpx; }
.dp-cat-inner { display: inline-flex; gap: 16rpx; }
.dp-cat-item { display: inline-flex; align-items: center; padding: 12rpx 28rpx; border-radius: 40rpx; font-size: 26rpx; color: #666; background: #f5f5f5; }
.dp-cat-active { color: #fff; background: #1a1a2e; font-weight: 600; }

/* AI Banner */
.dp-ai-banner { margin: 20rpx 24rpx; border-radius: 24rpx; overflow: hidden; position: relative; }
.dp-ai-banner-bg { position: absolute; inset: 0; background: linear-gradient(135deg, #1a1a2e 0%, #2d2d44 50%, #3d3d5c 100%); }
.dp-ai-banner-content { position: relative; display: flex; align-items: center; padding: 28rpx; gap: 16rpx; }
.dp-ai-icon-wrap { width: 64rpx; height: 64rpx; border-radius: 16rpx; background: linear-gradient(135deg, #6d5efc, #8b7cf8); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.dp-ai-icon-text { font-size: 24rpx; font-weight: 800; color: #fff; }
.dp-ai-banner-info { flex: 1; }
.dp-ai-banner-title { font-size: 28rpx; font-weight: 700; color: #fff; display: block; }
.dp-ai-banner-desc { font-size: 22rpx; color: rgba(255,255,255,.6); display: block; margin-top: 4rpx; }
.dp-ai-banner-arrow { font-size: 32rpx; color: rgba(255,255,255,.5); }

/* Custom Block */
.dp-custom-block { margin: 20rpx 24rpx; border-radius: 20rpx; overflow: hidden; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40rpx; min-height: 120rpx; }
.dp-custom-image { width: 100%; height: 200rpx; border-radius: 12rpx; margin-bottom: 12rpx; }
.dp-custom-text { font-size: 28rpx; color: #333; }

/* Job List Section */
.dp-section { margin: 0 24rpx 20rpx; background: #fff; border-radius: 20rpx; padding: 24rpx; }
.dp-section-header { margin-bottom: 16rpx; }
.dp-section-title { font-size: 30rpx; font-weight: 700; color: #1a1a2e; }
.dp-job-card { padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.dp-job-card:last-child { border-bottom: none; }
.dp-job-title { font-size: 28rpx; font-weight: 600; color: #1a1a2e; }
.dp-job-meta { font-size: 24rpx; color: #999; margin-top: 8rpx; }
.dp-empty { text-align: center; color: #999; padding: 40rpx 0; font-size: 26rpx; }

/* Skeleton */
.dp-skeleton-card { padding: 16rpx 0; }
.dp-skeleton-line { height: 20rpx; border-radius: 6rpx; background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; margin-bottom: 8rpx; }
.dp-skeleton-line-lg { width: 60%; }
.dp-skeleton-line-sm { width: 40%; }

@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
