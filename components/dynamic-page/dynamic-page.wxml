<view class="dp-page">
  <!-- 加载态 -->
  <view wx:if="{{phase === 'loading'}}" class="dp-phase">
    <view class="dp-loading-spinner"></view>
    <text class="dp-loading-text">页面加载中...</text>
  </view>

  <!-- 错误提示 -->
  <view wx:elif="{{errorMsg}}" class="dp-error-bar">
    <text class="dp-error-text">{{errorMsg}}</text>
  </view>

  <!-- 正常渲染 -->
  <block wx:elif="{{phase === 'ready'}}">
    <block wx:for="{{widgets}}" wx:key="index">
      <!-- 搜索栏 -->
      <block wx:if="{{item.type === 'search_bar'}}">
        <view class="dp-search" bindtap="onSearchTap">
          <image class="dp-search-icon" src="/pages/image/sousuo.png" />
          <text class="dp-search-text">{{item.props.placeholder || '搜索职位、企业、技能...'}}</text>
        </view>
      </block>

      <!-- 轮播图 -->
      <block wx:elif="{{item.type === 'banner'}}">
        <view class="dp-banner-wrap">
          <swiper class="dp-banner-swiper" indicator-dots="{{true}}" indicator-color="rgba(255,255,255,.3)" indicator-active-color="#fff" autoplay circular interval="{{item.props.interval || 4000}}" bindchange="onBannerChange">
            <swiper-item wx:for="{{banners}}" wx:key="id">
              <view class="dp-banner-item">
                <image class="dp-banner-img" src="{{item.image_url}}" mode="aspectFill" />
              </view>
            </swiper-item>
          </swiper>
        </view>
      </block>

      <!-- 快捷图标 -->
      <block wx:elif="{{item.type === 'quick_links'}}">
        <view class="dp-ql-section" wx:if="{{quickLinks.length > 0}}">
          <view class="dp-ql-item" wx:for="{{quickLinks}}" wx:key="id" data-link="{{item.link}}" bindtap="onQuickLinkTap">
            <image class="dp-ql-icon" src="{{item.icon}}" mode="aspectFit" />
            <text class="dp-ql-label">{{item.title}}</text>
          </view>
        </view>
      </block>

      <!-- 通知公告 -->
      <block wx:elif="{{item.type === 'notice_bar'}}">
        <view class="dp-notice-bar" wx:if="{{notices.length > 0}}" bindtap="onNoticeTap">
          <image class="dp-notice-icon" src="{{item.props.icon || '/pages/image/tongzhi.png'}}" mode="aspectFit" />
          <swiper class="dp-notice-swiper" vertical autoplay circular interval="3000" display-multiple-items="{{1}}">
            <swiper-item wx:for="{{notices}}" wx:key="id">
              <text class="dp-notice-text line-clamp-1">{{item.title}}</text>
            </swiper-item>
          </swiper>
          <text class="dp-notice-more">更多 ›</text>
        </view>
      </block>

      <!-- 分类标签 -->
      <block wx:elif="{{item.type === 'category_tabs'}}">
        <scroll-view class="dp-cat-scroll" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="dp-cat-inner">
            <view wx:for="{{categories}}" wx:key="id" class="dp-cat-item {{activeCategory === item.id ? 'dp-cat-active' : ''}}" data-id="{{item.id}}" bindtap="onCategoryTap">{{item.name}}</view>
          </view>
        </scroll-view>
      </block>

      <!-- AI 推荐横幅 -->
      <block wx:elif="{{item.type === 'ai_banner'}}">
        <view class="dp-ai-banner" bindtap="onSearchTap">
          <view class="dp-ai-banner-bg"></view>
          <view class="dp-ai-banner-content">
            <view class="dp-ai-icon-wrap"><text class="dp-ai-icon-text">AI</text></view>
            <view class="dp-ai-banner-info">
              <text class="dp-ai-banner-title">{{item.props.title || '发现适合你的机会'}}</text>
              <text class="dp-ai-banner-desc">{{item.props.desc || '基于你的偏好智能匹配'}}</text>
            </view>
            <view class="dp-ai-banner-arrow"><text>→</text></view>
          </view>
        </view>
      </block>

      <!-- 自定义块 -->
      <block wx:elif="{{item.type === 'custom_block'}}">
        <view class="dp-custom-block" style="background-color: {{item.props.bgColor || '#f5f5f5'}};" data-link="{{item.props.link}}" bindtap="onCustomBlockTap">
          <image wx:if="{{item.props.image}}" class="dp-custom-image" src="{{item.props.image}}" mode="aspectFill" />
          <text class="dp-custom-text">{{item.props.text || ''}}</text>
        </view>
      </block>

      <!-- 职位列表 -->
      <block wx:elif="{{item.type === 'job_list'}}">
        <view class="dp-section">
          <view class="dp-section-header">
            <text class="dp-section-title">{{item.props.title || '最新职位'}}</text>
          </view>
          <block wx:if="{{skeleton}}">
            <view class="dp-skeleton-card" wx:for="{{[1,2]}}" wx:key="*this">
              <view class="dp-skeleton-line dp-skeleton-line-lg"></view>
              <view class="dp-skeleton-line dp-skeleton-line-sm"></view>
            </view>
          </block>
          <block wx:elif="{{feedList.length > 0}}">
            <view class="dp-job-card" wx:for="{{feedList}}" wx:key="id" data-id="{{item.payload.job_id || item.id}}" bindtap="onJobTap">
              <view class="dp-job-title">{{item.payload.title || item.title}}</view>
              <view class="dp-job-meta">
                <text wx:if="{{item.payload.salary_min > 0 || item.payload.salary_max > 0}}" class="dp-salary">{{item.payload.salary_min}}-{{item.payload.salary_max}}元/月</text>
                <text wx:else class="dp-salary">{{item.payload.salary || ''}}</text>
                <text class="dp-company">{{item.payload.company_name || ''}}</text>
              </view>
              <view class="dp-job-extra">
                <text wx:if="{{item.payload.location}}" class="dp-tag">{{item.payload.location}}</text>
                <text wx:if="{{item.payload.experience}}" class="dp-tag">{{item.payload.experience}}</text>
                <text wx:if="{{item.payload.education}}" class="dp-tag">{{item.payload.education}}</text>
              </view>
              <view class="dp-job-tags" wx:if="{{item.payload.tags && item.payload.tags.length > 0}}">
                <text class="dp-welfare" wx:for="{{item.payload.tags}}" wx:for-item="t" wx:key="*this">{{t}}</text>
              </view>
            </view>
          </block>
          <block wx:else>
            <view class="dp-empty">暂无职位数据</view>
          </block>
        </view>
      </block>

      <!-- 企业动态 -->
      <block wx:elif="{{item.type === 'company_posts'}}">
        <view class="dp-section">
          <view class="dp-section-header">
            <text class="dp-section-title">{{item.props.title || '企业动态'}}</text>
          </view>
          <block wx:if="{{companyPosts.length > 0}}">
            <view class="dp-post-card" wx:for="{{companyPosts}}" wx:key="id" data-id="{{item.id}}" bindtap="onPostDetail">
              <view class="dp-post-avatar">{{item.company_name ? item.company_name[0] : '企'}}</view>
              <view class="dp-post-info">
                <view class="dp-post-title">{{item.title}}</view>
                <view class="dp-post-meta">{{item.company_name || ''}} · {{item.created_at ? item.created_at.substring(0,10) : ''}}</view>
              </view>
            </view>
          </block>
          <block wx:else>
            <view class="dp-empty">暂无企业动态</view>
          </block>
        </view>
      </block>

      <!-- 导航栏 -->
      <block wx:elif="{{item.type === 'nav_bar'}}">
        <view class="dp-nav-bar" style="background-color: {{item.props.bgColor || '#ffffff'}};">
          <view wx:if="{{item.props.showBack !== false}}" class="dp-nav-back" style="color: {{item.props.textColor || '#000'}};" bindtap="onNavBack">‹</view>
          <text class="dp-nav-title" style="color: {{item.props.textColor || '#000'}};">{{item.props.title || ''}}</text>
          <view class="dp-nav-space"></view>
        </view>
      </block>

      <!-- 图片导航 -->
      <block wx:elif="{{item.type === 'image_nav'}}">
        <view class="dp-imgnav">
          <view class="dp-imgnav-item" wx:for="{{item.props.items}}" wx:for-item="nav" wx:key="index" wx:if="{{index < (item.props.columns || 4) * 2}}" style="width: {{100 / (item.props.columns || 4)}}%;" data-link="{{nav.link}}" bindtap="onQuickLinkTap">
            <image wx:if="{{nav.icon}}" class="dp-imgnav-icon-img" src="{{nav.icon}}" mode="aspectFit" />
            <view wx:else class="dp-imgnav-icon-text" style="background: {{navIconColors[index % 4]}};">{{nav.label[0] || '·'}}</view>
            <text class="dp-imgnav-label">{{nav.label || '导航'}}</text>
          </view>
        </view>
      </block>

      <!-- 用户信息卡 -->
      <block wx:elif="{{item.type === 'user_card'}}">
        <view class="dp-user-card" bindtap="onUserCardTap">
          <view wx:if="{{item.props.showAvatar !== false}}" class="dp-user-avatar">
            <image wx:if="{{userInfo.avatarUrl}}" class="dp-user-avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
            <text wx:else class="dp-user-avatar-placeholder">👤</text>
          </view>
          <view class="dp-user-info">
            <text class="dp-user-greeting" wx:if="{{isLoggedIn}}">Hi，{{userInfo.nickName || '用户'}}</text>
            <text class="dp-user-greeting" wx:else>{{item.props.greeting || 'Hi，欢迎来到招聘平台'}}</text>
            <text class="dp-user-hint" wx:if="{{!isLoggedIn}}">登录后享受更多服务</text>
          </view>
          <view wx:if="{{item.props.showLoginBtn !== false && !isLoggedIn}}" class="dp-user-btn">登录</view>
        </view>
      </block>

      <!-- 倒计时 -->
      <block wx:elif="{{item.type === 'countdown'}}">
        <view class="dp-countdown" style="background-color: {{item.props.bgColor || '#ff5c39'}};">
          <view class="dp-cd-info">
            <text class="dp-cd-title" style="color: {{item.props.textColor || '#fff'}};">{{item.props.title || '招聘会倒计时'}}</text>
            <text class="dp-cd-sub" style="color: {{item.props.textColor || '#fff'}};">距截止还剩</text>
          </view>
          <view class="dp-cd-time">
            <text class="dp-cd-num">{{cdHours}}</text>
            <text class="dp-cd-dot">:</text>
            <text class="dp-cd-num">{{cdMinutes}}</text>
            <text class="dp-cd-dot">:</text>
            <text class="dp-cd-num">{{cdSeconds}}</text>
          </view>
        </view>
      </block>

      <!-- 视频 -->
      <block wx:elif="{{item.type === 'video'}}">
        <view class="dp-video-section">
          <text wx:if="{{item.props.title}}" class="dp-video-title">{{item.props.title}}</text>
          <video class="dp-video-player" src="{{item.props.src}}" poster="{{item.props.poster}}" autoplay="{{item.props.autoplay || false}}" loop="{{item.props.loop || false}}" controls show-center-play-btn="{{true}}" />
        </view>
      </block>

      <!-- 图文混排 -->
      <block wx:elif="{{item.type === 'rich_text'}}">
        <view class="dp-richtext">
          <text wx:if="{{item.props.title}}" class="dp-rt-title">{{item.props.title}}</text>
          <rich-text class="dp-rt-body" nodes="{{item.props.content || '企业介绍、福利待遇...'}}" />
        </view>
      </block>

      <!-- 图片橱窗 -->
      <block wx:elif="{{item.type === 'showcase'}}">
        <view class="dp-showcase">
          <text wx:if="{{item.props.title}}" class="dp-showcase-title">{{item.props.title}}</text>
          <view class="dp-showcase-grid" style="grid-template-columns: repeat({{item.props.columns || 2}}, 1fr);">
            <view class="dp-showcase-item" wx:for="{{item.props.items}}" wx:for-item="pic" wx:key="index" data-link="{{pic.link}}" bindtap="onQuickLinkTap">
              <image wx:if="{{pic.image}}" class="dp-showcase-img" src="{{pic.image}}" mode="aspectFill" />
              <view wx:else class="dp-showcase-img-placeholder" style="background: {{navIconColors[index % 4]}};"></view>
              <text class="dp-showcase-name">{{pic.name || '照片'}}</text>
              <text wx:if="{{pic.price}}" class="dp-showcase-price">¥{{pic.price}}</text>
            </view>
          </view>
        </view>
      </block>

      <!-- 联系按钮 -->
      <block wx:elif="{{item.type === 'contact_btn'}}">
        <view class="dp-contact {{item.props.style === 'fixed' ? 'dp-contact-fixed' : ''}}" style="background-color: {{item.props.bgColor || '#07c160'}};" bindtap="onContactTap">
          <text class="dp-contact-icon">📞</text>
          <view class="dp-contact-mid">
            <text class="dp-contact-text">{{item.props.text || '咨询招聘详情'}}</text>
            <text class="dp-contact-name">{{item.props.contactName || '李小姐'}}</text>
          </view>
          <text class="dp-contact-arrow">›</text>
        </view>
        <view wx:if="{{item.props.qrImage}}" class="dp-contact-qr-wrap">
          <image class="dp-contact-qr-img" src="{{item.props.qrImage}}" mode="aspectFit" show-menu-by-longpress="{{true}}" />
          <text class="dp-contact-qr-hint">长按识别二维码添加{{item.props.contactName || '李小姐'}}</text>
        </view>
      </block>

      <!-- 位置信息 -->
      <block wx:elif="{{item.type === 'location_card'}}">
        <view class="dp-location">
          <map wx:if="{{item.props.showMap !== false && item.props.latitude && item.props.longitude}}" class="dp-loc-map" latitude="{{item.props.latitude}}" longitude="{{item.props.longitude}}" markers="{{locMarkers}}" show-location enable-scroll="{{false}}" bindtap="onLocMapTap" />
          <view wx:else class="dp-loc-map-placeholder">📍</view>
          <view class="dp-loc-info">
            <text class="dp-loc-name">{{item.props.name || '面试地点'}}</text>
            <text class="dp-loc-addr">{{item.props.address || '详细办公地址'}}</text>
          </view>
          <view wx:if="{{item.props.phone}}" class="dp-loc-phone" bindtap="onLocPhoneTap">
            <text>📞 {{item.props.phone}}</text>
          </view>
        </view>
      </block>
    </block>
  </block>

  <!-- 兜底：没有任何内容 -->
  <view wx:else class="dp-phase">
    <view class="dp-empty-icon icon-ph"></view>
    <text class="dp-loading-text">页面暂无内容</text>
  </view>
</view>
