<wxs src="../../utils/wxs.wxs" module="wxs" />
<view class="feed-card-base" bindtap="onCardTap">
  <!-- HEADER: avatar + name + time -->
  <slot name="header">
    <view class="feed-header">
      <view class="feed-header-avatar" bindtap="onCompanyTap" data-id="{{item.company_id || item.enterprise_id}}" catchtap="onCompanyTap">
        <image wx:if="{{item.company_logo || item.enterprise_logo}}" src="{{item.company_logo || item.enterprise_logo}}" mode="aspectFill" />
        <text wx:else>{{wxs.firstChar(item.company_name || item.enterprise_name)}}</text>
      </view>
      <view class="feed-header-info">
        <text class="feed-header-name">{{item.company_name || item.enterprise_name || '企业'}}</text>
        <text class="feed-header-meta">{{item.publish_time || item.created_at || '刚刚'}}</text>
      </view>
    </view>
  </slot>

  <!-- BODY: title + description + tags -->
  <slot name="body">
    <view class="feed-body">
      <view class="feed-title line-clamp-2">{{item.title}}</view>
      <view class="feed-description line-clamp-2" wx:if="{{item.description || item.summary}}">
        {{item.description || item.summary}}
      </view>
      <view class="feed-tags" wx:if="{{item.tags && item.tags.length > 0}}">
        <text class="feed-tag" wx:for="{{item.tags}}" wx:key="*this" wx:if="{{index < 3}}">{{item}}</text>
      </view>
    </view>
  </slot>

  <!-- CUSTOM BODY SLOT (for AI/Post specialized content) -->
  <slot name="custom-body"></slot>

  <!-- FOOTER: interactions -->
  <slot name="footer">
    <view class="feed-footer">
      <view class="feed-action" data-action="favorite" catchtap="onInteraction">
        <view class="feed-action-icon {{item.is_favorite ? 'feed-action-icon--active' : ''}}">
          <text>{{item.is_favorite ? '❤' : '♡'}}</text>
        </view>
        <text class="feed-action-count">{{item.favorite_count || ''}}</text>
      </view>
      <view class="feed-action" data-action="comment" catchtap="onInteraction">
        <view class="feed-action-icon"><text>💬</text></view>
        <text class="feed-action-count">{{item.comment_count || ''}}</text>
      </view>
      <view class="feed-action" data-action="chat" catchtap="onInteraction">
        <view class="feed-action-icon"><text>✉</text></view>
        <text class="feed-action-label">聊聊</text>
      </view>
      <view class="feed-action" data-action="share" catchtap="onInteraction">
        <view class="feed-action-icon"><text>↗</text></view>
      </view>
    </view>
  </slot>
</view>
