var tools = {
  firstChar: function(str) {
    if (!str) return '企';
    return str.charAt(0);
  },
  jobType: function(type) {
    var map = {
      fulltime: '全职',
      parttime: '兼职',
      intern: '实习',
      normal: '全职',
      premium: '高端'
    };
    return map[type] || type || '';
  }
};

module.exports = tools;
