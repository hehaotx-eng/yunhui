function pad(n) { return n < 10 ? '0' + n : n; }

function formatChatTime(t) {
  if (!t) return '';
  var d = getDate(t);
  var now = getDate();
  var Y = d.getFullYear();
  var M = d.getMonth() + 1;
  var D = d.getDate();
  var h = pad(d.getHours());
  var m = pad(d.getMinutes());
  var timeStr = h + ':' + m;
  if (Y === now.getFullYear() && M === now.getMonth() + 1 && D === now.getDate()) return timeStr;
  var yesterday = getDate();
  yesterday.setDate(yesterday.getDate() - 1);
  if (Y === yesterday.getFullYear() && M === yesterday.getMonth() + 1 && D === yesterday.getDate()) return '昨天 ' + timeStr;
  return pad(M) + '-' + pad(D) + ' ' + timeStr;
}

var tools = {
  firstChar: function(str) {
    if (!str) return '企';
    return str.charAt(0);
  },
  jobType: function(type) {
    var map = {
      fulltime: '全职',
      parttime: '兼职',
      intern: '实习',
      daily: '日结',
      normal: '全职',
      premium: '高端'
    };
    return map[type] || type || '';
  },

  timeAgo: function(t) {
    if (!t) return '';
    var d = getDate(t);
    var now = getDate();
    var diff = Math.floor((now.getTime() - d.getTime()) / 1000);
    if (diff < 60) return '刚刚';
    if (diff < 3600) return Math.floor(diff / 60) + '分钟前';
    if (diff < 86400) return Math.floor(diff / 3600) + '小时前';
    if (diff < 604800) return Math.floor(diff / 86400) + '天前';
    var M = d.getMonth() + 1;
    var D = d.getDate();
    if (M < 10) M = '0' + M;
    if (D < 10) D = '0' + D;
    return M + '-' + D;
  },
  getStatusText: function(status) {
    var map = {
      pending: '待处理',
      viewed: '已查看',
      accepted: '已通过',
      rejected: '已拒绝'
    };
    return map[status] || status || '';
  },
  getFlow: function(status) {
    var flows = {
      pending: [
        { label: '投递成功', done: true, active: false, result: '' },
        { label: '等待查看', done: false, active: true, result: '', hint: '企业尚未查看你的简历' },
        { label: '反馈结果', done: false, active: false, result: '', hint: '等待企业反馈' }
      ],
      viewed: [
        { label: '投递成功', done: true, active: false, result: '' },
        { label: '已被查看', done: true, active: false, result: '' },
        { label: '反馈结果', done: false, active: true, result: '', hint: '等待企业反馈中' }
      ],
      accepted: [
        { label: '投递成功', done: true, active: false, result: '' },
        { label: '已被查看', done: true, active: false, result: '' },
        { label: '已通过', done: true, active: true, result: 'pass' }
      ],
      rejected: [
        { label: '投递成功', done: true, active: false, result: '' },
        { label: '已被查看', done: true, active: false, result: '' },
        { label: '未通过', done: true, active: true, result: 'fail' }
      ]
    };
    return flows[status] || flows.pending;
  },
  formatChatTime: formatChatTime,

  formatTime: function(t) {
    if (!t) return '';
    var d = getDate(t);
    var Y = d.getFullYear();
    var M = d.getMonth() + 1;
    var D = d.getDate();
    if (M < 10) M = '0' + M;
    if (D < 10) D = '0' + D;
    return Y + '-' + M + '-' + D;
  }
};

module.exports = tools;
