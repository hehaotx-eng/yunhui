page {
  --c-bg: #f6f7f9;
  --c-card: #ffffff;
  --c-accent: #ff5c39;
  --c-ai: #6d5efc;
  --c-ai-light: rgba(109,94,252,.06);
  --c-ai-border: rgba(109,94,252,.12);
  --c-text: #1a1a2e;
  --c-text-2: #6b7280;
  --c-text-3: #9ca3af;
  --c-border: #f0f0f0;
  --c-success: #22c55e;
  --c-warn: #f59e0b;
  --shadow-card: 0 2rpx 12rpx rgba(15,23,42,.04);
  --shadow-float: 0 8rpx 32rpx rgba(15,23,42,.08);
  --r-card: 24rpx;
  --r-tag: 12rpx;

  background: var(--c-bg);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  color: var(--c-text);
  font-size: 28rpx;
  line-height: 1.6;
}

.feed-page {
  min-height: 100vh;
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
}

.card {
  background: var(--c-card);
  border-radius: var(--r-card);
  box-shadow: var(--shadow-card);
}

.text-accent { color: var(--c-accent); }
.text-ai { color: var(--c-ai); }
.text-2 { color: var(--c-text-2); }
.text-3 { color: var(--c-text-3); }

.line-clamp-1 {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.line-clamp-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.skeleton-pulse {
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 400% 100%;
  animation: pulse 1.5s ease-in-out infinite;
  border-radius: 8rpx;
}

@keyframes pulse {
  0% { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}
