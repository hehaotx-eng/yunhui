/* ============================================
   FEED — 信息流布局 + 统一卡片容器
   所有 Feed 卡片必须继承 .feed-card-base
   ============================================ */

.feed-page {
  min-height: 100vh;
  background: var(--c-bg);
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

.feed-list {
  padding: var(--sp-20) 0;
}

/* ── 统一卡片容器（所有 feed 卡片必须使用） ── */
.feed-card-base {
  background: var(--c-card);
  border-radius: var(--card-radius);
  box-shadow: var(--card-shadow);
  margin: 0 var(--sp-24) var(--card-gap);
  overflow: hidden;
}

/* ── 卡片头部（统一结构） ── */
.feed-header {
  display: flex;
  align-items: center;
  padding: var(--sp-24);
}

.feed-header-avatar {
  width: var(--avatar-md);
  height: var(--avatar-md);
  border-radius: var(--avatar-radius);
  background: var(--c-skeleton);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--sp-12);
  flex-shrink: 0;
  overflow: hidden;
}

.feed-header-avatar image { width: 100%; height: 100%; }
.feed-header-avatar text {
  font-size: var(--fs-xs);
  font-weight: var(--fw-bold);
  color: var(--c-text);
}

.feed-header-info {
  flex: 1;
  min-width: 0;
}

.feed-header-name {
  font-size: var(--fs-xs);
  font-weight: var(--fw-semibold);
  color: var(--c-text);
  line-height: 1.3;
  display: block;
}

.feed-header-meta {
  font-size: var(--fs-micro);
  color: var(--c-text-3);
  display: block;
  margin-top: 2rpx;
}

/* ── 卡片内容（统一结构） ── */
.feed-body {
  padding: 0 var(--sp-24) var(--sp-24);
}

.feed-title {
  font-size: var(--fs-lg);
  font-weight: var(--fw-bold);
  color: var(--c-text);
  line-height: 1.5;
  margin-bottom: var(--sp-12);
}

.feed-description {
  font-size: var(--fs-sm);
  color: var(--c-text-2);
  line-height: 1.7;
  margin-bottom: var(--sp-12);
}

/* ── 统一标签 ── */
.feed-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-8);
  margin-bottom: var(--sp-12);
}

.feed-tag {
  font-size: var(--fs-xxs);
  color: var(--c-ai);
  background: var(--c-ai-light);
  padding: var(--tag-padding);
  border-radius: var(--tag-radius);
}

.feed-tag--accent {
  color: var(--c-accent);
  background: var(--c-accent-light);
}

.feed-tag--neutral {
  color: var(--c-text-2);
  background: #f5f5f5;
}

/* ── 统一互动栏 ── */
.feed-footer {
  display: flex;
  align-items: center;
  padding: var(--sp-16) var(--sp-24);
  border-top: 1rpx solid var(--c-border);
}

.feed-action {
  display: flex;
  align-items: center;
  gap: var(--sp-6);
  margin-right: var(--sp-32);
}

.feed-action-icon {
  font-size: var(--fs-md);
  line-height: 1;
}

.feed-action-icon--active { color: var(--c-danger); }

.feed-action-count {
  font-size: var(--fs-xxs);
  color: var(--c-text-3);
}

.feed-action-label {
  font-size: var(--fs-xxs);
  color: var(--c-text-2);
}
