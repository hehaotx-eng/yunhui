/* ========== 页面 ========== */
.page {
  background-color: #f6f7f9;
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

/* ========== 顶部导航 ========== */
.header {
  background: #ffffff;
  border-bottom: 1rpx solid #f0f1f3;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
}

.header-date {
  font-size: 24rpx;
  color: #9ca3af;
  font-weight: 400;
}

/* ========== 内容 ========== */
.content {
  padding: 24rpx 20rpx;
}

/* ========== 分区标题 ========== */
.section {
  margin-bottom: 32rpx;
}

.section:last-child {
  margin-bottom: 0;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.section-tag {
  font-size: 20rpx;
  color: #9ca3af;
  background: #f3f4f6;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.section-more {
  font-size: 24rpx;
  color: #2563eb;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
}

.more-hover {
  background-color: #f0f5ff;
}

/* ========== 核心指标 ========== */
.metric-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.metric-card {
  background: #ffffff;
  border: 1rpx solid #f0f1f3;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  transition: background 0.15s ease;
}

.metric-hover {
  background: #fafbfc;
}

.metric-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.1;
  margin-bottom: 8rpx;
  letter-spacing: -1rpx;
}

.metric-unit {
  font-size: 24rpx;
  font-weight: 500;
  color: #6b7280;
  margin-left: 4rpx;
}

.metric-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
  font-weight: 400;
}

.metric-change {
  font-size: 20rpx;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  gap: 2rpx;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.metric-change.up {
  color: #16a34a;
  background: #f0fdf4;
}

.metric-change.down {
  color: #ef4444;
  background: #fef2f2;
}

/* ========== 卡片容器 ========== */
.card {
  background: #ffffff;
  border: 1rpx solid #f0f1f3;
  border-radius: 16rpx;
  padding: 24rpx;
}

/* ========== 图表 ========== */
.chart-card {
  padding: 8rpx 0 0 0;
}

.chart-canvas {
  width: 100%;
  height: 320rpx;
  display: block;
}

/* ========== 漏斗 ========== */
.funnel-card {
  padding: 8rpx 24rpx 16rpx;
}

.funnel-step {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
  transition: background 0.15s ease;
  margin: 0 -24rpx;
  padding: 20rpx 24rpx;
}

.funnel-step:last-child {
  border-bottom: none;
}

.funnel-hover {
  background: #fafbfc;
}

.funnel-labels {
  width: 140rpx;
  flex-shrink: 0;
}

.funnel-stage {
  font-size: 26rpx;
  color: #374151;
  font-weight: 500;
  display: block;
}

.funnel-count {
  font-size: 20rpx;
  color: #9ca3af;
  display: block;
  margin-top: 2rpx;
}

.funnel-bar-bg {
  flex: 1;
  height: 28rpx;
  background: #f3f4f6;
  border-radius: 14rpx;
  overflow: hidden;
}

.funnel-bar {
  height: 100%;
  border-radius: 14rpx;
  transition: width 0.3s ease;
}

.funnel-rate {
  width: 80rpx;
  text-align: right;
  font-size: 22rpx;
  color: #6b7280;
  flex-shrink: 0;
}

/* ========== 列表 ========== */
.list-card {
  padding: 0;
  overflow: hidden;
}

.list-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
  transition: background 0.15s ease;
}

.list-row:last-child {
  border-bottom: none;
}

.row-hover {
  background: #fafbfc;
}

.row-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.row-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f0f5ff;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.row-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.row-info {
  flex: 1;
  min-width: 0;
}

.row-top {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 4rpx;
}

.row-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-meta {
  font-size: 22rpx;
  color: #9ca3af;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-time {
  font-size: 22rpx;
  color: #9ca3af;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ========== 状态标签 ========== */
.status-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
  flex-shrink: 0;
  line-height: 1.4;
}

.status-tag.pending {
  background: #fef9ee;
  color: #b8860b;
}

.status-tag.viewed {
  background: #f0f5ff;
  color: #2563eb;
}

.status-tag.accepted {
  background: #f0fdf4;
  color: #16a34a;
}

.status-tag.rejected {
  background: #fef2f2;
  color: #ef4444;
}

.status-tag.interview {
  background: #f5f3ff;
  color: #7c3aed;
}

.status-tag.online {
  background: #f0fdf4;
  color: #16a34a;
}

.status-tag.paused {
  background: #fef9ee;
  color: #b8860b;
}

.status-tag.closed {
  background: #f3f4f6;
  color: #9ca3af;
}

/* ========== 骨架屏 ========== */
.skeleton-wrap {
  padding: 0 4rpx;
}

.skeleton-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.skeleton-metric {
  background: #ffffff;
  border: 1rpx solid #f0f1f3;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
}

.sk-block {
  background: #ffffff;
  border: 1rpx solid #f0f1f3;
  border-radius: 16rpx;
  padding: 24rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.sk-h-60 {
  height: 320rpx;
}

.sk-list {
  background: #ffffff;
  border: 1rpx solid #f0f1f3;
  border-radius: 16rpx;
  overflow: hidden;
}

.sk-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.sk-row:last-child {
  border-bottom: none;
}

.sk-line {
  height: 20rpx;
  background: #f0f1f3;
  border-radius: 6rpx;
}

.sk-w-20 { width: 20%; }
.sk-w-30 { width: 30%; }
.sk-w-40 { width: 40%; }
.sk-w-50 { width: 50%; }
.sk-w-60 { width: 60%; }
.sk-w-70 { width: 70%; }
.sk-w-80 { width: 80%; }