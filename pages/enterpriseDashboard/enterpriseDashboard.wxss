/* 页面背景 */
.page {
  background-color: #f6f7f9;
  min-height: 100vh;
  font-family: "PingFang SC","Microsoft YaHei",sans-serif;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

/* 顶部导航 */
.header {
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 24rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

/* 内容区域 */
.content {
  padding: 16rpx;
  padding-top: 24rpx;
}

/* 分区标题 */
.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.section-more {
  font-size: 24rpx;
  color: #ff5c39;
}

/* 数据概览网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.stat-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stat-card:nth-child(4),
.stat-card:nth-child(5) {
  background: linear-gradient(135deg, #fff5f3 0%, #ffffff 100%);
  border: 1rpx solid rgba(255,92,57,0.1);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8rpx;
}

.stat-card:nth-child(4) .stat-value,
.stat-card:nth-child(5) .stat-value {
  color: #ff5c39;
}

.stat-label {
  font-size: 22rpx;
  color: #9ca3af;
}

/* AI推荐人才 */
.ai-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.ai-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.ai-info {
  flex: 1;
  min-width: 0;
}

.ai-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.ai-desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.ai-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.ai-tag {
  font-size: 20rpx;
  color: #ff5c39;
  background-color: #fff5f3;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.ai-match {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.match-score {
  font-size: 32rpx;
  font-weight: 700;
  color: #22c55e;
}

.match-label {
  font-size: 20rpx;
  color: #9ca3af;
}

/* 快捷入口网格 */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.quick-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
  padding: 24rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.quick-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.quick-icon.post {
  background: linear-gradient(135deg, #ff5c39 0%, #ff8c6b 100%);
}

.quick-icon.manage {
  background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
}

.quick-icon.apply {
  background: linear-gradient(135deg, #22c55e 0%, #4ade80 100%);
}

.quick-icon.talent {
  background: linear-gradient(135deg, #8b5cf6 0%, #a78bfa 100%);
}

.icon-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.quick-text {
  font-size: 24rpx;
  color: #111827;
  text-align: center;
}

/* 最近投递卡片 */
.app-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}
.app-info {
  flex: 1;
}
.app-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}
.app-job {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 4rpx;
}
.app-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}
.app-status.pending {
  background: #fef3c7;
  color: #d97706;
}
.app-status.viewed {
  background: #dbeafe;
  color: #2563eb;
}
.app-status.accepted {
  background: #d1fae5;
  color: #059669;
}
.app-status.rejected {
  background: #fee2e2;
  color: #dc2626;
}

/* 空状�?*/
.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-icon-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #9ca3af;
}

.empty-text {
  font-size: 28rpx;
  color: #111827;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #9ca3af;
  text-align: center;
  padding: 0 48rpx;
}

/* 骨架�?*/
.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 8rpx;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

.section-title-skeleton {
  width: 200rpx;
  height: 36rpx;
  margin-bottom: 16rpx;
}

.stat-card-skeleton {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.skeleton-value {
  width: 80rpx;
  height: 48rpx;
}

.skeleton-label {
  width: 100rpx;
  height: 28rpx;
}

.ai-card-skeleton {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.skeleton-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.skeleton-name {
  width: 160rpx;
  height: 32rpx;
}

.skeleton-desc {
  width: 280rpx;
  height: 24rpx;
}

.quick-card-skeleton {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.skeleton-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
}

.skeleton-text {
  width: 80rpx;
  height: 28rpx;
}

/* TabBar */
.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  height: 100%;
}

.tab-item.active .tab-text {
  color: #ff5c39;
}

.tab-icon {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-icon-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background-color: #999;
}

.tab-icon-dot.active {
  width: 24rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background-color: #ff5c39;
}

.tab-text {
  font-size: 22rpx;
  color: #999;
}

page { padding-bottom: 60px; }