<view class="page">

  <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-inner">
      <text class="header-title">招聘仪表盘</text>
      <text class="header-date">{{currentDate}}</text>
    </view>
  </view>

  <view class="content">

    <block wx:if="{{loading}}">
      <view class="skeleton-wrap">
        <view class="skeleton-grid">
          <view class="skeleton-metric" wx:for="{{4}}" wx:key="index">
            <view class="sk-line sk-w-30"></view>
            <view class="sk-line sk-w-50"></view>
            <view class="sk-line sk-w-20"></view>
          </view>
        </view>
        <view class="sk-block"></view>
        <view class="sk-block sk-h-60"></view>
        <view class="sk-list">
          <view class="sk-row" wx:for="{{5}}" wx:key="index">
            <view class="sk-line sk-w-70"></view>
            <view class="sk-line sk-w-30"></view>
          </view>
        </view>
      </view>
    </block>

    <block wx:else>

      <!-- ============ 第一屏：核心指标 ============ -->
      <view class="section">
        <view class="section-head">
          <text class="section-title">核心指标</text>
          <view class="section-tag">今日</view>
        </view>
        <view class="metric-grid">
          <view class="metric-card" wx:for="{{metricList}}" wx:key="key" hover-class="metric-hover">
            <view class="metric-value">{{item.value}}<text class="metric-unit" wx:if="{{item.unit}}">{{item.unit}}</text></view>
            <view class="metric-label">{{item.label}}</view>
            <view class="metric-change {{item.trend > 0 ? 'up' : 'down'}}">
              <text wx:if="{{item.trend > 0}}">↑</text>
              <text wx:else>↓</text>
              {{item.trend}}%
            </view>
          </view>
        </view>
      </view>

      <!-- ============ 第二屏：投递趋势 ============ -->
      <view class="section">
        <view class="section-head">
          <text class="section-title">投递趋势</text>
          <view class="section-tag">近7日</view>
        </view>
        <view class="card chart-card">
          <canvas type="2d" id="trendChart" class="chart-canvas"></canvas>
        </view>
      </view>

      <!-- ============ 第三屏：招聘漏斗 ============ -->
      <view class="section">
        <view class="section-head">
          <text class="section-title">招聘漏斗</text>
          <view class="section-tag">近30日</view>
        </view>
        <view class="card funnel-card">
          <view class="funnel-step" wx:for="{{funnel}}" wx:key="stage" hover-class="funnel-hover">
            <view class="funnel-labels">
              <text class="funnel-stage">{{item.stage}}</text>
              <text class="funnel-count">{{item.count}}</text>
            </view>
            <view class="funnel-bar-bg">
              <view class="funnel-bar" style="width: {{item.percentage}}%; background-color: {{item.barColor}};"></view>
            </view>
            <text class="funnel-rate">{{item.percentage}}%</text>
          </view>
        </view>
      </view>

      <!-- ============ 第四屏：业务列表 ============ -->
      <!-- 最近投递 -->
      <view class="section">
        <view class="section-head">
          <text class="section-title">最近投递</text>
          <text class="section-more" hover-class="more-hover">查看全部 →</text>
        </view>
        <view class="card list-card">
          <view class="list-row" wx:for="{{recentApplications}}" wx:key="id" hover-class="row-hover">
            <view class="row-left">
              <view class="row-avatar">{{item.name[0]}}</view>
              <view class="row-info">
                <view class="row-top">
                  <text class="row-name">{{item.name}}</text>
                  <view class="status-tag {{item.statusClass}}">{{item.statusText}}</view>
                </view>
                <view class="row-meta">{{item.job}} · {{item.company}}</view>
              </view>
            </view>
            <text class="row-time">{{item.time}}</text>
          </view>
        </view>
      </view>

      <!-- 最新发布岗位 -->
      <view class="section">
        <view class="section-head">
          <text class="section-title">最新发布岗位</text>
          <text class="section-more" hover-class="more-hover">查看全部 →</text>
        </view>
        <view class="card list-card">
          <view class="list-row" wx:for="{{recentJobs}}" wx:key="id" hover-class="row-hover">
            <view class="row-left">
              <view class="row-icon">职</view>
              <view class="row-info">
                <view class="row-top">
                  <text class="row-name">{{item.title}}</text>
                  <view class="status-tag {{item.statusClass}}">{{item.statusText}}</view>
                </view>
                <view class="row-meta">{{item.company}} · {{item.salary}}</view>
              </view>
            </view>
            <text class="row-time">{{item.time}}</text>
          </view>
        </view>
      </view>

    </block>

  </view>

</view>