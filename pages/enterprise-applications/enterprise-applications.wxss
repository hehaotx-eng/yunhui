.page {
  min-height: 100vh;
  background: #f6f7f9;
  padding-bottom: 40rpx;
}

.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255,255,255,.25);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 44rpx;
  color: #1a1a2e;
  font-weight: 300;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.nav-placeholder {
  width: 60rpx;
}

.body {
  padding: 0 20rpx 40rpx;
}

.tabs {
  display: flex;
  white-space: nowrap;
  padding: 16rpx 0;
}

.tab {
  display: inline-flex;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #6b7280;
  background: #f3f4f6;
  border-radius: 40rpx;
  font-weight: 500;
}

.tab.active {
  background: #1a1a2e;
  color: #fff;
  font-weight: 600;
}

.list {
  padding-top: 8rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.app-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.app-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #299ff0, #5ab8f5);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.app-detail {
  flex: 1;
  min-width: 0;
}

.app-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
}

.app-job {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 4rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.app-time {
  font-size: 22rpx;
  color: #c0c4cc;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.card-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f3f4f6;
}

.action-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.status-pending { background: #fef9ee; color: #d48806; }
.status-viewed { background: #e6f4ff; color: #1677ff; }
.status-accepted { background: #f0f9eb; color: #389e0d; }
.status-rejected { background: #fff2f0; color: #cf1322; }

.action-btns {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-weight: 500;
}

.action-btn.pass {
  background: rgba(34, 197, 94, .1);
  color: #22c55e;
}

.action-btn.fail {
  background: rgba(239, 68, 68, .1);
  color: #ef4444;
}

.resume-btn {
  background: rgba(41, 159, 240, .1);
  color: #299ff0;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

.loading {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: #9ca3af;
}
