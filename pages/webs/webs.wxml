<wxs src="../../utils/wxs.wxs" module="wxs" />
<view class="feed-page">
  <view class="top-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <text class="nav-logo">公司</text>
      <view class="nav-search">
        <image class="search-icon" src="/pages/image/sousuo.png" />
        <input class="search-input" placeholder="搜索公司名称、行业" placeholder-class="search-placeholder" value="{{keyword}}" bindinput="onKeywordInput" bindconfirm="onSearch" confirm-type="search" />
        <view wx:if="{{keyword}}" class="search-clear" bindtap="clearKeyword">x</view>
      </view>
    </view>
  </view>

  <view class="page-body" style="padding-top: {{statusBarHeight + 44}}px;">
    <view wx:if="{{skeleton}}" class="skeleton-wrap">
      <view class="skeleton-card skeleton-animate" wx:for="{{[1,2,3,4]}}" wx:key="*this">
        <view class="skeleton-logo-title">
          <view class="skeleton-logo"></view>
          <view class="skeleton-title-block">
            <view class="skeleton-title-line"></view>
            <view class="skeleton-subtitle"></view>
          </view>
        </view>
        <view class="skeleton-tags">
          <view class="skeleton-tag"></view>
          <view class="skeleton-tag"></view>
        </view>
      </view>
    </view>

    <view wx:if="{{!skeleton}}" class="company-list">
      <view wx:if="{{showEmpty}}" class="empty-card">
        <view class="empty-icon-wrap">
          <view class="empty-icon">🏢</view>
        </view>
        <view class="empty-text">暂无符合条件的公司</view>
        <view class="empty-tip">试试调整搜索条件</view>
      </view>

      <view wx:for="{{companies}}" wx:key="id" class="company-card" data-id="{{item.id}}" bindtap="goDetail">
        <view class="card-main">
          <view class="card-logo">
            <image wx:if="{{item._logo}}" src="{{item._logo}}" mode="aspectFill" />
            <text wx:else>{{wxs.firstChar(item.name)}}</text>
          </view>
          <view class="card-body">
            <view class="card-name-row">
              <text class="card-name line-clamp-1">{{item.name}}</text>
              <text wx:if="{{item.verified}}" class="verified-tag">已认证</text>
            </view>
            <view class="card-meta">
              <text wx:if="{{item.address}}" class="meta-item">{{item.address}}</text>
              <text wx:if="{{item.contact_name}}" class="meta-item">联系人: {{item.contact_name}}</text>
            </view>
            <text wx:if="{{item.description}}" class="card-desc line-clamp-1">{{item.description}}</text>
            <view class="card-jobs" wx:if="{{item.job_count > 0}}">
              <text class="jobs-icon">💼</text>
              <text class="jobs-text">{{item.job_count}}个在招职位</text>
            </view>
          </view>
          <view class="card-arrow">›</view>
        </view>
      </view>

      <view wx:if="{{loadingMore}}" class="loading-more">
        <view class="loading-spinner"></view>
        <text class="loading-text">加载中...</text>
      </view>
      <view wx:if="{{!hasMore && companies.length > 0}}" class="no-more">
        <view class="no-more-line"></view>
        <text class="no-more-text">已经到底了</text>
        <view class="no-more-line"></view>
      </view>
    </view>
  </view>
</view>

<custom-tab-bar />
