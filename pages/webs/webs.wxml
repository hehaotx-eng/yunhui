<!--pages/webs/webs.wxml-->
<view class="page">
  <view class="header">
    <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
    
    <view class="search-bar">
      <view class="search-box">
        <image class="search-icon" src="/pages/image/sousuo.png" mode="aspectFit" />
        <input 
          class="search-input" 
          placeholder="请输入职位或企业名称" 
          placeholder-class="search-placeholder"
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
          confirm-type="search"
          bindconfirm="onSearch"
        />
      </view>
      <view class="search-actions">
        <view class="action-btn">
          <image class="action-icon" src="/pages/image/qiehuan.png" mode="aspectFit" />
        </view>
        <view class="action-btn">
          <image class="action-icon" src="/pages/image/qiehuan.png" mode="aspectFit" />
        </view>
      </view>
    </view>
  </view>

  <view class="filter-bar-wrapper">
    <scroll-view class="filter-bar" scroll-x>
      <view 
        wx:for="{{filters}}" 
        wx:key="id" 
        class="filter-item {{activeFilter === item.id ? 'active' : ''}}"
        bindtap="switchFilter"
        data-id="{{item.id}}"
      >
        <text>{{item.name}}</text>
        <text wx:if="{{item.hasArrow}}" class="filter-arrow">▾</text>
      </view>
    </scroll-view>
  </view>

  <scroll-view class="job-list" scroll-y bindscrolltolower="onReachBottom">
    <view 
      wx:for="{{jobs}}" 
      wx:key="id" 
      class="job-card"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >
      <view wx:if="{{item.tags && item.tags.length > 0}}" class="job-tag hot">急聘</view>
      
      <view class="job-title">{{item.title}}</view>
      
      <view class="job-meta">
        <view class="job-salary">{{item.salary}} <text class="salary-unit">元/月</text></view>
        <view class="job-time">{{formatTime(item.createdAt)}}</view>
      </view>
      
      <view class="welfare-list">
        <view class="welfare-tag">{{item.area}}</view>
        <view wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="welfare-tag">{{tag}}</view>
        <view wx:if="{{item.tags && item.tags.length > 3}}" class="welfare-tag more">...</view>
      </view>
      
      <view class="job-footer">
        <view class="company-info">
          <view class="company-logo">
            <text class="logo-text">{{item.enterpriseName && item.enterpriseName.charAt(0) || '企'}}</text>
          </view>
          <view class="company-detail">
            <view class="company-contact">{{item.contactName}}</view>
            <view class="company-name">
              {{item.enterpriseName}}
              <text class="verify-badge">✓</text>
            </view>
          </view>
        </view>
        <view class="btn-call" catchtap="callPhone" data-phone="{{item.contactPhone}}">拨打电话</view>
      </view>
    </view>

    <view wx:if="{{loading}}" class="loading-more">
      <text>加载中...</text>
    </view>
    <view wx:if="{{!hasMore && jobs.length > 0}}" class="no-more">
      <text>没有更多了</text>
    </view>
  </scroll-view>
</view>