<view class="page">
  <view class="header">
    <view class="header-text">职位机会</view>
  </view>

  <view class="search-bar">
    <view class="search-wrapper">
      <image class="icon-search" src="/pages/image/sousuo.png" />
      <input class="search-input" placeholder="搜索职位 / 公司 / 技能" value="{{keyword}}" bindinput="onKeywordInput" bindconfirm="onSearch" confirm-type="search" />
    </view>
  </view>

  <view class="filter-scroll">
    <view wx:for="{{filters}}" wx:key="id" class="filter-item {{activeFilter === item.id ? 'active' : ''}}" data-id="{{item.id}}" bindtap="switchFilter">{{item.name}}</view>
  </view>

  <view class="job-list">
    <view wx:for="{{jobs}}" wx:key="id" class="job-card" data-id="{{item.id}}" bindtap="goDetail">
      <view wx:if="{{item.tag}}" class="job-tag">{{item.tag}}</view>
      <view class="job-title">{{item.title}}</view>
      <view class="job-meta">
        <view class="job-salary">{{item.salary || '薪资面议'}}</view>
        <view class="job-time">{{item.time || '近期发布'}}</view>
      </view>
      <view class="welfare-list">
        <view wx:for="{{item.tags || item.welfare}}" wx:for-item="w" wx:key="*this" class="welfare-tag">{{w}}</view>
      </view>
      <view class="job-footer">
        <view class="company-info">
          <view class="company-logo">{{item.enterpriseName ? item.enterpriseName.substring(0,1) : '企'}}</view>
          <view class="company-detail">
            <view class="company-contact">{{item.enterpriseName || '企业信息待完善'}}</view>
            <view class="company-name">{{item.area || '地区不限'}} · {{item.experience || '经验不限'}} · {{item.education || '学历不限'}}</view>
          </view>
        </view>
        <view class="btn-call" catchtap="callPhone" data-phone="{{item.contactPhone}}">电话</view>
      </view>
    </view>

    <view wx:if="{{showEmpty}}" class="empty-card">
      <view class="empty-icon">💼</view>
      <view class="empty-text">暂无职位</view>
    </view>
    <view wx:if="{{loading}}" class="loading">加载中...</view>
    <view wx:if="{{showNoMore}}" class="loading">没有更多了</view>
  </view>
</view>