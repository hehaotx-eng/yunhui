<wxs src="../../utils/wxs.wxs" module="wxs" />
<view class="feed-page">
  <view class="top-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <text class="nav-logo">职位</text>
      <view class="nav-search">
        <image class="search-icon" src="/pages/image/sousuo.png" />
        <input class="search-input" placeholder="搜索职位、公司、技能" placeholder-class="search-placeholder" value="{{keyword}}" bindinput="onKeywordInput" bindconfirm="onSearch" confirm-type="search" />
        <view wx:if="{{keyword}}" class="search-clear" bindtap="clearKeyword">x</view>
      </view>
    </view>
  </view>

  <view class="filter-wrap" style="margin-top: {{statusBarHeight + 44}}px;">
    <view class="filter-section">
      <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="filter-item {{activeCity === '' ? 'active' : ''}}" bindtap="switchCity" data-city="">全国</view>
        <view wx:for="{{cities}}" wx:key="*this" class="filter-item {{activeCity === item ? 'active' : ''}}" bindtap="switchCity" data-city="{{item}}">{{item}}</view>
      </scroll-view>
      <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="filter-item {{activeCategory === '' ? 'active' : ''}}" bindtap="switchCategory" data-category="">全部分类</view>
        <view wx:for="{{categories}}" wx:key="id" class="filter-item {{activeCategory === item.id ? 'active' : ''}}" bindtap="switchCategory" data-category="{{item.id}}">{{item.name}}</view>
      </scroll-view>
      <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view wx:for="{{salaryRanges}}" wx:key="id" class="filter-item {{activeSalary === item.id ? 'active' : ''}}" bindtap="switchSalary" data-salary="{{item.id}}">{{item.name}}</view>
      </scroll-view>
    </view>

    <view wx:if="{{activeTags.length > 0}}" class="active-tags">
      <view class="tag-list">
        <view wx:for="{{activeTags}}" wx:key="type" class="active-tag">
          <text class="tag-text">{{item.label}}</text>
          <view class="tag-remove" bindtap="removeTag" data-type="{{item.type}}">x</view>
        </view>
        <view class="clear-all-tags" bindtap="clearAllTags">清除全部</view>
      </view>
    </view>
  </view>

  <view wx:if="{{skeleton}}" class="skeleton-wrap">
    <view class="skeleton-card skeleton-animate" wx:for="{{[1,2,3,4]}}" wx:key="*this">
      <view class="skeleton-title"></view>
      <view class="skeleton-salary"></view>
      <view class="skeleton-tags">
        <view class="skeleton-tag"></view>
        <view class="skeleton-tag"></view>
        <view class="skeleton-tag"></view>
      </view>
      <view class="skeleton-footer">
        <view class="skeleton-company"></view>
        <view class="skeleton-btn"></view>
      </view>
    </view>
  </view>

  <view wx:if="{{!skeleton}}" class="job-list">
    <view wx:if="{{showEmpty}}" class="empty-card">
      <view class="empty-icon-wrap">
        <view class="empty-icon">💼</view>
      </view>
      <view class="empty-text">暂无符合条件的职位</view>
      <view class="empty-tip">试试调整筛选条件</view>
    </view>

    <view wx:for="{{jobs}}" wx:key="id" class="job-card" data-id="{{item.id}}" bindtap="goDetail">
      <view class="card-row-top">
        <text class="card-title line-clamp-1">{{item.title}}</text>
        <text class="card-salary">{{item.salary || (item.salary_min && item.salary_max ? (item.salary_min) + '-' + (item.salary_max) + '元' : item.salary_min ? (item.salary_min) + '元起' : '面议')}}</text>
      </view>
      <view class="card-tags" wx:if="{{item.tags && item.tags.length > 0}}">
        <text class="card-tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="card-tags" wx:else>
        <text wx:if="{{item.experience}}" class="card-tag">{{item.experience}}</text>
        <text wx:if="{{item.education}}" class="card-tag">{{item.education}}</text>
      </view>
      <view class="card-row-bottom">
        <view class="company-info-left">
          <view class="company-logo">
            <image wx:if="{{item.company_logo || item.logo || item.enterprise_logo}}" src="{{item.company_logo || item.logo || item.enterprise_logo}}" mode="aspectFill" />
            <text wx:else>{{wxs.firstChar(item.company_name || item.enterpriseName || item.enterprise_name)}}</text>
          </view>
          <text class="company-name line-clamp-1">{{item.company_name || item.enterpriseName || item.enterprise_name || ''}}</text>
        </view>
        <view class="card-info-right">
          <text class="info-location">{{item.location || item.city || item.area || ''}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{loadingMore}}" class="loading-more">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
    <view wx:if="{{!hasMore && jobs.length > 0}}" class="no-more">
      <view class="no-more-line"></view>
      <text class="no-more-text">已经到底了</text>
      <view class="no-more-line"></view>
    </view>
  </view>

  <view wx:if="{{loading && !skeleton && !loadingMore}}" class="global-loading">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>
</view>

<custom-tab-bar />
