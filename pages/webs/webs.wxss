page {
  background: #f6f7f9;
  min-height: 100vh;
}

.page {
  min-height: 100vh;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  padding-bottom: 40rpx;
}

/* ==========================
   Navigation Bar
========================== */

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 24rpx 20rpx;
}

.nav-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
}

.nav-ai-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(99,102,241,0.3);
}

.ai-icon-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #ffffff;
  background: rgba(255,255,255,0.2);
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
}

.ai-btn-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 600;
}

/* ==========================
   Search Section
========================== */

.search-section {
  position: fixed;
  top: 140rpx;
  left: 0;
  right: 0;
  z-index: 99;
  background: #ffffff;
  padding: 16rpx 24rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-wrapper {
  flex: 1;
  height: 80rpx;
  background: #f3f4f6;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  transition: all 0.3s ease;
}

.search-wrapper:focus-within {
  background: #ffffff;
  box-shadow: 0 0 0 2rpx #00a2ff;
}

.icon-search {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #111827;
}

.search-placeholder {
  color: #9ca3af;
}

.search-clear {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #d1d5db;
  border-radius: 50%;
  color: #ffffff;
  font-size: 20rpx;
  flex-shrink: 0;
}

/* ==========================
   AI Search Panel
========================== */

.ai-search-panel {
  position: fixed;
  top: 240rpx;
  left: 0;
  right: 0;
  z-index: 98;
  background: #ffffff;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.08);
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.ai-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.ai-panel-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.ai-panel-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f4f6;
  border-radius: 50%;
  color: #6b7280;
  font-size: 24rpx;
}

.ai-input-wrap {
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #e5e7eb;
}

.ai-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #111827;
  line-height: 1.6;
}

.ai-placeholder {
  color: #9ca3af;
  font-size: 26rpx;
}

.ai-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.ai-tag {
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, rgba(99,102,241,0.08) 0%, rgba(139,92,246,0.08) 100%);
  border: 1rpx solid rgba(99,102,241,0.2);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #6366f1;
}

.ai-submit-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  opacity: 0.6;
  transition: all 0.3s ease;
}

.ai-submit-btn.active {
  opacity: 1;
  box-shadow: 0 8rpx 24rpx rgba(99,102,241,0.3);
}

/* ==========================
   Filter Section
========================== */

.filter-section {
  position: fixed;
  top: 240rpx;
  left: 0;
  right: 0;
  z-index: 97;
  background: #ffffff;
  padding: 0 0 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(15,23,42,.03);
}

.filter-scroll {
  white-space: nowrap;
  padding: 12rpx 24rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.filter-scroll::-webkit-scrollbar {
  display: none;
}

.filter-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  padding: 0 24rpx;
  margin-right: 12rpx;
  background: #f3f4f6;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
  transition: all 0.2s ease;
}

.filter-item.active {
  background: #111827;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(17,24,39,0.2);
}

/* ==========================
   Active Tags
========================== */

.active-tags {
  position: fixed;
  top: 480rpx;
  left: 0;
  right: 0;
  z-index: 96;
  background: #ffffff;
  padding: 12rpx 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.tag-list {
  display: flex;
  align-items: center;
  gap: 12rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.tag-list::-webkit-scrollbar {
  display: none;
}

.active-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: rgba(0,162,255,0.08);
  border: 1rpx solid rgba(0,162,255,0.2);
  border-radius: 8rpx;
  flex-shrink: 0;
}

.tag-text {
  font-size: 22rpx;
  color: #00a2ff;
}

.tag-remove {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,162,255,0.2);
  border-radius: 50%;
  color: #00a2ff;
  font-size: 16rpx;
}

.clear-all-tags {
  font-size: 22rpx;
  color: #9ca3af;
  margin-left: auto;
  flex-shrink: 0;
}

/* ==========================
   Skeleton
========================== */

.skeleton-wrap {
  padding: 24rpx;
  margin-top: 480rpx;
}

.skeleton-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
}

.skeleton-title {
  width: 60%;
  height: 40rpx;
  background: #e5e7eb;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.skeleton-salary {
  width: 30%;
  height: 48rpx;
  background: #e5e7eb;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.skeleton-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.skeleton-tag {
  width: 120rpx;
  height: 40rpx;
  background: #e5e7eb;
  border-radius: 8rpx;
}

.skeleton-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f3f4f6;
}

.skeleton-company {
  width: 200rpx;
  height: 36rpx;
  background: #e5e7eb;
  border-radius: 8rpx;
}

.skeleton-btn {
  width: 120rpx;
  height: 48rpx;
  background: #e5e7eb;
  border-radius: 12rpx;
}

.skeleton-animate {
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

@keyframes skeleton-loading {
  0% { opacity: 1; }
  50% { opacity: 0.5; }
  100% { opacity: 1; }
}

/* ==========================
   Job List
========================== */

.job-list {
  padding: 24rpx;
  margin-top: 480rpx;
}

.job-list.has-tags {
  margin-top: 540rpx;
}

/* ==========================
   Job Card
========================== */

.job-card {
  position: relative;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
  transition: all 0.2s ease;
}

.job-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(15,23,42,.06);
}

/* VIP标签 */

.job-vip-tag {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(245,158,11,0.3);
}

/* 职位标题 */

.job-title-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.job-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.4;
  flex: 1;
  padding-right: 80rpx;
}

/* 薪资区域 */

.job-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.job-salary {
  display: flex;
  align-items: baseline;
}

.salary-num {
  font-size: 38rpx;
  font-weight: 700;
  color: #ff5c39;
}

.job-location {
  font-size: 24rpx;
  color: #9ca3af;
  background: #f3f4f6;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

/* ==========================
   Welfare
========================== */

.welfare-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.welfare-tag {
  padding: 6rpx 14rpx;
  background: #f5f6f8;
  border: 1rpx solid #e8ebf0;
  border-radius: 8rpx;
  color: #667085;
  font-size: 22rpx;
}

.welfare-tag.experience {
  background: rgba(0,162,255,0.06);
  border-color: rgba(0,162,255,0.15);
  color: #00a2ff;
}

.welfare-tag.education {
  background: rgba(99,102,241,0.06);
  border-color: rgba(99,102,241,0.15);
  color: #6366f1;
}

/* ==========================
   Footer
========================== */

.job-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid #f3f4f6;
}

/* 企业信息 */

.company-info {
  flex: 1;
  display: flex;
  align-items: center;
  overflow: hidden;
}

.company-logo {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  flex-shrink: 0;
}

.company-logo-placeholder {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #6b7280;
  flex-shrink: 0;
}

.company-detail {
  margin-left: 14rpx;
  overflow: hidden;
}

.company-name {
  font-size: 26rpx;
  color: #374151;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-time {
  font-size: 22rpx;
  color: #9ca3af;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ==========================
   Empty State
========================== */

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
  border-radius: 40rpx;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #374151;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #9ca3af;
}

/* ==========================
   Loading
========================== */

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 40rpx 0;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #e5e7eb;
  border-top-color: #00a2ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: #9ca3af;
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 40rpx 0;
}

.no-more-line {
  width: 80rpx;
  height: 2rpx;
  background: #e5e7eb;
}

.no-more-text {
  font-size: 24rpx;
  color: #d1d5db;
}

.global-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 80rpx 0;
  font-size: 28rpx;
  color: #9ca3af;
}

/* ==========================
   Responsive Adjustments
========================== */

@media screen and (max-width: 375px) {
  .filter-item {
    padding: 0 16rpx;
    font-size: 22rpx;
  }
  
  .job-title {
    font-size: 30rpx;
  }
  
  .salary-num {
    font-size: 34rpx;
  }
}

page { padding-bottom: 60px; }