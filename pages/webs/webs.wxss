page {
  background: #f6f7f9;
  min-height: 100vh;
}

.feed-page {
  min-height: 100vh;
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
}

.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255,255,255,.25);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  gap: 20rpx;
}

.nav-logo {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a1a2e;
  flex-shrink: 0;
}

.nav-search {
  flex: 1;
  max-width: 440rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #f3f4f6;
  border-radius: 32rpx;
  padding: 0 20rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 24rpx;
  color: #1a1a2e;
  background: transparent;
}

.search-placeholder {
  color: #9ca3af;
  font-size: 24rpx;
}

.search-clear {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #d1d5db;
  border-radius: 50%;
  color: #fff;
  font-size: 20rpx;
  flex-shrink: 0;
}

.filter-wrap {
  background: linear-gradient(180deg, rgba(41, 159, 240, 0.1) 0%, transparent 60rpx), #fff;
}

.filter-section {
  padding: 0 0 12rpx;
}

.filter-scroll {
  white-space: nowrap;
  padding: 12rpx 24rpx 0;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.filter-scroll::-webkit-scrollbar {
  display: none;
}

.filter-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  padding: 0 24rpx;
  margin-right: 12rpx;
  background: #f3f4f6;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
  transition: all .2s ease;
}

.filter-item.active {
  background: #1a1a2e;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(17,24,39,.2);
}

.active-tags {
  padding: 12rpx 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.tag-list {
  display: flex;
  align-items: center;
  gap: 12rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.tag-list::-webkit-scrollbar {
  display: none;
}

.active-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: rgba(0,162,255,.08);
  border: 1rpx solid rgba(0,162,255,.2);
  border-radius: 8rpx;
  flex-shrink: 0;
}

.tag-text {
  font-size: 22rpx;
  color: #00a2ff;
}

.tag-remove {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,162,255,.2);
  border-radius: 50%;
  color: #00a2ff;
  font-size: 16rpx;
}

.clear-all-tags {
  font-size: 22rpx;
  color: #9ca3af;
  margin-left: auto;
  flex-shrink: 0;
}

.skeleton-wrap {
  padding: 24rpx;
}

.skeleton-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
}

.skeleton-title {
  width: 60%;
  height: 40rpx;
  background: #e5e7eb;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.skeleton-salary {
  width: 30%;
  height: 48rpx;
  background: #e5e7eb;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.skeleton-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.skeleton-tag {
  width: 120rpx;
  height: 40rpx;
  background: #e5e7eb;
  border-radius: 8rpx;
}

.skeleton-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f3f4f6;
}

.skeleton-company {
  width: 200rpx;
  height: 36rpx;
  background: #e5e7eb;
  border-radius: 8rpx;
}

.skeleton-btn {
  width: 120rpx;
  height: 48rpx;
  background: #e5e7eb;
  border-radius: 12rpx;
}

.skeleton-animate {
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

@keyframes skeleton-loading {
  0% { opacity: 1; }
  50% { opacity: .5; }
  100% { opacity: 1; }
}

.job-list {
  padding: 24rpx;
}

.job-card {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 0 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}

.card-row-top {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-salary {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff5c39;
  flex-shrink: 0;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.card-tag {
  font-size: 22rpx;
  color: #6b7280;
  background: #f5f6f8;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.card-row-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.company-info-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.company-logo {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.company-logo image { width: 100%; height: 100%; }

.company-logo text {
  font-size: 22rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.company-name {
  font-size: 26rpx;
  color: #1a1a2e;
  max-width: 380rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-info-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-location {
  font-size: 24rpx;
  color: #9ca3af;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
  border-radius: 40rpx;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #374151;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #9ca3af;
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 40rpx 0;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #e5e7eb;
  border-top-color: #00a2ff;
  border-radius: 50%;
  animation: spin .8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #9ca3af;
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 40rpx 0;
}

.no-more-line {
  width: 80rpx;
  height: 2rpx;
  background: #e5e7eb;
}

.no-more-text {
  font-size: 24rpx;
  color: #d1d5db;
}

.global-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 80rpx 0;
  font-size: 28rpx;
  color: #9ca3af;
}

@media screen and (max-width: 375px) {
  .filter-item { padding: 0 16rpx; font-size: 22rpx; }
  .job-title { font-size: 30rpx; }
  .salary-num { font-size: 34rpx; }
}


