page {
  background: #f6f7f9;
}

.page {
  min-height: 100vh;
}

/* ==========================
   Header
========================== */

.header {
  padding: 120rpx 24rpx 24rpx;
}

.header-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #111827;
}

/* ==========================
   Search
========================== */

.search-bar {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.search-wrapper {
  height: 88rpx;

  background: #fff;

  border-radius: 20rpx;

  display: flex;
  align-items: center;

  padding: 0 24rpx;

  box-shadow:
    0 6rpx 20rpx rgba(15,23,42,.03);
}

.icon-search {
  width: 34rpx;
  height: 34rpx;
}

.search-input {
  flex: 1;

  margin-left: 16rpx;

  font-size: 28rpx;

  color: #111827;
}

/* ==========================
   Filter
========================== */

.filter-scroll {
  white-space: nowrap;

  padding: 0 24rpx;

  margin-bottom: 20rpx;
}

.filter-item {
  display: inline-flex;

  align-items: center;
  justify-content: center;

  height: 64rpx;

  padding: 0 24rpx;

  margin-right: 16rpx;

  background: #fff;

  border-radius: 12rpx;

  font-size: 26rpx;

  color: #6b7280;

  box-shadow:
    0 4rpx 12rpx rgba(15,23,42,.03);
}

.filter-item.active {
  background: #111827;
  color: #fff;
}

/* ==========================
   Job List
========================== */

.job-list {
  padding: 0 24rpx 40rpx;
}

/* ==========================
   Job Card
========================== */

.job-card {
  position: relative;

  background: #fff;

  border-radius: 24rpx;

  padding: 28rpx;

  margin-bottom: 20rpx;

  box-shadow:
    0 8rpx 24rpx rgba(15,23,42,.03);
}

/* 推荐标签 */

.job-tag {
  position: absolute;

  right: 24rpx;
  top: 24rpx;

  background: #fff3ee;

  color: #ff5c39;

  font-size: 22rpx;

  padding: 6rpx 12rpx;

  border-radius: 8rpx;
}

/* 职位名称 */

.job-title {
  font-size: 34rpx;

  font-weight: 700;

  color: #111827;

  line-height: 1.5;

  padding-right: 80rpx;
}

/* 薪资区域 */

.job-meta {
  margin-top: 16rpx;

  display: flex;

  justify-content: space-between;
  align-items: center;
}

.job-salary {
  font-size: 38rpx;

  font-weight: 700;

  color: #ff5c39;
}

.job-time {
  font-size: 24rpx;

  color: #9ca3af;
}

/* ==========================
   Welfare
========================== */

.welfare-list {
  display: flex;
  flex-wrap: wrap;

  gap: 10rpx;

  margin-top: 18rpx;
}

.welfare-tag {
  padding: 8rpx 16rpx;

  background: #f5f6f8;

  border: 1rpx solid #e8ebf0;

  border-radius: 8rpx;

  color: #667085;

  font-size: 22rpx;
}

/* ==========================
   Footer
========================== */

.job-footer {
  margin-top: 24rpx;

  padding-top: 24rpx;

  border-top: 1rpx solid #f3f4f6;

  display: flex;

  align-items: center;
  justify-content: space-between;
}

/* 企业信息 */

.company-info {
  flex: 1;

  display: flex;
  align-items: center;
}

.company-logo {
  width: 72rpx;
  height: 72rpx;

  border-radius: 16rpx;

  background: #f3f4f6;

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 28rpx;
  font-weight: 700;

  color: #111827;
}

.company-detail {
  margin-left: 16rpx;
}

.company-contact {
  font-size: 28rpx;

  color: #111827;

  font-weight: 600;
}

.company-name {
  margin-top: 8rpx;

  font-size: 24rpx;

  color: #9ca3af;
}

/* 电话按钮 */

.btn-call {
  height: 64rpx;

  padding: 0 24rpx;

  background: #ff5c39;

  border-radius: 12rpx;

  display: flex;
  align-items: center;
  justify-content: center;

  color: #fff;

  font-size: 24rpx;
  font-weight: 600;
}

/* ==========================
   Empty
========================== */

.empty-card {
  background: #fff;

  border-radius: 24rpx;

  padding: 100rpx 0;

  text-align: center;

  box-shadow:
    0 8rpx 24rpx rgba(15,23,42,.03);
}

.empty-icon {
  font-size: 90rpx;
}

.empty-text {
  margin-top: 20rpx;

  font-size: 28rpx;

  color: #9ca3af;
}

/* ==========================
   Loading
========================== */

.loading {
  text-align: center;

  padding: 40rpx 0;

  font-size: 26rpx;

  color: #9ca3af;
}