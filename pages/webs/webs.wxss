page {
  background: var(--c-bg);
  min-height: 100vh;
}

.feed-page {
  min-height: 100vh;
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
}

/* ── Top Navigation ── */
.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255,255,255,.75);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
  border-bottom: 1rpx solid rgba(0,0,0,.03);
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  gap: 20rpx;
}

.nav-logo {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--c-text);
  flex-shrink: 0;
  letter-spacing: 2rpx;
}

.nav-search {
  flex: 1;
  max-width: 440rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #f2f3f5;
  border-radius: 30rpx;
  padding: 0 16rpx;
  transition: all .2s;
}

.nav-search:focus-within {
  background: #eef0f2;
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: var(--fs-xs);
  color: var(--c-text);
  background: transparent;
}

.search-placeholder {
  color: var(--c-text-3);
  font-size: var(--fs-xs);
}

.search-clear {
  width: 30rpx;
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--c-text-3);
  border-radius: 50%;
  color: #fff;
  font-size: 18rpx;
  flex-shrink: 0;
  line-height: 1;
}

/* ── Filter Area ── */
.filter-wrap {
  background: #fff;
  border-bottom: 1rpx solid var(--c-border);
  padding: 14rpx 24rpx;
}

.filter-scroll {
  white-space: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.filter-scroll::-webkit-scrollbar {
  display: none;
}

.filter-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 52rpx;
  padding: 0 22rpx;
  margin-right: 10rpx;
  background: var(--c-bg);
  border-radius: 26rpx;
  font-size: var(--fs-xxs);
  color: var(--c-text-2);
  transition: all .25s ease;
  border: 1rpx solid transparent;
}

.filter-item.active {
  background: var(--c-accent-light);
  color: var(--c-accent);
  border-color: rgba(255,92,57,.15);
  font-weight: var(--fw-semibold);
}

/* ── Skeleton Loading ── */
.skeleton-wrap {
  padding: 24rpx;
}

.skeleton-card {
  background: var(--c-card);
  border-radius: var(--card-radius);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--card-shadow);
}

.skeleton-logo-title {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.skeleton-logo {
  width: 56rpx;
  height: 56rpx;
  background: var(--c-skeleton);
  border-radius: 14rpx;
  flex-shrink: 0;
}

.skeleton-title-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.skeleton-title-line {
  width: 70%;
  height: 32rpx;
  background: var(--c-skeleton);
  border-radius: 8rpx;
}

.skeleton-subtitle {
  width: 50%;
  height: 24rpx;
  background: var(--c-skeleton);
  border-radius: 8rpx;
}

.skeleton-tags {
  display: flex;
  gap: 10rpx;
}

.skeleton-tag {
  width: 100rpx;
  height: 34rpx;
  background: var(--c-skeleton);
  border-radius: 17rpx;
}

.skeleton-animate {
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

@keyframes skeleton-loading {
  0% { opacity: 1; }
  50% { opacity: .45; }
  100% { opacity: 1; }
}

/* ── Company Card ── */
.company-list {
  padding: 20rpx 20rpx 0;
}

.company-card {
  background: var(--c-card);
  border-radius: 20rpx;
  margin: 0 0 16rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(15,23,42,.04);
  transition: transform .2s ease, box-shadow .2s ease;
}

.company-card:active {
  transform: scale(.98);
  box-shadow: 0 1rpx 8rpx rgba(15,23,42,.06);
}

.card-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

/* ── Logo ── */
.card-logo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: var(--c-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.card-logo image {
  width: 100%;
  height: 100%;
}

.card-logo text {
  font-size: var(--fs-lg);
  font-weight: var(--fw-bold);
  color: var(--c-text);
}

/* ── Card Body ── */
.card-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.card-name {
  font-size: var(--fs-lg);
  font-weight: var(--fw-bold);
  color: var(--c-text);
  flex: 1;
  min-width: 0;
}

.verified-tag {
  font-size: 20rpx;
  color: #22c55e;
  background: rgba(34,197,94,.1);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: var(--fs-xs);
  color: var(--c-text-3);
}

.meta-item {
  display: flex;
  align-items: center;
}

.meta-item::before {
  content: '';
  display: inline-block;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: var(--c-text-3);
  margin-right: 12rpx;
}

.meta-item:first-child::before {
  display: none;
}

.card-desc {
  font-size: var(--fs-xs);
  color: var(--c-text-2);
  line-height: 1.5;
}

.card-jobs {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 4rpx;
}

.jobs-icon {
  font-size: 22rpx;
}

.jobs-text {
  font-size: var(--fs-xxs);
  color: var(--c-accent);
  font-weight: 500;
}

.card-arrow {
  font-size: 36rpx;
  color: var(--c-text-3);
  flex-shrink: 0;
}

/* ── Empty State ── */
.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: var(--c-card);
  border-radius: var(--card-radius);
  box-shadow: var(--card-shadow);
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--c-bg) 0%, #e5e7eb 100%);
  border-radius: 40rpx;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: var(--fs-md);
  color: var(--c-text);
  font-weight: var(--fw-medium);
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: var(--fs-xs);
  color: var(--c-text-3);
}

/* ── Loading States ── */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 40rpx 0;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid var(--c-border);
  border-top-color: var(--c-accent);
  border-radius: 50%;
  animation: spin .8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: var(--fs-xs);
  color: var(--c-text-3);
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 40rpx 0;
}

.no-more-line {
  width: 80rpx;
  height: 2rpx;
  background: var(--c-border);
}

.no-more-text {
  font-size: var(--fs-xs);
  color: var(--c-text-3);
}

@media screen and (max-width: 375px) {
  .filter-item { padding: 0 16rpx; font-size: var(--fs-xxs); }
  .card-name { font-size: var(--fs-md); }
  .card-logo { width: 64rpx; height: 64rpx; }
}
