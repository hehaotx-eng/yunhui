<!--pages/login/login.wxml-->
<view class="login-page">
  <view class="login-header">
    <view class="logo">
      <text class="logo-text">📝</text>
    </view>
    <view class="title">在线招聘</view>
  </view>

  <view class="login-form">
    <view class="form-item">
      <input 
        class="form-input" 
        placeholder="请输入邮箱" 
        bindinput="onEmailInput"
        value="{{email}}"
      />
    </view>

    <view class="form-item">
      <input 
        class="form-input" 
        type="password"
        placeholder="请输入密码" 
        bindinput="onPasswordInput"
        value="{{password}}"
      />
    </view>

    <view class="login-btn" bindtap="handleLogin">
      <text>登录</text>
    </view>

    <view class="other-links">
      <text class="link-item" bindtap="goRegister">注册账号</text>
      <text class="link-item" bindtap="goForgot">忘记密码</text>
    </view>
  </view>

  <view class="divider">
    <view class="line"></view>
    <text class="divider-text">其他方式</text>
    <view class="line"></view>
  </view>

  <view class="third-btns">
    <button
  open-type="getPhoneNumber"
  bindgetphonenumber="onGetPhoneNumber"
  class="wechat-btn"
>
  微信快捷登录
</button>

    <view class="third-btn" bindtap="phoneLogin">
      <text class="third-icon">📞</text>
      <text class="third-text">手机号登录</text>
    </view>
  </view>
</view>