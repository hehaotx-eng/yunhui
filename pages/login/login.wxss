/* pages/login/login.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #e8f0fe 0%, #f5f5f8 40%, #fff 100%);
  position: relative;
  overflow: hidden;
}

.page::before {
  content: '';
  position: absolute;
  top: -200rpx;
  right: -150rpx;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(74, 144, 217, 0.12) 0%, transparent 70%);
}

.page::after {
  content: '';
  position: absolute;
  bottom: -100rpx;
  left: -100rpx;
  width: 350rpx;
  height: 350rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(74, 144, 217, 0.08) 0%, transparent 70%);
}

.content {
  position: relative;
  z-index: 1;
  padding: 0 56rpx;
  padding-top: 160rpx;
}

/* ========== Logo 区域 ========== */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #4a90d9, #357abd);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(74, 144, 217, 0.35);
  margin-bottom: 36rpx;
  animation: logoFadeIn 0.8s ease forwards;
}

.logo-icon {
  font-size: 72rpx;
}

.app-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #222;
  letter-spacing: 4rpx;
  margin-bottom: 14rpx;
  animation: textSlideUp 0.8s ease 0.15s forwards;
  opacity: 0;
}

.app-subtitle {
  font-size: 26rpx;
  color: #999;
  letter-spacing: 2rpx;
  animation: textSlideUp 0.8s ease 0.3s forwards;
  opacity: 0;
}

/* ========== 登录按钮组 ========== */
.login-buttons {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  margin-bottom: 60rpx;
}

.login-btn {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid rgba(0, 0, 0, 0.03);
  transition: all 0.25s ease;
  opacity: 0;
  animation: btnSlideUp 0.6s ease forwards;
  position: relative;
}

.login-btn:nth-child(1) {
  animation-delay: 0.4s;
}

.login-btn:nth-child(2) {
  animation-delay: 0.55s;
}

.login-btn:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 微信隐藏按钮覆盖层 */
.wechat-btn {
  position: relative;
}

.wechat-hidden-btn {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  z-index: 10;
  opacity: 0;
}

.wechat-hidden-btn::after {
  border: none;
}

.btn-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.login-btn:nth-child(1) .btn-icon {
  background: linear-gradient(135deg, #e8f4fd, #d0ebff);
}

.login-btn:nth-child(2) .btn-icon {
  background: linear-gradient(135deg, #e8f8e8, #d0f0d0);
}

.btn-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.btn-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.btn-desc {
  font-size: 22rpx;
  color: #aaa;
}

.btn-arrow {
  font-size: 44rpx;
  color: #ccc;
  font-weight: 300;
  margin-left: 16rpx;
}

/* ========== 底部协议 ========== */
.agreement {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
  color: #aaa;
  animation: textSlideUp 0.8s ease 0.7s forwards;
  opacity: 0;
}

.link {
  color: #4a90d9;
  position: relative;
  padding-bottom: 2rpx;
}

.link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: #4a90d9;
  transform: scaleX(0);
  transition: transform 0.3s ease;
}

.link:active::after {
  transform: scaleX(1);
}

/* ========== 动画 ========== */
@keyframes logoFadeIn {
  from {
    opacity: 0;
    transform: scale(0.6);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes textSlideUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes btnSlideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
