/* pages/login/login.wxss */
.login-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.login-header {
  padding: 100rpx 40rpx 60rpx;
  text-align: center;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 30rpx;
  background: linear-gradient(135deg, #00a2ff, #0066ff);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-text {
  font-size: 56rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.login-form {
  padding: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border-radius: 44rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  border: 1rpx solid #eee;
}

.form-input:focus {
  border-color: #00a2ff;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #00a2ff, #0066ff);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}

.login-btn text {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
}

.other-links {
  display: flex;
  justify-content: center;
  gap: 80rpx;
  margin-top: 30rpx;
}

.link-item {
  font-size: 28rpx;
  color: #666;
}

.divider {
  display: flex;
  align-items: center;
  margin: 60rpx 40rpx 40rpx;
}

.line {
  flex: 1;
  height: 1rpx;
  background: #eee;
}

.divider-text {
  font-size: 26rpx;
  color: #999;
  padding: 0 30rpx;
}

.third-btns {
  display: flex;
  justify-content: center;
  gap: 120rpx;
}

.third-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.third-icon {
  width: 100rpx;
  height: 100rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.third-text {
  font-size: 28rpx;
  color: #666;
}

.wechat-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  box-shadow: none;
}

.wechat-btn::after {
  border: none;
}
