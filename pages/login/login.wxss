page {
  background: #f6f7f9;
  overflow: hidden;
  height: 100%;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.hero {
  padding: 240rpx 32rpx 80rpx;
}

.hero-title {
  font-size: 58rpx;
  font-weight: 700;
  color: #111827;
}

.hero-desc {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.6;
}

.btn-group {
  margin-top: 600rpx;
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.btn {
  margin-left: 5%;
  width: 90%;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  line-height: 96rpx;
  padding: 0;
  box-shadow: 0 16rpx 40rpx rgba(17, 24, 39, .10);
  background: none;
}

.btn::after {
  display: none;
}

.btn-wechat {
  background: #07C160;
  color: #fff;
}

.btn-phone {
  background: #111827;
  color: #fff;
}

.footer {
  margin-top: auto;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #9ca3af;
}

.footer-link {
  font-size: 22rpx;
  color: #111827;
}