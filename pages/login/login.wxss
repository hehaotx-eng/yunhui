.page { background: #f6f7f9; min-height: 100vh; padding: 180rpx 40rpx 60rpx; }

.nav { position: fixed; top: 0; left: 0; right: 0; height: 160rpx; padding-top: 60rpx; display: flex; align-items: center; justify-content: space-between; background: #f6f7f9; z-index: 100; }
.nav-left { width: 120rpx; display: flex; align-items: center; justify-content: center; }
.nav-back { font-size: 48rpx; color: #111827; font-weight: 500; }
.nav-right { width: 120rpx; }

.hero { margin-bottom: 40rpx; }
.title { margin-top: 28rpx; font-size: 52rpx; font-weight: 700; color: #111827; }
.subtitle { margin-top: 12rpx; font-size: 26rpx; color: #6b7280; }

.role-section { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 40rpx; }
.role-card { display: flex; align-items: center; background: #fff; border-radius: 24rpx; padding: 28rpx 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.04); border: 2rpx solid transparent; transition: all .2s; }
.role-card.active { border-color: #111827; background: #fafafa; }
.role-icon { font-size: 40rpx; margin-right: 16rpx; }
.role-info { flex: 1; }
.role-name { font-size: 30rpx; font-weight: 600; color: #111827; }
.role-desc { font-size: 24rpx; color: #9ca3af; margin-top: 4rpx; }
.role-check { width: 40rpx; height: 40rpx; border-radius: 50%; border: 2rpx solid #ddd; display: flex; align-items: center; justify-content: center; font-size: 22rpx; color: #fff; font-weight: 700; flex-shrink: 0; }
.role-check.checked { background: #111827; border-color: #111827; }

.login-card { background: #fff; border-radius: 32rpx; padding: 24rpx; box-shadow: 0 10rpx 30rpx rgba(15,23,42,.04); }
.action-primary { height: 92rpx; border-radius: 20rpx; background: #111827; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 600; }
.action-secondary { height: 92rpx; border-radius: 20rpx; background: #f8fafc; color: #111827; margin-top: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 30rpx; }

.agreement { margin-top: 32rpx; text-align: center; font-size: 22rpx; color: #9ca3af; }