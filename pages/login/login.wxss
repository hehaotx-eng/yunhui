/* 页面背景 */
.page {
  background: #f6f7f9;
  min-height: 100vh;
  padding: 180rpx 40rpx 60rpx;
}

/* 顶部导航 */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 160rpx;
  padding-top: 60rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f6f7f9;
  z-index: 100;
}

.nav-left {
  width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back {
  font-size: 48rpx;
  color: #111827;
  font-weight: 500;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.nav-right {
  width: 120rpx;
}

/* Hero 区 */
.hero {
  margin-bottom: 100rpx;
}

.badge {
  display: inline-flex;
  padding: 10rpx 20rpx;
  background: #ffffff;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #6b7280;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,.03);
}

.title {
  margin-top: 28rpx;
  font-size: 68rpx;
  font-weight: 700;
  color: #111827;
}

.subtitle {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.6;
}

/* 登录卡片 */
.login-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(15,23,42,.04);
}

.action-primary {
  height: 92rpx;
  border-radius: 20rpx;
  background: #111827;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.action-secondary {
  height: 92rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  color: #111827;
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

/* 用户协议 */
.agreement {
  margin-top: 32rpx;
  text-align: center;
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.7;
}