page {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #00a2ff 0%, #0080ff 100%);
  padding: 60rpx 32rpx 32rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  height: 140rpx;
  box-sizing: border-box;
}

.header-content {
  padding-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #fff;
}

.header-text {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.submit-btn {
  padding: 16rpx 40rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #fff;
  cursor: pointer;
  user-select: none;
}

.form-content {
  padding-top: calc(160rpx + env(safe-area-inset-top));
  padding-bottom: 40rpx;
  height: 100vh;
  box-sizing: border-box;
}

.form-section {
  background: #fff;
  margin: 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item.half {
  flex: 1;
}

.form-row {
  display: flex;
  gap: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-input.salary {
  width: 120rpx;
  text-align: center;
}

.salary-input {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.salary-separator {
  font-size: 28rpx;
  color: #999;
}

.salary-unit {
  font-size: 28rpx;
  color: #999;
}

.picker-value {
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  color: #999;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.welfare-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.welfare-tag {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
  position: relative;
  z-index: 1;
}

.welfare-tag.active {
  background: #00a2ff;
  color: #fff;
}

.status-options {
  display: flex;
  gap: 24rpx;
}

.status-option {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
}

.status-option.active {
  background: #00a2ff;
  color: #fff;
}