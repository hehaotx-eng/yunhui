/* ==================== 全局变量 ==================== */
page {
  --primary: #4F6EF7;
  --primary-light: #EEF1FE;
  --primary-dark: #3A56D4;
  --primary-gradient: linear-gradient(135deg, #4F6EF7 0%, #7C5CFC 100%);
  
  --success: #34C759;
  --warning: #FF9500;
  --danger: #FF3B30;
  --gray-1: #F7F8FA;
  --gray-2: #EDEEF2;
  --gray-3: #D1D3D8;
  --gray-4: #A8ABB3;
  --gray-5: #6E727D;
  --gray-6: #3D4047;
  --gray-7: #1C1E23;
  
  --radius-sm: 10rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  
  --shadow-sm: 0 2rpx 12rpx rgba(79, 110, 247, 0.08);
  --shadow-md: 0 8rpx 32rpx rgba(79, 110, 247, 0.12);
  --shadow-lg: 0 16rpx 48rpx rgba(79, 110, 247, 0.16);
  
  --font-base: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", "Helvetica Neue", sans-serif;
  
  background: #F5F6FA;
}

.page {
  position: relative;
  min-height: 100vh;
  background: #F5F6FA;
  font-family: var(--font-base);
  padding-bottom: 140rpx;
}

/* ==================== 进度条 ==================== */
.progress-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  height: 6rpx;
  background: var(--gray-2);
  border-radius: 0;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--primary-gradient);
  border-radius: 0;
  transition: width 0.5s cubic-bezier(0.22, 1, 0.36, 1);
}

/* ==================== 滚动容器 ==================== */
.body {
  height: 100vh;
  padding: 24rpx 28rpx 0;
  box-sizing: border-box;
}

/* ==================== 卡片区块 ==================== */
.section {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 32rpx 28rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  transition: box-shadow 0.25s ease;
}

.section:active {
  box-shadow: var(--shadow-md);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--gray-1);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--gray-7);
  letter-spacing: -0.5rpx;
}

.section-tag {
  font-size: 22rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: var(--primary-gradient);
  padding: 4rpx 18rpx;
  border-radius: 40rpx;
  letter-spacing: 0.5rpx;
}

.section-hint {
  font-size: 24rpx;
  color: var(--gray-4);
  font-weight: 400;
}

/* ==================== 表单字段 ==================== */
.field {
  margin-bottom: 28rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-6);
  margin-bottom: 12rpx;
  letter-spacing: 0.3rpx;
}

.field-input {
  width: 100%;
  height: 88rpx;
  background: var(--gray-1);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--gray-7);
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
  box-sizing: border-box;
}

.field-input:focus {
  background: #FFFFFF;
  border-color: var(--primary);
  box-shadow: 0 0 0 6rpx rgba(79, 110, 247, 0.08);
}

.field-input.filled {
  background: #FFFFFF;
  border-color: var(--gray-2);
}

.field-input.filled:focus {
  border-color: var(--primary);
}

.placeholder {
  color: var(--gray-4);
  font-weight: 400;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: var(--gray-4);
  margin-top: 8rpx;
  letter-spacing: 0.2rpx;
}

/* ==================== 工作类型网格 ==================== */
.type-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--gray-1);
  border-radius: var(--radius-md);
  padding: 20rpx 8rpx;
  border: 2rpx solid transparent;
  transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  cursor: pointer;
  min-height: 120rpx;
}

.type-item:active {
  transform: scale(0.96);
}

.type-item.active {
  background: var(--primary-light);
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx rgba(79, 110, 247, 0.1);
}

.type-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.type-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--gray-6);
  margin-bottom: 2rpx;
}

.type-desc {
  font-size: 20rpx;
  color: var(--gray-4);
}

.type-item.active .type-name {
  color: var(--primary-dark);
}

.type-item.active .type-desc {
  color: var(--primary);
}

/* ==================== VIP岗位切换 ==================== */
.vip-toggle {
  display: flex;
  gap: 16rpx;
}

.vip-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--gray-1);
  border-radius: var(--radius-md);
  padding: 24rpx 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  cursor: pointer;
  min-height: 140rpx;
}

.vip-option:active {
  transform: scale(0.96);
}

.vip-option.active {
  background: var(--primary-light);
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx rgba(79, 110, 247, 0.1);
}

.vip-option:first-child.active {
  border-color: var(--success);
  background: rgba(52, 199, 89, 0.08);
  box-shadow: 0 0 0 4rpx rgba(52, 199, 89, 0.1);
}

.vip-option:last-child.active {
  border-color: #f59e0b;
  background: rgba(245, 158, 11, 0.08);
  box-shadow: 0 0 0 4rpx rgba(245, 158, 11, 0.1);
}

.vip-opt-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.vip-opt-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-6);
  margin-bottom: 4rpx;
}

.vip-opt-desc {
  font-size: 20rpx;
  color: var(--gray-4);
}

.vip-option.active .vip-opt-name {
  color: var(--gray-7);
}

.vip-option:first-child.active .vip-opt-desc {
  color: var(--success);
}

.vip-option:last-child.active .vip-opt-desc {
  color: #b45309;
}

/* ==================== 薪资输入 ==================== */
.salary-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.salary-input-wrap {
  flex: 1;
}

.salary-input {
  text-align: center;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.salary-sep {
  font-size: 32rpx;
  font-weight: 300;
  color: var(--gray-3);
  padding: 0 4rpx;
}

.salary-quick {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.salary-chip {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--gray-5);
  background: var(--gray-1);
  padding: 8rpx 24rpx;
  border-radius: 40rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
  cursor: pointer;
}

.salary-chip:active {
  transform: scale(0.95);
}

.salary-chip.active {
  color: var(--primary);
  background: var(--primary-light);
  border-color: var(--primary);
}

/* ==================== 行内双栏 ==================== */
.field-row {
  display: flex;
  gap: 20rpx;
}

.field.half {
  flex: 1;
  margin-bottom: 0;
}

/* ==================== Picker 样式 ==================== */
.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-right: 20rpx;
  cursor: pointer;
}

.picker text:first-child {
  flex: 1;
  color: var(--gray-5);
}

.picker.filled text:first-child {
  color: var(--gray-7);
}

.picker-arrow {
  font-size: 36rpx;
  color: var(--gray-3);
  font-weight: 300;
  transform: rotate(90deg);
  display: inline-block;
  transition: transform 0.2s ease;
}

.picker:active .picker-arrow {
  transform: rotate(90deg) translateX(4rpx);
}

/* ==================== Textarea ==================== */
.field-textarea {
  width: 100%;
  min-height: 180rpx;
  background: var(--gray-1);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--gray-7);
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
  box-sizing: border-box;
  line-height: 1.6;
}

.field-textarea:focus {
  background: #FFFFFF;
  border-color: var(--primary);
  box-shadow: 0 0 0 6rpx rgba(79, 110, 247, 0.08);
}

.field-textarea.filled {
  background: #FFFFFF;
  border-color: var(--gray-2);
}

.field-textarea.filled:focus {
  border-color: var(--primary);
}

/* ==================== 标签区域 ==================== */
.tag-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.tag-input {
  flex: 1;
  height: 76rpx;
  background: var(--gray-1);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--gray-7);
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
  box-sizing: border-box;
}

.tag-input:focus {
  background: #FFFFFF;
  border-color: var(--primary);
  box-shadow: 0 0 0 6rpx rgba(79, 110, 247, 0.08);
}

.tag-add-btn {
  flex-shrink: 0;
  height: 76rpx;
  padding: 0 32rpx;
  background: var(--primary-gradient);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 16rpx rgba(79, 110, 247, 0.25);
}

.tag-add-btn:active {
  transform: scale(0.94);
  opacity: 0.85;
}

.tag-add-btn.hidden {
  visibility: hidden;
  opacity: 0;
}

.tag-preset-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 24rpx;
  background: var(--gray-1);
  border-radius: var(--radius-md);
  font-size: 26rpx;
  color: var(--gray-5);
  transition: all 0.2s ease;
  margin-bottom: 20rpx;
  border: 2rpx dashed var(--gray-3);
}

.tag-preset-btn:active {
  background: var(--primary-light);
  border-color: var(--primary);
  color: var(--primary);
}

.tag-preset-btn .picker-arrow {
  font-size: 32rpx;
  color: var(--gray-3);
}

.selected-tags {
  margin-top: 4rpx;
}

.selected-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.selected-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx 8rpx 24rpx;
  background: var(--primary-light);
  color: var(--primary-dark);
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 40rpx;
  border: 1rpx solid rgba(79, 110, 247, 0.15);
  transition: all 0.2s ease;
}

.selected-tag:active {
  transform: scale(0.95);
}

.tag-remove {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--primary);
  opacity: 0.6;
  margin-left: 2rpx;
  padding: 0 4rpx;
  transition: opacity 0.2s ease;
}

.tag-remove:active {
  opacity: 1;
  transform: scale(1.2);
}

/* ==================== 标签弹窗 ==================== */
.tag-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  animation: fadeIn 0.3s ease;
}

.tag-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 75vh;
  background: #FFFFFF;
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  display: flex;
  flex-direction: column;
  box-shadow: 0 -16rpx 64rpx rgba(0, 0, 0, 0.12);
}

.tag-modal.show {
  transform: translateY(0);
}

.tag-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 2rpx solid var(--gray-1);
  flex-shrink: 0;
}

.tag-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--gray-7);
}

.tag-modal-close {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  transition: all 0.2s ease;
}

.tag-modal-close:active {
  background: var(--primary-light);
}

.tag-modal-tabs {
  display: flex;
  padding: 16rpx 32rpx 8rpx;
  border-bottom: 2rpx solid var(--gray-1);
  flex-shrink: 0;
  white-space: nowrap;
}

.tag-modal-tab {
  display: inline-block;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--gray-4);
  padding: 12rpx 20rpx;
  margin-right: 12rpx;
  border-radius: var(--radius-sm);
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.tag-modal-tab.active {
  color: var(--primary);
  background: var(--primary-light);
  font-weight: 600;
}

.tag-modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx 40rpx;
  -webkit-overflow-scrolling: touch;
}

.tag-modal-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-modal-item {
  padding: 14rpx 28rpx;
  background: var(--gray-1);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--gray-5);
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
  cursor: pointer;
}

.tag-modal-item:active {
  transform: scale(0.94);
}

.tag-modal-item.active {
  background: var(--primary-light);
  color: var(--primary-dark);
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx rgba(79, 110, 247, 0.08);
}

/* ==================== 底部操作栏 ==================== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  padding: 16rpx 28rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 50;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.04);
}

.bar-inner {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.bar-btn {
  flex: 1;
  height: 96rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  cursor: pointer;
}

.bar-btn:active {
  transform: scale(0.97);
}

.bar-btn.preview {
  flex: 0.6;
  background: var(--gray-1);
  color: var(--gray-5);
  border: 2rpx solid var(--gray-2);
}

.bar-btn.preview:active {
  background: var(--gray-2);
}

.bar-btn.save {
  flex: 1.4;
  background: var(--primary-gradient);
  color: #FFFFFF;
  box-shadow: 0 8rpx 28rpx rgba(79, 110, 247, 0.3);
}

.bar-btn.save:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(79, 110, 247, 0.2);
}

.bar-btn.save.disabled {
  opacity: 0.6;
  pointer-events: none;
}

.save-loading {
  display: inline-block;
  animation: spin 1s linear infinite;
  margin-right: 12rpx;
  font-size: 32rpx;
}

/* ==================== 动画 ==================== */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes slideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.section {
  animation: slideUp 0.4s ease forwards;
}

.section:nth-child(2) {
  animation-delay: 0.08s;
}

.section:nth-child(3) {
  animation-delay: 0.16s;
}

/* ==================== 滚动条美化 ==================== */
::-webkit-scrollbar {
  width: 0;
  height: 0;
}

/* ==================== 工具类 ==================== */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ==================== 适配 ==================== */
@media screen and (max-width: 375px) {
  .type-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .field-row {
    flex-direction: column;
    gap: 28rpx;
  }
  
  .field.half {
    flex: none;
  }
}

@media screen and (min-width: 768px) {
  .page {
    max-width: 720rpx;
    margin: 0 auto;
  }
  
  .bottom-bar {
    max-width: 720rpx;
    left: 50%;
    transform: translateX(-50%);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }
}