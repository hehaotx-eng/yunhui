.page {
  min-height: 100vh;
  background: #f6f7f9;
  padding-bottom: 40rpx;
}

.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255,255,255,.25);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 44rpx;
  color: #1a1a2e;
  font-weight: 300;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.nav-placeholder {
  width: 60rpx;
}

.body {
  height: 100vh;
  padding: 0 20rpx 40rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.field {
  margin-bottom: 20rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.field-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.field.half {
  flex: 1;
  margin-bottom: 0;
}

.field-sep {
  font-size: 28rpx;
  color: #9ca3af;
  margin-top: 40rpx;
}

.field-unit {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 40rpx;
}

.field-label {
  font-size: 24rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.field-input {
  width: 100%;
  height: 72rpx;
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #1a1a2e;
  box-sizing: border-box;
}

.field-input.picker {
  display: flex;
  align-items: center;
  line-height: 72rpx;
}

.field-input.placeholder {
  color: #9ca3af;
}

.field-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #1a1a2e;
  box-sizing: border-box;
}

.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #6b7280;
  background: #f3f4f6;
  border-radius: 40rpx;
  font-weight: 500;
}

.tag.active {
  color: #299ff0;
  background: rgba(41,159,240,.1);
}

.bottom-bar {
  position: fixed;
  bottom: 48rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  gap: 16rpx;
  z-index: 100;
}

.bar-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
}

.bar-btn.preview {
  background: #f3f4f6;
  color: #6b7280;
}

.bar-btn.save {
  background: linear-gradient(135deg, #299ff0, #5ab8f5);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(41,159,240,.3);
}

.bar-btn.save.disabled {
  opacity: .6;
}
