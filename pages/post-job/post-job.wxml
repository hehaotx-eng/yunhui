<wxs src="./tags.wxs" module="tagsUtil" />
<view class="page">
  <view class="header">
    <view class="header-content">
      <view class="back-btn" bindtap="goBack">‹</view>
      <view class="header-text">{{isEdit ? '编辑职位' : '发布职位'}}</view>
      <view class="submit-btn" bindtap="submit">保存</view>
    </view>
  </view>

  <scroll-view scroll-y class="form-content">
    <view class="form-section">
      <view class="section-title">基本信息</view>
      
      <view class="form-item">
        <view class="form-label">职位名称 *</view>
        <input class="form-input" placeholder="请输入职位名称" value="{{formData.title}}" bindinput="handleInput" data-field="title" />
      </view>

      <view class="form-item">
        <view class="form-label">薪资范围 *</view>
        <view class="salary-input">
          <input class="form-input salary" type="digit" placeholder="最低" value="{{formData.salaryMin}}" bindinput="handleInput" data-field="salaryMin" />
          <view class="salary-separator">-</view>
          <input class="form-input salary" type="digit" placeholder="最高" value="{{formData.salaryMax}}" bindinput="handleInput" data-field="salaryMax" />
          <view class="salary-unit">元</view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">工作地点 *</view>
        <input class="form-input" placeholder="请输入工作地点" value="{{formData.location}}" bindinput="handleInput" data-field="location" />
      </view>

      <view class="form-row">
        <view class="form-item half">
          <view class="form-label">经验要求 *</view>
          <picker mode="selector" range="{{experienceOptions}}" bindchange="onExperienceChange">
            <view class="picker-value">{{formData.experience || '请选择'}}</view>
          </picker>
        </view>
        <view class="form-item half">
          <view class="form-label">学历要求 *</view>
          <picker mode="selector" range="{{educationOptions}}" bindchange="onEducationChange">
            <view class="picker-value">{{formData.education || '请选择'}}</view>
          </picker>
        </view>
      </view>

      <view class="form-row">
        <view class="form-item half">
          <view class="form-label">职位类型</view>
          <picker mode="selector" range="{{typeOptions}}" bindchange="onTypeChange">
            <view class="picker-value">{{formData.type === 'full-time' ? '全职' : (formData.type === 'part-time' ? '兼职' : (formData.type === 'intern' ? '实习' : '全职'))}}</view>
          </picker>
        </view>
        <view class="form-item half">
          <view class="form-label">截止日期</view>
          <picker mode="date" value="{{formData.deadline}}" bindchange="onDeadlineChange">
            <view class="picker-value">{{formData.deadline || '请选择'}}</view>
          </picker>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">职位描述</view>
      
      <view class="form-item">
        <view class="form-label">职位描述</view>
        <textarea class="form-textarea" placeholder="请输入职位描述" value="{{formData.description}}" bindinput="handleInput" data-field="description" />
      </view>

      <view class="form-item">
        <view class="form-label">任职要求</view>
        <textarea class="form-textarea" placeholder="请输入任职要求" value="{{formData.requirements}}" bindinput="handleInput" data-field="requirements" />
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">标签</view>
      
      <view class="form-item">
        <view class="form-label">选择标签</view>
        <view class="welfare-list">
          <view wx:for="{{tagOptions}}" wx:key="*this" class="welfare-tag {{tagsUtil.isSelected(formData.tags, item) ? 'active' : ''}}" bindtap="toggleTag" data-value="{{item}}">
            {{item}}
          </view>
        </view>
      </view>
      
      <view class="form-item">
        <view class="form-label">自定义标签</view>
        <input class="form-input" placeholder="多个标签用逗号分隔" value="{{customTags}}" bindinput="handleCustomTags" />
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">职位状态</view>
      
      <view class="form-item">
        <view class="form-label">状态</view>
        <view class="status-options">
          <view class="status-option {{formData.status === 'active' ? 'active' : ''}}" bindtap="setStatus" data-value="active">发布</view>
          <view class="status-option {{formData.status === 'paused' ? 'active' : ''}}" bindtap="setStatus" data-value="paused">暂停</view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>