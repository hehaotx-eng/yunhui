<view class="page">
  <view class="top-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-back" bindtap="goBack">
        <text class="nav-back-icon">‹</text>
      </view>
      <text class="nav-title">{{isEdit ? '编辑职位' : '发布职位'}}</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <scroll-view class="body" scroll-y style="margin-top: {{statusBarHeight + 44}}px;">
    <view class="section">
      <text class="section-title">基本信息</text>
      <view class="field">
        <text class="field-label">职位名称 *</text>
        <input class="field-input" placeholder="如：前端开发工程师" value="{{form.title}}" bindinput="onInput" data-field="form.title" />
      </view>
      <view class="field-row">
        <view class="field half">
          <text class="field-label">最低薪资</text>
          <input class="field-input" placeholder="如：10" type="digit" value="{{form.salary_min}}" bindinput="onInput" data-field="form.salary_min" />
        </view>
        <text class="field-sep">-</text>
        <view class="field half">
          <text class="field-label">最高薪资</text>
          <input class="field-input" placeholder="如：20" type="digit" value="{{form.salary_max}}" bindinput="onInput" data-field="form.salary_max" />
        </view>
        <text class="field-unit">K</text>
      </view>
      <view class="field">
        <text class="field-label">工作地点 *</text>
        <input class="field-input" placeholder="如：北京朝阳" value="{{form.location}}" bindinput="onInput" data-field="form.location" />
      </view>
      <view class="field-row">
        <view class="field half">
          <text class="field-label">经验要求</text>
          <picker mode="selector" range="{{['不限','1年以下','1-3年','3-5年','5-10年','10年以上']}}" bindchange="onExperienceChange">
            <view class="field-input picker {{form.experience ? '' : 'placeholder'}}">{{form.experience || '请选择'}}</view>
          </picker>
        </view>
        <view class="field half">
          <text class="field-label">学历要求</text>
          <picker mode="selector" range="{{['不限','高中','大专','本科','硕士','博士']}}" bindchange="onEducationChange">
            <view class="field-input picker {{form.education ? '' : 'placeholder'}}">{{form.education || '请选择'}}</view>
          </picker>
        </view>
      </view>
      <view class="field">
        <text class="field-label">职位类型</text>
        <picker mode="selector" range="{{['普通职位','VIP职位']}}" bindchange="onTypeChange">
          <view class="field-input picker">{{form.job_type === 'premium' ? 'VIP职位' : '普通职位'}}</view>
        </picker>
      </view>
    </view>

    <view class="section">
      <text class="section-title">职位详情</text>
      <view class="field">
        <text class="field-label">职位描述 *</text>
        <textarea class="field-textarea" placeholder="描述工作内容和职责" value="{{form.description}}" bindinput="onInput" data-field="form.description" />
      </view>
      <view class="field">
        <text class="field-label">任职要求</text>
        <textarea class="field-textarea" placeholder="描述任职条件和要求" value="{{form.requirements}}" bindinput="onInput" data-field="form.requirements" />
      </view>
    </view>

    <view class="section">
      <text class="section-title">技能标签</text>
      <view class="tag-wrap">
        <text class="tag {{form.tags.indexOf(item) !== -1 ? 'active' : ''}}" wx:for="{{['Vue','React','Java','Python','Go','Node.js','MySQL','Redis','Docker','K8s','AI','产品设计','运营','销售','市场']}}" wx:key="*this" bindtap="toggleTag" data-value="{{item}}">{{item}}</text>
      </view>
    </view>

    <view style="height: 160rpx;"></view>
  </scroll-view>

  <view class="bottom-bar">
    <view class="bar-btn preview" bindtap="preview">预览</view>
    <view class="bar-btn save {{submitting ? 'disabled' : ''}}" bindtap="submit">{{submitting ? '保存中...' : '保存'}}</view>
  </view>
</view>
