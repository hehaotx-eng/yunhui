page {
  overflow: hidden;
}

.page {
  height: 100vh;
  background: linear-gradient(145deg, #E8F0FE 0%, #eef9ff 50%, #FDE8F0 100%);
  position: relative;
  display: flex;
  flex-direction: column;
}

.page::before {
  content: '';
  position: fixed;
  top: -20%;
  right: -10%;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(79, 124, 255, 0.15);
  filter: blur(80rpx);
  z-index: 0;
  pointer-events: none;
}

.page::after {
  content: '';
  position: fixed;
  bottom: -10%;
  left: -10%;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: rgba(255, 154, 118, 0.12);
  filter: blur(100rpx);
  z-index: 0;
  pointer-events: none;
}

.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
}

.back-icon {
  font-size: 42rpx;
  color: #1A2332;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #1A2332;
  letter-spacing: 1rpx;
}

.body {
  position: relative;
  z-index: 1;
  flex: 1;
  padding: 120rpx 0 240rpx;
  box-sizing: border-box;
}

.profile-section {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 40rpx 32rpx 36rpx;
}

.avatar-frame {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  flex-shrink: 0;
  position: relative;
  background: linear-gradient(135deg, rgba(255,255,255,0.5), rgba(255,255,255,0.1));
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 8rpx 32rpx rgba(79, 124, 255, 0.2), inset 0 0 20rpx rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-frame::after {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 12rpx;
  width: 40rpx;
  height: 20rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.6), transparent);
  border-radius: 50%;
  transform: rotate(-20deg);
}

.profile-avatar-img {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  display: block;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4F7CFF, #7B61FF);
  color: #fff;
  font-size: 48rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(79, 124, 255, 0.25);
  border: 2px solid rgba(255, 255, 255, 0.6);
}

.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A2332;
  letter-spacing: 1rpx;
}

.profile-title {
  font-size: 26rpx;
  color: #4F7CFF;
  background: rgba(79, 124, 255, 0.12);
  padding: 4rpx 18rpx;
  border-radius: 30rpx;
  align-self: flex-start;
}

.profile-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 4rpx;
}

.profile-tag {
  font-size: 22rpx;
  color: #6B7A8F;
  background: rgba(255, 255, 255, 0.4);
  padding: 4rpx 14rpx;
  border-radius: 30rpx;
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.contact-section {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 0 32rpx 36rpx;
  position: relative;
}

.contact-section::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 32rpx;
  right: 32rpx;
  height: 1px;
  background: rgba(255, 255, 255, 0.4);
}

.contact-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  color: #1A2332;
}

.contact-icon {
  font-size: 28rpx;
  opacity: 0.6;
}

.contact-text {
  font-weight: 500;
}

.section {
  padding: 28rpx 32rpx 32rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #A0B0C4;
  letter-spacing: 2rpx;
  padding-left: 14rpx;
  border-left: 3rpx solid #4F7CFF;
  margin-bottom: 20rpx;
  display: block;
}

.intent-grid {
  background: rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: 20rpx;
  border: 1px solid rgba(255, 255, 255, 0.3);
  padding: 16rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.intent-item {
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(4px);
  border-radius: 14rpx;
  padding: 20rpx 14rpx;
  text-align: center;
}

.intent-label {
  font-size: 22rpx;
  color: #A0B0C4;
  display: block;
  margin-bottom: 6rpx;
}

.intent-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A2332;
}

.edu-card {
  display: flex;
  gap: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 24rpx;
}

.edu-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4F7CFF, #7B61FF);
  margin-top: 12rpx;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(79, 124, 255, 0.12);
}

.edu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.edu-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.edu-school {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A2332;
}

.edu-badge {
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #4F7CFF, #7B61FF);
  padding: 2rpx 14rpx;
  border-radius: 30rpx;
  font-weight: 500;
}

.edu-major {
  font-size: 26rpx;
  color: #6B7A8F;
}

.edu-date {
  font-size: 22rpx;
  color: #A0B0C4;
}

.skill-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.skill-tag {
  background: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.4);
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #1A2332;
  font-weight: 500;
}

.skill-tag:nth-child(3n+1) {
  background: rgba(79, 124, 255, 0.12);
}

.skill-tag:nth-child(3n+2) {
  background: rgba(123, 97, 255, 0.12);
}

.skill-tag:nth-child(3n+3) {
  background: rgba(255, 154, 118, 0.12);
}

.bottom-bar {
  position: fixed;
  bottom: 36rpx;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  justify-content: center;
  padding: 0 48rpx;
}

.bottom-bar-inner {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.btn-fav {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.fav-icon {
  font-size: 34rpx;
  line-height: 1;
  color: #ff5c39;
}

.btn-edit {
  flex: 1;
  background: linear-gradient(135deg, rgba(79, 124, 255, 0.55), rgba(123, 97, 255, 0.5));
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  padding: 32rpx 0;
  text-align: center;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 32rpx rgba(79, 124, 255, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.3);
  position: relative;
  overflow: hidden;
}

.btn-edit::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.2), transparent);
  border-radius: 50rpx 50rpx 0 0;
  pointer-events: none;
}

.btn-edit:active {
  opacity: 0.8;
}

.btn-call {
  flex: 1;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  color: #1A2332;
  font-size: 26rpx;
  font-weight: 500;
  padding: 28rpx 0;
  text-align: center;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.5);
  position: relative;
  overflow: hidden;
}

.btn-chat {
  flex: 1;
  background: linear-gradient(135deg, rgba(79, 124, 255, 0.55), rgba(123, 97, 255, 0.5));
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
  padding: 28rpx 0;
  text-align: center;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 32rpx rgba(79, 124, 255, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.3);
  position: relative;
  overflow: hidden;
}

.btn-call:active,
.btn-chat:active {
  opacity: 0.85;
}

.empty-state {
  display: flex;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-state .empty-text {
  font-size: 28rpx;
  color: #A0B0C4;
}

.loading-wrap {
  text-align: center;
  padding: 80rpx 0;
  margin-top: 40%;
}

.loading-text {
  font-size: 28rpx;
  color: #6B7A8F;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 1; }
}