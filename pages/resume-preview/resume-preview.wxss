.page {
  min-height: 100vh;
  background: #f0f2f5;
  padding-bottom: 40rpx;
}

.body {
  padding: 16rpx 16rpx 40rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

.profile-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, .04);
}

.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #0077ff;
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  display: block;
  line-height: 1.3;
}

.profile-title {
  font-size: 26rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

.profile-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.profile-tag {
  font-size: 22rpx;
  color: #666;
}

.contact-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, .04);
}

.contact-label {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.contact-text {
  font-size: 24rpx;
  color: #333;
}

.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, .04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid #0077ff;
  line-height: 1.2;
}

.intent-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx 40rpx;
}

.intent-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.intent-label {
  font-size: 22rpx;
  color: #999;
}

.intent-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.edu-card {
  display: flex;
  gap: 20rpx;
  position: relative;
}

.edu-circle {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #0077ff;
  margin-top: 8rpx;
  flex-shrink: 0;
  position: relative;
}

.edu-circle::before {
  content: '';
  position: absolute;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 2rpx;
  height: 100rpx;
  background: #e8e8e8;
}

.edu-content {
  flex: 1;
  min-width: 0;
  padding-bottom: 8rpx;
}

.edu-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.edu-school {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.edu-badge {
  font-size: 20rpx;
  color: #0077ff;
  padding: 2rpx 12rpx;
  background: rgba(0, 119, 255, .06);
  border-radius: 4rpx;
  font-weight: 500;
}

.edu-major {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 4rpx;
}

.edu-date {
  font-size: 22rpx;
  color: #bbb;
  display: block;
}

.skill-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.skill-tag {
  font-size: 24rpx;
  color: #0077ff;
  background: none;
  border: none;
  padding: 0;
  font-weight: 500;
}

.bottom-bar {
  margin: 40rpx 0 32rpx;
  display: flex;
  justify-content: center;
}

.btn-edit {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #0077ff, #3399ff);
  border-radius: 44rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 119, 255, .3);
}
