/* ==================== 全局变量 ==================== */
page {
  --primary: #4F6EF7;
  --primary-light: #EEF1FE;
  --primary-dark: #3A56D4;
  --primary-gradient: linear-gradient(135deg, #4F6EF7 0%, #7C5CFC 100%);
  
  --success: #34C759;
  --warning: #FF9500;
  --danger: #FF3B30;
  --gray-1: #F7F8FA;
  --gray-2: #EDEEF2;
  --gray-3: #D1D3D8;
  --gray-4: #A8ABB3;
  --gray-5: #6E727D;
  --gray-6: #3D4047;
  --gray-7: #1C1E23;
  
  --radius-sm: 10rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;
  
  --shadow-sm: 0 2rpx 12rpx rgba(79, 110, 247, 0.08);
  --shadow-md: 0 8rpx 32rpx rgba(79, 110, 247, 0.12);
  --shadow-lg: 0 16rpx 48rpx rgba(79, 110, 247, 0.16);
  
  --font-base: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", "Helvetica Neue", sans-serif;
  
  background: #F5F6FA;
}

.page {
  position: relative;
  min-height: 100vh;
  background: #F5F6FA;
  font-family: var(--font-base);
  padding-bottom: 140rpx;
}

/* ==================== 滚动容器 ==================== */
.body {
  height: 100vh;
  padding: 24rpx 28rpx 0;
  box-sizing: border-box;
}

/* ==================== 加载状态 ==================== */
.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: var(--gray-4);
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 1; }
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 160rpx 0;
}

.empty-text {
  font-size: 30rpx;
  color: var(--gray-4);
  background: #FFFFFF;
  padding: 40rpx 60rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

/* ==================== 个人信息卡片 ==================== */
.profile-section {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 36rpx 32rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  gap: 24rpx;
  transition: box-shadow 0.25s ease;
}

.profile-section:active {
  box-shadow: var(--shadow-md);
}

/* 头像 */
.profile-avatar,
.avatar-frame {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  background: var(--primary-gradient);
  box-shadow: 0 8rpx 24rpx rgba(79, 110, 247, 0.25);
  overflow: hidden;
}

.avatar-frame {
  padding: 0;
  background: transparent;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.profile-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* 个人信息文字 */
.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--gray-7);
  margin-bottom: 6rpx;
  letter-spacing: -0.3rpx;
}

.profile-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--primary);
  margin-bottom: 12rpx;
}

.profile-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.profile-tag {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--gray-5);
  background: var(--gray-1);
  padding: 4rpx 16rpx;
  border-radius: 40rpx;
  border: 1rpx solid var(--gray-2);
}

/* ==================== 联系方式 ==================== */
.contact-section {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 8rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  transition: box-shadow 0.25s ease;
}

.contact-section:active {
  box-shadow: var(--shadow-md);
}

.contact-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--gray-1);
  transition: background 0.2s ease;
}

.contact-row:last-child {
  border-bottom: none;
}

.contact-row:active {
  background: var(--gray-1);
  border-radius: var(--radius-sm);
  margin: 0 -12rpx;
  padding-left: 12rpx;
  padding-right: 12rpx;
}

.contact-icon {
  font-size: 34rpx;
  width: 48rpx;
  flex-shrink: 0;
  text-align: center;
  color: var(--gray-4);
}

.contact-text {
  font-size: 28rpx;
  color: var(--gray-6);
  font-weight: 500;
  margin-left: 12rpx;
  word-break: break-all;
}

/* ==================== 通用卡片区块 ==================== */
.section {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 32rpx 28rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  transition: box-shadow 0.25s ease;
  animation: slideUp 0.4s ease forwards;
}

.section:active {
  box-shadow: var(--shadow-md);
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--gray-7);
  margin-bottom: 24rpx;
  letter-spacing: -0.3rpx;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: var(--primary-gradient);
  border-radius: 4rpx;
}

/* ==================== 求职意向网格 ==================== */
.intent-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.intent-item {
  background: var(--gray-1);
  border-radius: var(--radius-md);
  padding: 18rpx 20rpx;
  display: flex;
  flex-direction: column;
  transition: background 0.2s ease;
}

.intent-item:active {
  background: var(--gray-2);
}

.intent-label {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--gray-4);
  margin-bottom: 6rpx;
  letter-spacing: 0.3rpx;
}

.intent-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-7);
  word-break: break-all;
}

/* ==================== 教育经历 ==================== */
.edu-card {
  display: flex;
  gap: 20rpx;
  padding: 4rpx 0;
}

.edu-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--primary-gradient);
  border-radius: 50%;
  margin-top: 10rpx;
  flex-shrink: 0;
  box-shadow: 0 0 0 6rpx var(--primary-light);
}

.edu-content {
  flex: 1;
  min-width: 0;
}

.edu-head {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.edu-school {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--gray-7);
}

.edu-badge {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--primary);
  background: var(--primary-light);
  padding: 2rpx 16rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(79, 110, 247, 0.1);
}

.edu-major {
  display: block;
  font-size: 26rpx;
  color: var(--gray-5);
  margin-bottom: 4rpx;
}

.edu-date {
  display: block;
  font-size: 24rpx;
  color: var(--gray-4);
}

/* ==================== 技能标签 ==================== */
.skill-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.skill-tag {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--gray-6);
  background: var(--gray-1);
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  border: 1rpx solid var(--gray-2);
  transition: all 0.2s ease;
}

.skill-tag:active {
  background: var(--primary-light);
  border-color: var(--primary);
  color: var(--primary-dark);
  transform: scale(0.95);
}

/* ==================== 底部操作栏 ==================== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  padding: 16rpx 28rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 50;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.04);
}

.bottom-bar-inner {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 收藏按钮 */
.btn-fav {
  flex-shrink: 0;
  width: 96rpx;
  height: 96rpx;
  background: var(--gray-1);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  border: 2rpx solid var(--gray-2);
}

.btn-fav:active {
  transform: scale(0.92);
  background: var(--gray-2);
}

.fav-icon {
  font-size: 44rpx;
  line-height: 1;
  transition: transform 0.3s ease, color 0.3s ease;
}

.btn-fav .fav-icon {
  color: var(--gray-4);
}

.btn-fav:active .fav-icon {
  transform: scale(1.2);
}

/* 当收藏激活时（需配合js动态类，此处仅样式） */
/* 实际项目中可通过添加类 .active 控制 */
.btn-fav.active .fav-icon {
  color: var(--danger);
}

/* 编辑简历按钮（个人） */
.btn-edit {
  flex: 1;
  height: 96rpx;
  background: var(--primary-gradient);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  box-shadow: 0 8rpx 28rpx rgba(79, 110, 247, 0.3);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.btn-edit:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(79, 110, 247, 0.2);
}

/* 企业操作按钮：拨打电话、在线联系 */
.btn-call,
.btn-chat {
  flex: 1;
  height: 96rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.btn-call {
  background: var(--gray-1);
  color: var(--gray-6);
  border: 2rpx solid var(--gray-2);
}

.btn-call:active {
  background: var(--gray-2);
  transform: scale(0.96);
}

.btn-chat {
  flex: 1.4;
  background: var(--primary-gradient);
  color: #FFFFFF;
  box-shadow: 0 8rpx 28rpx rgba(79, 110, 247, 0.3);
}

.btn-chat:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(79, 110, 247, 0.2);
}

/* ==================== 动画 ==================== */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 为多个section设置延迟 */
.section:nth-child(1) { animation-delay: 0.05s; }
.section:nth-child(2) { animation-delay: 0.10s; }
.section:nth-child(3) { animation-delay: 0.15s; }
.section:nth-child(4) { animation-delay: 0.20s; }

/* ==================== 滚动条隐藏 ==================== */
::-webkit-scrollbar {
  width: 0;
  height: 0;
}

/* ==================== 适配 ==================== */
@media screen and (max-width: 375px) {
  .intent-grid {
    grid-template-columns: 1fr;
  }
  
  .profile-section {
    flex-wrap: wrap;
    justify-content: center;
    text-align: center;
  }
  
  .profile-info {
    text-align: center;
  }
  
  .profile-tags {
    justify-content: center;
  }
}

@media screen and (min-width: 768px) {
  .page {
    max-width: 720rpx;
    margin: 0 auto;
  }
  
  .bottom-bar {
    max-width: 720rpx;
    left: 50%;
    transform: translateX(-50%);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }
}