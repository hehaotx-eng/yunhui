<wxs src="../../utils/wxs.wxs" module="wxs" />
<view class="page">
  <view class="favorite-list">
    <view wx:for="{{list}}" wx:key="id" class="job-card" bindtap="goDetail" data-id="{{item.job_id}}">
      <view class="card-row-top">
        <text class="card-title">{{item.title}}</text>
        <text class="card-salary">{{item.salary || (item.salary_min && item.salary_max ? (item.salary_min) + '-' + (item.salary_max) + '元' : item.salary_min ? (item.salary_min) + '元起' : '面议')}}</text>
      </view>
      <view class="card-tags" wx:if="{{item.tags && item.tags.length > 0}}">
        <text class="card-tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="card-row-bottom">
        <view class="company-info-left">
          <view class="company-logo">
            <image wx:if="{{item.company_logo}}" src="{{item.company_logo}}" mode="aspectFill" />
            <text wx:else>{{wxs.firstChar(item.company_name)}}</text>
          </view>
          <text class="company-name">{{item.company_name || ''}}</text>
        </view>
        <view class="card-info-right">
          <text class="info-location">{{item.location || ''}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{showEmpty}}" class="empty-card">
      <view class="empty-icon">💔</view>
      <view class="empty-text">暂无收藏职位</view>
    </view>
    <view wx:if="{{loading}}" class="loading">加载中...</view>
  </view>
</view>
