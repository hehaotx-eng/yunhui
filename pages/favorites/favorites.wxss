page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.header {
  background: linear-gradient(135deg, #00a2ff 0%, #0080ff 100%);
  padding: 60rpx 32rpx 40rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.favorite-list {
  padding: 24rpx;
}

.favorite-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.job-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.job-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.job-salary {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff6b6b;
}

.job-info {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.job-tag {
  font-size: 24rpx;
  color: #999;
}

.job-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.company-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.company-logo {
  width: 64rpx;
  height: 64rpx;
  border-radius: 10rpx;
  background: #f5f5f5;
}

.company-name {
  font-size: 24rpx;
  color: #666;
}

.delete-btn {
  padding: 12rpx 24rpx;
  background: #fff2f0;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #ff4d4f;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}