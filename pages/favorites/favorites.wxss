page {
  min-height: 100vh;
  background: #f6f7f9;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.favorite-list {
  padding: 24rpx;
}

.job-card {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}

.card-row-top {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-salary {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff5c39;
  flex-shrink: 0;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.card-tag {
  font-size: 22rpx;
  color: #6b7280;
  background: #f5f6f8;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.card-row-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.company-info-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.company-logo {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.company-logo image { width: 100%; height: 100%; }

.company-logo text {
  font-size: 22rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.company-name {
  font-size: 26rpx;
  color: #1a1a2e;
  max-width: 380rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-info-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-location {
  font-size: 24rpx;
  color: #9ca3af;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: #999;
}
