<view class="page">

<!-- 顶部 -->
<view class="header">
  <view class="header-title">人才搜索</view>
</view>

<!-- 内容 -->
<view class="content">

  <!-- 搜索框 -->
  <view class="search-bar">
    <view class="search-wrapper">
      <image class="icon-search" src="/pages/image/sousuo.png" mode="aspectFit" />
      <input
        class="search-input"
        placeholder="搜索候选人姓名/技能"
        value="{{keyword}}"
        bindinput="onKeywordInput"
        bindconfirm="onSearch"
        confirm-type="search"
      />
    </view>
  </view>

  <!-- 筛选横向滚动 -->
  <scroll-view class="filter-scroll" scroll-x>
    <view
      wx:for="{{filters}}"
      wx:key="id"
      class="filter-item {{activeFilter === item.id ? 'active' : ''}}"
      data-id="{{item.id}}"
      bindtap="switchFilter"
    >
      {{item.name}}
    </view>
  </scroll-view>

  <!-- 候选人列表 -->
  <view class="candidate-list">

    <view
      wx:for="{{candidates}}"
      wx:key="id"
      class="candidate-card"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >

      <!-- 头像 -->
      <view class="avatar">
        <image wx:if="{{item.avatar}}" src="{{item.avatar}}" mode="aspectFill" />
        <view wx:else class="avatar-placeholder">{{item.username ? item.username.substring(0,1) : '人'}}</view>
      </view>

      <!-- 内容 -->
      <view class="content-inner">

        <!-- 名称 + 学历 -->
        <view class="name-row">
          <text class="name">{{item.username || '候选人'}}</text>
          <text wx:if="{{item.education}}" class="education">{{item.education}}</text>
        </view>

        <!-- 经验 + 城市 -->
        <view class="meta">{{item.experience || '经验不限'}} · {{item.city || '地区不限'}}</view>

        <!-- 技能标签 -->
        <view class="skills">
          <view wx:for="{{item.skills || []}}" wx:for-item="skill" wx:key="*this" class="skill-tag">{{skill}}</view>
        </view>

      </view>

      <!-- 右箭头 -->
      <view class="arrow">
        <image src="/pages/image/arrow-right.png" mode="aspectFit" />
      </view>

    </view>

    <!-- 空状态 -->
    <view wx:if="{{showEmpty}}" class="empty-card">
      <image class="empty-icon" src="/pages/image/empty-candidates.png" />
      <view class="empty-text">暂无匹配的候选人</view>
    </view>

    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loading">加载中...</view>

  </view>

</view>

<!-- 底部 TabBar -->
<view class="tabbar">

  <view class="tab-item" bindtap="goHome">
    <image class="tab-icon" src="/pages/image/home.png" mode="aspectFit" />
    <view class="tab-text">首页</view>
  </view>

  <view class="tab-item active">
    <image class="tab-icon" src="/pages/image/users.png" mode="aspectFit" />
    <view class="tab-text">人才</view>
  </view>

  <view class="tab-item" bindtap="goJobs">
    <image class="tab-icon" src="/pages/image/job.png" mode="aspectFit" />
    <view class="tab-text">岗位</view>
  </view>

  <view class="tab-item" bindtap="goMsg">
    <image class="tab-icon" src="/pages/image/msg.png" mode="aspectFit" />
    <view class="tab-text">消息</view>
  </view>

  <view class="tab-item" bindtap="goMy">
    <image class="tab-icon" src="/pages/image/my.png" mode="aspectFit" />
    <view class="tab-text">我的</view>
  </view>

</view>

</view>