<wxs src="../../utils/wxs.wxs" module="wxs" />
<view class="page">
  <view class="top-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <text class="nav-logo">人才搜索</text>
      <view class="nav-search">
        <input class="search-input" placeholder="搜索姓名 / 技能 / 职位" placeholder-class="search-placeholder" value="{{keyword}}" bindinput="onKeywordInput" bindconfirm="onSearch" confirm-type="search" />
      </view>
    </view>
  </view>

  <view class="body" style="margin-top: {{statusBarHeight + 44}}px;">
    <view class="list">
      <view wx:for="{{list}}" wx:key="user_id" class="card" bindtap="viewResume" data-resumeid="{{item.resume_id}}">
        <view class="card-top">
          <view class="avatar">{{wxs.firstChar(item.nickname)}}</view>
          <view class="info">
            <text class="name">{{item.nickname || '候选人'}}</text>
            <text class="title">{{item.expectedJob || item.title || '求职中'}}</text>
          </view>
        </view>
        <view class="card-tags" wx:if="{{item.skills && item.skills.length > 0}}">
          <text class="tag" wx:for="{{item.skills}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="card-meta">
          <text wx:if="{{item.school}}" class="meta-item">{{item.school}}</text>
          <text wx:if="{{item.education}}" class="meta-item">{{item.education}}</text>
          <text wx:if="{{item.location}}" class="meta-item">{{item.location}}</text>
        </view>
      </view>

      <view wx:if="{{showEmpty}}" class="empty">
        <view class="empty-icon">🔍</view>
        <text class="empty-text">暂无匹配的候选人</text>
      </view>
      <view wx:if="{{loading}}" class="loading">加载中...</view>
    </view>
  </view>
</view>

<enterprise-tabbar current="candidates" />
