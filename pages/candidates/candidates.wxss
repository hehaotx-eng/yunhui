/* йЎөйқўиғҢжҷҜ */
.page {
  background-color: #f6f7f9;
  min-height: 100vh;
  font-family: "PingFang SC","Microsoft YaHei",sans-serif;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

/* йЎ¶йғЁ */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  z-index: 10;
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 24rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

/* еҶ…е®№еҢ?*/
.content {
  padding: 16rpx;
  padding-top: calc(88rpx + env(safe-area-inset-top) + 20rpx);
}

/* жҗңзҙўжЎ?*/
.search-bar {
  margin-bottom: 24rpx;
}

.search-wrapper {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 0 16rpx;
  height: 64rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
}

.icon-search {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #111827;
  border: none;
  outline: none;
  background-color: transparent;
}

/* зӯӣйҖүжЁӘеҗ‘ж»ҡеҠ?*/
.filter-scroll {
  display: flex;
  margin-bottom: 24rpx;
  overflow-x: scroll;
}

.filter-item {
  padding: 8rpx 16rpx;
  background-color: #f5f6f8;
  color: #667085;
  border-radius: 16rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.filter-item.active {
  background-color: #ff5c39;
  color: #ffffff;
}

/* еҖҷйҖүдәәеҲ—иЎЁ */
.candidate-list {
  display: flex;
  flex-direction: column;
}

/* еҖҷйҖүдәәеҚЎзүҮ */
.candidate-card {
  display: flex;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
  align-items: flex-start;
  cursor: pointer;
}

/* еӨҙеғҸ */
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background-color: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #111827;
  margin-right: 16rpx;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* еҶ…е®№еҢәеҹҹ */
.content-inner {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* еҗҚз§° + еӯҰеҺҶ */
.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.name {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-right: 12rpx;
}

.education {
  font-size: 24rpx;
  color: #9ca3af;
}

/* з»ҸйӘҢ + еҹҺеёӮ */
.meta {
  font-size: 24rpx;
  color: #4b5563;
  margin-bottom: 12rpx;
}

/* жҠҖиғҪж Үзӯ?*/
.skills {
  display: flex;
  flex-wrap: wrap;
}

.skill-tag {
  font-size: 24rpx;
  color: #667085;
  background-color: #f5f6f8;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

/* еҸіз®ӯеӨ?*/
.arrow {
  width: 24rpx;
  height: 24rpx;
  margin-left: 12rpx;
  align-self: center;
}

/* з©әзҠ¶жҖ?*/
.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 0;
  color: #9ca3af;
  font-size: 28rpx;
}

.empty-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 16rpx;
}

/* еҠ иҪҪдё?*/
.loading {
  text-align: center;
  font-size: 28rpx;
  color: #9ca3af;
  padding: 32rpx 0;
}

/* еә•йғЁ TabBar */
.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  height: 100%;
}

.tab-item.active .tab-text {
  color: #ff5c39;
}

.tab-icon {
  width: 36rpx;
  height: 36rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #999;
}

page { padding-bottom: 60px; }