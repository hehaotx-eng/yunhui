.page {
  min-height: 100vh;
  background: #f6f7f9;
  padding-bottom: 120rpx;
}

.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255,255,255,.25);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  gap: 20rpx;
}

.nav-logo {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a1a2e;
  flex-shrink: 0;
}

.nav-search {
  flex: 1;
  max-width: 440rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  background: #f3f4f6;
  border-radius: 32rpx;
  padding: 0 20rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 24rpx;
  color: #1a1a2e;
  background: transparent;
}

.search-placeholder {
  color: #9ca3af;
  font-size: 24rpx;
}

.body {
  padding: 0 20rpx 40rpx;
}

.list {
  padding-top: 16rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}

.card-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #299ff0, #5ab8f5);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.info {
  flex: 1;
  min-width: 0;
}

.name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
}

.title {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 4rpx;
  display: block;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.tag {
  font-size: 22rpx;
  color: #299ff0;
  background: rgba(41,159,240,.08);
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #9ca3af;
  padding: 4rpx 12rpx;
  background: #f5f6f8;
  border-radius: 4rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

.loading {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: #9ca3af;
}
