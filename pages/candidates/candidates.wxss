.page {
  min-height: 100vh;
  background: #f6f7fb;
}

.body {
  padding: 24rpx;
}

/* ===== list ===== */
.list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

/* ===== 核心卡片（去重阴影） ===== */
.glass-card {
  background: #fff;
  border: 1px solid #eef0f3;
  border-radius: 18rpx;
  padding: 20rpx;
  transition: all 0.2s ease;
}

.glass-card:active {
  transform: scale(0.985);
  background: #fafafa;
}

/* ===== top ===== */
.card-top {
  display: flex;
  align-items: center;
}

/* 头像升级：更“身份感” */
.card-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg,#3b82f6,#60a5fa);
  color: #fff;
  display:flex;
  align-items:center;
  justify-content:center;
  font-weight:600;
  font-size: 26rpx;
}

.card-avatar-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
}

.card-info {
  margin-left: 14rpx;
  flex: 1;
}

.card-name {
  font-size: 30rpx;
  font-weight: 650;
  color: #111;
}

.card-title {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-top: 4rpx;
}

/* ===== skills（重点：内容化标签） ===== */
.card-tags {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  background: #f5f7fa;
  color: #4b5563;
  border: 1px solid #eef0f3;
}

/* ===== meta（弱信息） ===== */
.card-meta {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #9aa0a6;
}

/* ===== empty ===== */
.empty {
  text-align: center;
  padding: 80rpx 0;
  color: #c0c4cc;
}

.empty-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.empty-text {
  font-size: 24rpx;
}

/* ===== loading ===== */
.loading,
.loading-more {
  text-align: center;
  font-size: 24rpx;
  color: #aaa;
  padding: 20rpx 0;
}