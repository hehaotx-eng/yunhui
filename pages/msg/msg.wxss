.page {
  min-height: 100vh;
  background: #f6f7f9;
  padding-bottom: 160rpx;
}

.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255,255,255,.25);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
}

.nav-logo {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a1a2e;
}

.body {
  padding: 0 20rpx 40rpx;
}

.list {
  padding-top: 16rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}

.card-left {
  flex-shrink: 0;
  position: relative;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #299ff0, #5ab8f5);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid #e8ecf0;
}

.unread-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #ff3b30;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
  box-sizing: border-box;
  border: 2rpx solid #fff;
}

.card-body {
  flex: 1;
  min-width: 0;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.card-time {
  font-size: 22rpx;
  color: #c0c4cc;
}

.card-preview {
  font-size: 24rpx;
  color: #9ca3af;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.card-preview.unread {
  color: #1a1a2e;
  font-weight: 600;
}

.loading {
  text-align: center;
  padding: 80rpx 0;
  font-size: 26rpx;
  color: #9ca3af;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
  margin-bottom: 20rpx;
}

.empty-btn {
  font-size: 26rpx;
  color: #299ff0;
  font-weight: 500;
}
