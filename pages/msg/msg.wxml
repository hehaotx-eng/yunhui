<view class="msg-page">
  <view class="empty" wx:if="{{conversations.length === 0 && !loading}}">
    <text class="empty-icon">💬</text>
    <text class="empty-text">暂无消息</text>
    <text class="empty-hint">去找工作和企业聊聊吧</text>
  </view>

  <view class="conv-list" wx:else>
    <view
      class="conv-item"
      wx:for="{{conversations}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goChat"
    >
      <view class="conv-avatar">
        <text class="avatar-text">{{item.enterpriseName[0] || '企'}}</text>
      </view>
      <view class="conv-info">
        <view class="conv-top">
          <text class="conv-name">{{item.enterpriseName || '企业'}}</text>
          <text class="conv-time">{{item.timeText}}</text>
        </view>
        <view class="conv-bottom">
          <text class="conv-msg">{{item.last_message || '暂无消息'}}</text>
          <view class="conv-badge" wx:if="{{item.unread_user > 0}}">
            <text class="badge-text">{{item.unread_user > 99 ? '99+' : item.unread_user}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
