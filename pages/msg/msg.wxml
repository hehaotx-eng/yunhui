<view class="page">
  <view class="header">
    <view class="header-text">消息</view>
  </view>

  <view class="search-bar">
    <view class="search-wrapper">
      <image class="icon-search" src="/pages/image/sousuo.png" />
      <input class="search-input" placeholder="搜索会话" />
    </view>
    <view class="notice-entry" bindtap="goNotifications">通知</view>
  </view>

  <view wx:if="{{showLoginTip}}" class="empty-card">
    <view class="empty-icon">🔔</view>
    <view class="empty-text">登录后查看消息</view>
    <view class="empty-btn" bindtap="goLogin">去登录</view>
  </view>

  <view class="conversation-list">
    <view wx:for="{{conversations}}" wx:key="id" class="conversation-card" bindtap="goChat" data-id="{{item.id}}">
      <view class="avatar">{{item.avatarLetter}}</view>
      <view class="content">
        <view class="top-row">
          <text class="name">{{item.enterpriseName || item.username || item.name || '会话'}}</text>
          <text class="time">{{item.formattedTime}}</text>
        </view>
        <view class="last">{{item.lastMessage || item.last_message || '暂无消息'}}</view>
      </view>
      <view wx:if="{{item.showBadge}}" class="badge">{{item.badgeText}}</view>
    </view>
    <view wx:if="{{showEmptyTip}}" class="empty-card">
      <view class="empty-icon">💬</view>
      <view class="empty-text">暂无会话</view>
    </view>
    <view wx:if="{{loading}}" class="loading">加载中...</view>
  </view>
</view>

<custom-tab-bar />