<wxs src="../../utils/wxs.wxs" module="wxs" />
<view class="page">
  <view class="top-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <text class="nav-logo">消息</text>
    </view>
  </view>

  <view class="body" style="margin-top: {{statusBarHeight + 44}}px;">
    <view wx:if="{{showLoginTip}}" class="empty-card">
      <view class="empty-icon">🔔</view>
      <view class="empty-text">登录后查看消息</view>
      <view class="empty-btn" bindtap="goLogin">去登录</view>
    </view>

    <view wx:elif="{{loading}}" class="loading">加载中...</view>

    <view wx:elif="{{showEmptyTip}}" class="empty-card">
      <view class="empty-icon">💬</view>
      <view class="empty-text">暂无会话</view>
    </view>

    <view wx:else class="list">
      <view wx:for="{{conversations}}" wx:key="id" class="card" bindtap="goChat" data-id="{{item.id}}" data-name="{{item.name}}" data-avatar="{{item.avatar}}">
        <view class="card-left">
          <image wx:if="{{item.avatar}}" class="avatar-img" src="{{item.avatar}}" mode="aspectFill" />
          <view wx:else class="avatar">{{item.avatarChar}}</view>
          <view wx:if="{{item.unreadCount > 0}}" class="unread-badge">{{item.unreadCount > 99 ? '99+' : item.unreadCount}}</view>
        </view>
        <view class="card-body">
          <view class="card-top">
            <text class="card-name">{{item.name || '对方'}}</text>
            <text class="card-time">{{wxs.formatTime(item.lastMessageTime)}}</text>
          </view>
          <text class="card-preview {{item.unreadCount > 0 ? 'unread' : ''}}">{{item.lastMessage || '暂无消息'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>

<custom-tab-bar />
