<wxs src="../../utils/wxs.wxs" module="wxs" />
<view class="page">
  <view class="top-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <text class="nav-logo">消息</text>
    </view>
  </view>

  <view class="body" style="margin-top: {{statusBarHeight + 44}}px;">
    <view wx:if="{{showLoginTip}}" class="empty-card">
      <view class="empty-icon">🔔</view>
      <view class="empty-text">登录后查看消息</view>
      <view class="empty-btn" bindtap="goLogin">去登录</view>
    </view>

    <view wx:elif="{{loading}}" class="loading">加载中...</view>

    <view wx:elif="{{showEmptyTip}}" class="empty-card">
      <view class="empty-icon">💬</view>
      <view class="empty-text">暂无会话</view>
    </view>

    <view wx:else class="list">
      <view wx:for="{{conversations}}" wx:key="id" class="card" bindtap="goChat" data-id="{{item.id}}">
        <view class="card-left">
          <view class="avatar">{{wxs.firstChar(item.other_name)}}</view>
        </view>
        <view class="card-body">
          <view class="card-top">
            <text class="card-name">{{item.other_name || '对方'}}</text>
            <text class="card-time">{{wxs.formatTime(item.last_message_at)}}</text>
          </view>
          <text class="card-preview">{{item.last_message || '暂无消息'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>

<custom-tab-bar />
