<view class="ep-page" wx:if="{{enterprise}}">
  <!-- 导航 -->
  <view class="ep-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-back" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <text class="nav-title">{{enterprise.name || '企业详情'}}</text>
    <view style="width:60rpx;"></view>
  </view>

  <scroll-view class="ep-scroll" scroll-y enhanced show-scrollbar="{{false}}">

    <!-- 企业头部 -->
    <view class="ep-header">
      <image class="ep-logo" src="{{enterprise.logo || enterprise.company_logo || '/pages/image/company-placeholder.png'}}" mode="aspectFill" />
      <view class="ep-name">{{enterprise.name}}</view>
      <view class="ep-tags">
        <text class="ep-tag">{{enterprise.industry || '互联网'}}</text>
        <text class="ep-tag">{{enterprise.scale || '20-99人'}}</text>
      </view>
    </view>

    <!-- 环境照片 -->
    <view class="section" wx:if="{{enterprise.company_images && enterprise.company_images.length > 0}}">
      <text class="section-title">环境照片</text>
      <scroll-view class="photo-scroll" scroll-x>
        <image wx:for="{{enterprise.company_images}}" wx:key="*this" class="photo-img" src="{{item}}" mode="aspectFill" />
      </scroll-view>
    </view>

    <!-- 公司介绍 -->
    <view class="section">
      <text class="section-title">公司介绍</text>
      <text class="section-body">{{enterprise.description || '暂无企业介绍'}}</text>
    </view>

    <!-- 基本信息 -->
    <view class="section">
      <text class="section-title">基本信息</text>
      <view class="info-grid">
        <view class="info-item">
          <text class="info-label">联系人</text>
          <text class="info-value">{{enterprise.contact_name || enterprise.contactName || '待完善'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">联系电话</text>
          <text class="info-value phone" bindtap="callPhone">{{enterprise.contact_phone || enterprise.contactPhone || '待完善'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">公司地址</text>
          <text class="info-value">{{enterprise.address || '待完善'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">公司规模</text>
          <text class="info-value">{{enterprise.scale || '待完善'}}</text>
        </view>
      </view>
    </view>

    <!-- 在招岗位 -->
    <view class="section">
      <view class="section-title-row">
        <text class="section-title">在招岗位</text>
        <text class="job-count">{{enterprise.jobs ? enterprise.jobs.length : 0}}个</text>
      </view>
      <view wx:for="{{enterprise.jobs || jobs}}" wx:key="id" class="job-item" bindtap="goJob" data-id="{{item.id}}">
        <view class="job-top">
          <text class="job-title">{{item.title}}</text>
          <text class="job-salary">{{item.salary || (item.salary_min && item.salary_max ? item.salary_min + '-' + item.salary_max + 'K' : '面议')}}</text>
        </view>
        <view class="job-meta">
          <text>{{item.location || item.area || '地点不限'}}</text>
          <text wx:if="{{item.experience}}"> · {{item.experience}}</text>
          <text wx:if="{{item.education}}"> · {{item.education}}</text>
        </view>
      </view>
      <view wx:if="{{!enterprise.jobs || enterprise.jobs.length === 0}}" class="empty">暂无在招职位</view>
    </view>

    <view style="height: 60rpx;"></view>
  </scroll-view>
</view>