.ep-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.ep-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  height: 188rpx;
  padding: 0 20rpx;
  background: rgba(255, 255, 255, .95);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(0, 0, 0, .04);
  z-index: 100;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.ep-scroll {
  height: calc(100vh - 88rpx);
  padding-top: 88rpx;
}

.ep-header {
  margin-top: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx 32rpx;
  position: relative;
  overflow: hidden;
}
.ep-header-bg {
  position: absolute; inset: 0;
  filter: blur(30rpx); opacity: 0.25;
  transform: scale(1.3);
  width: 100%; height: 100%;
}

.ep-logo {
  width: 128rpx;
  height: 128rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  position: relative; z-index: 1;
}

.ep-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.ep-tags {
  display: flex;
  gap: 12rpx;
}

.ep-tag {
  padding: 6rpx 20rpx;
  border-radius: 6rpx;
  background: #f5f5f5;
  font-size: 22rpx;
  color: #666;
}

.section {
  margin: 16rpx 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 16rpx;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.job-count {
  font-size: 22rpx;
  color: #999;
}

.section-body {
  font-size: 26rpx;
  color: #555;
  line-height: 1.9;
  white-space: pre-wrap;
}

.photo-scroll {
  display: flex;
  gap: 16rpx;
  white-space: nowrap;
}

.photo-img {
  width: 280rpx;
  height: 200rpx;
  border-radius: 12rpx;
  display: inline-block;
  margin-right: 16rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.info-label {
  font-size: 22rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #1a1a2e;
  font-weight: 500;
}

.info-value.phone {
  color: #0066ff;
}

.job-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.job-item:last-child {
  border-bottom: none;
}

.job-animate {
  animation: jobSlideUp .4s ease both;
  transform-origin: center bottom;
}

@keyframes jobSlideUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.job-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.job-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.job-salary {
  font-size: 28rpx;
  font-weight: 700;
  color: #ff5c39;
}

.job-meta {
  font-size: 22rpx;
  color: #999;
}

.empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 26rpx;
}