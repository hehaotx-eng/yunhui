page {
  background: #f6f7f9;
}

.page {
  padding: 24rpx;
  padding-bottom: 40rpx;
}

/* ======================
   Hero
====================== */

.hero {
  background: #fff;

  border-radius: 24rpx;

  padding: 40rpx 32rpx;

  margin-bottom: 20rpx;

  display: flex;
  flex-direction: column;
  align-items: center;

  box-shadow:
    0 8rpx 24rpx rgba(15,23,42,.03);
}

.logo,
.logo-text {
  width: 120rpx;
  height: 120rpx;

  border-radius: 24rpx;
}

.logo {
  background: #f3f4f6;
}

.logo-text {
  background: #f3f4f6;

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 42rpx;
  font-weight: 700;

  color: #111827;
}

.name {
  margin-top: 24rpx;

  font-size: 38rpx;
  font-weight: 700;

  color: #111827;

  text-align: center;
}

.meta {
  margin-top: 12rpx;

  font-size: 24rpx;

  color: #6b7280;

  text-align: center;
}

.verify-badge {
  margin-top: 20rpx;

  padding: 10rpx 20rpx;

  background: #ecfdf3;

  color: #10b981;

  font-size: 24rpx;

  border-radius: 10rpx;
}

/* ======================
   Section
====================== */

.section {
  background: #fff;

  border-radius: 24rpx;

  padding: 32rpx;

  margin-bottom: 20rpx;

  box-shadow:
    0 8rpx 24rpx rgba(15,23,42,.03);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;

  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;

  color: #111827;
}

.job-count {
  font-size: 24rpx;

  color: #9ca3af;
}

/* ======================
   公司介绍
====================== */

.text-content {
  font-size: 28rpx;

  color: #4b5563;

  line-height: 1.9;

  white-space: pre-wrap;
}

/* ======================
   信息列表
====================== */

.info-list {
  width: 100%;
}

.info-item {
  padding: 24rpx 0;

  border-bottom: 1rpx solid #f3f4f6;

  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;

  color: #9ca3af;

  font-size: 26rpx;
}

.info-value {
  flex: 1;

  text-align: right;

  color: #111827;

  font-size: 28rpx;

  line-height: 1.6;

  word-break: break-all;
}

/* ======================
   职位列表
====================== */

.job-mini {
  display: flex;
  justify-content: space-between;
  align-items: center;

  padding: 24rpx 0;

  border-bottom: 1rpx solid #f3f4f6;
}

.job-mini:last-child {
  border-bottom: none;
}

.job-left {
  flex: 1;
}

.job-title {
  font-size: 30rpx;
  font-weight: 600;

  color: #111827;
}

.job-meta {
  margin-top: 10rpx;

  font-size: 24rpx;

  color: #9ca3af;
}

.job-right {
  display: flex;
  align-items: center;
}

.salary {
  color: #ff5c39;

  font-size: 30rpx;
  font-weight: 700;
}

.arrow {
  margin-left: 12rpx;

  color: #d1d5db;

  font-size: 36rpx;
}

/* ======================
   Empty
====================== */

.empty {
  text-align: center;

  padding: 60rpx 0;

  color: #9ca3af;

  font-size: 26rpx;
}