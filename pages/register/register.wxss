page {
  background:#f6f7f9;
}

.page {
  min-height:100vh;
  padding-bottom:180rpx;
}

/* ==========================
   Navbar
========================== */
.navbar {
  position:fixed;
  top:0; left:0; right:0;
  z-index:999;
  background:rgba(246,247,249,.92);
  backdrop-filter:blur(24rpx);
}

.navbar-content {
  margin-top:88rpx;
  height:88rpx;
  display:flex;
  align-items:center;
  padding:0 24rpx;
}

.nav-back {
  width:72rpx; height:72rpx;
  border-radius:18rpx;
  background:#fff;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:30rpx;
  color:#111827;
  box-shadow:0 4rpx 12rpx rgba(0,0,0,.04);
}

.nav-title {
  flex:1;
  text-align:center;
  font-size:30rpx;
  font-weight:600;
  color:#111827;
}

.nav-placeholder {
  width:72rpx;
}

/* ==========================
   Hero
========================== */
.hero.register-hero {
  padding-top:200rpx;
  margin-left: 3%;
}

.hero-title {
  font-size:58rpx;
  font-weight:700;
  color:#111827;
  line-height:1.2;
}

.hero-desc {
  margin-top:16rpx;
  font-size:28rpx;
  color:#6b7280;
  line-height:1.6;
}

/* ==========================
   Section Title
========================== */
.section-title {
  margin:24rpx;
  font-size:26rpx;
  font-weight:600;
  color:#6b7280;
}

/* ==========================
   Role Section
========================== */
.role-section {
  margin:0 24rpx 24rpx;
}

.role-card {
  background:#fff;
  border-radius:24rpx;
  padding:32rpx;
  margin-bottom:16rpx;
  border:2rpx solid transparent;
  box-shadow:0 8rpx 24rpx rgba(15,23,42,.03);
  transition:.2s;
}

.role-card.active {
  border-color:#ff5c39;
  background:#fff8f6;
}

.role-head {
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.role-name {
  font-size:32rpx;
  font-weight:700;
  color:#111827;
}

.role-check {
  width:42rpx;
  height:42rpx;
  border-radius:50%;
  background:#ff5c39;
  display:flex;
  align-items:center;
  justify-content:center;
  color:#fff;
  font-size:22rpx;
}

.role-desc {
  margin-top:14rpx;
  font-size:24rpx;
  color:#6b7280;
  line-height:1.7;
}

/* ==========================
   Form
========================== */
.form-card {
  margin:24rpx;
  background:#fff;
  border-radius:24rpx;
  overflow:hidden;
  box-shadow:0 8rpx 24rpx rgba(15,23,42,.03);
}

.form-item {
  padding:28rpx 32rpx;
  border-bottom:1rpx solid #f3f4f6;
}

.form-item:last-child {
  border-bottom:none;
}

.label {
  margin-bottom:12rpx;
  font-size:24rpx;
  color:#9ca3af;
}

.form-item input {
  width:100%;
  font-size:30rpx;
  color:#111827;
}

.form-item input::placeholder {
  color:#c4c7ce;
}

.required {
  color: #ff3b30;
  font-weight: 600;
}

.logo-uploader {
  display: flex;
  align-items: center;
}

.logo-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  object-fit: cover;
}

.logo-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: #f3f4f6;
  border: 2rpx dashed #d1d5db;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.logo-plus {
  font-size: 36rpx;
  color: #9ca3af;
  line-height: 1;
}

.logo-hint {
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.picker-value {
  width: 100%;
  font-size: 30rpx;
  color: #c4c7ce;
}

.picker-value.filled {
  color: #111827;
}

/* ==========================
   Agreement
========================== */
.agree-row {
  margin:32rpx 24rpx 0;
  display:flex;
  align-items:center;
}

.agree-box {
  width:36rpx; height:36rpx;
  border:2rpx solid #d1d5db;
  border-radius:10rpx;
  display:flex;
  align-items:center;
  justify-content:center;
  color:transparent;
  flex-shrink:0;
}

.agree-box.checked {
  background:#ff5c39;
  border-color:#ff5c39;
  color:#fff;
}

.agree-text {
  margin-left:12rpx;
  font-size:24rpx;
  color:#6b7280;
  line-height:1.5;
}

/* ==========================
   Floating Register Button
========================== */
.floating-bar {
  position:fixed;
  left:24rpx;
  right:24rpx;
  bottom:24rpx;
  z-index:999;
}

.submit-btn {
  height:96rpx;
  border-radius:24rpx;
  background:#111827;
  display:flex;
  align-items:center;
  justify-content:center;
  color:#fff;
  font-size:30rpx;
  font-weight:600;
  box-shadow:0 16rpx 40rpx rgba(17,24,39,.16);
}

/* ==========================
   Login Link
========================== */
.login-link {
  text-align:center;
  margin-top:28rpx;
  font-size:26rpx;
  color:#6b7280;
}

/* ==========================
   Safe area
========================== */
.safe-bottom {
  height:env(safe-area-inset-bottom);
}