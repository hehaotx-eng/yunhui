/* pages/register/register.wxss */
.register-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.register-header {
  padding: 100rpx 40rpx 40rpx;
  text-align: center;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 30rpx;
  background: linear-gradient(135deg, #00a2ff, #0066ff);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-text {
  font-size: 56rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.tab-bar {
  display: flex;
  margin: 0 40rpx;
  background: #fff;
  border-radius: 48rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.tab-item {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #00a2ff, #0066ff);
  color: #fff;
}

.register-form {
  padding: 40rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border-radius: 44rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  border: 1rpx solid #eee;
}

.form-input:focus {
  border-color: #00a2ff;
}

.checkbox-wrap {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin: 20rpx 0;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ccc;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.checkbox.checked {
  background: #00a2ff;
  border-color: #00a2ff;
  color: #fff;
  font-size: 24rpx;
}

.agreement {
  font-size: 24rpx;
  color: #666;
}

.agreement-link {
  font-size: 24rpx;
  color: #00a2ff;
}

.register-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #00a2ff, #0066ff);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 30rpx;
}

.register-btn text {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
}

.login-link {
  text-align: center;
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #666;
}

.login-link .link {
  color: #00a2ff;
  margin-left: 8rpx;
}