/* pages/register/register.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #e8f4fd 100%);
}

.content {
  padding: 60rpx 40rpx 40rpx;
}

.logo-section {
  text-align: center;
  padding: 40rpx 0;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 30rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 32rpx rgba(16, 185, 129, 0.25);
}

.logo-icon {
  font-size: 56rpx;
}

.app-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  margin-bottom: 12rpx;
}

.app-subtitle {
  font-size: 26rpx;
  color: #64748b;
}

.role-tabs {
  display: flex;
  gap: 24rpx;
  margin: 32rpx 0;
}

.role-tab {
  flex: 1;
  height: 100rpx;
  background: #fff;
  border-radius: 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
  border: 2rpx solid transparent;
}

.role-tab.active {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
}

.role-icon {
  font-size: 36rpx;
}

.role-text {
  font-size: 26rpx;
  color: #475569;
}

.role-tab.active .role-text {
  color: #fff;
}

.form-section {
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.form-scroll {
  max-height: 800rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-input {
  width: 100%;
  height: 96rpx;
  background: #f8fafc;
  border-radius: 24rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  color: #1e293b;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.form-input:focus {
  border-color: #10b981;
  background: #fff;
}

.form-input::placeholder {
  color: #94a3b8;
}

.agree-section {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 8rpx;
  padding: 20rpx 0;
}

.agree-checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.agree-checkbox.checked {
  background: #10b981;
  border-color: #10b981;
}

.agree-checkbox.checked text {
  color: #fff;
  font-size: 24rpx;
}

.agree-text {
  font-size: 24rpx;
  color: #64748b;
}

.agree-link {
  font-size: 24rpx;
  color: #10b981;
}

.btn-register {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
}

.btn-register text {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
}

.login-hint {
  text-align: center;
  font-size: 28rpx;
  color: #64748b;
}

.login-link {
  color: #10b981;
  margin-left: 8rpx;
}