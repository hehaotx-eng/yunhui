<!--pages/register/register.wxml-->
<view class="page">
  <view class="content">
    <view class="logo-section">
      <view class="logo">
        <text class="logo-icon">📝</text>
      </view>
      <text class="app-title">创建账号</text>
      <text class="app-subtitle">开启您的职业之旅</text>
    </view>

    <view class="role-tabs">
      <view 
        class="role-tab {{role === 'user' ? 'active' : ''}}" 
        bindtap="setRole('user')"
      >
        <text class="role-icon">👤</text>
        <text class="role-text">个人用户</text>
      </view>
      <view 
        class="role-tab {{role === 'enterprise' ? 'active' : ''}}" 
        bindtap="setRole('enterprise')"
      >
        <text class="role-icon">🏢</text>
        <text class="role-text">企业用户</text>
      </view>
    </view>

    <view class="form-section">
      <scroll-view class="form-scroll" scroll-y>
        <view wx:if="{{role === 'user'}}">
          <view class="form-item">
            <input class="form-input" placeholder="用户名" value="{{form.username}}" bindinput="onInput" data-field="username" />
          </view>
          <view class="form-item">
            <input class="form-input" placeholder="邮箱" value="{{form.email}}" bindinput="onInput" data-field="email" />
          </view>
          <view class="form-item">
            <input class="form-input" type="password" placeholder="密码" value="{{form.password}}" bindinput="onInput" data-field="password" />
          </view>
          <view class="form-item">
            <input class="form-input" type="password" placeholder="确认密码" value="{{form.confirmPassword}}" bindinput="onInput" data-field="confirmPassword" />
          </view>
          <view class="form-item">
            <input class="form-input" placeholder="手机号（选填）" value="{{form.phone}}" bindinput="onInput" data-field="phone" />
          </view>
        </view>

        <view wx:if="{{role === 'enterprise'}}">
          <view class="form-item">
            <input class="form-input" placeholder="企业名称" value="{{form.name}}" bindinput="onInput" data-field="name" />
          </view>
          <view class="form-item">
            <input class="form-input" placeholder="联系人" value="{{form.contact}}" bindinput="onInput" data-field="contact" />
          </view>
          <view class="form-item">
            <input class="form-input" placeholder="邮箱" value="{{form.email}}" bindinput="onInput" data-field="email" />
          </view>
          <view class="form-item">
            <input class="form-input" type="password" placeholder="密码" value="{{form.password}}" bindinput="onInput" data-field="password" />
          </view>
          <view class="form-item">
            <input class="form-input" type="password" placeholder="确认密码" value="{{form.confirmPassword}}" bindinput="onInput" data-field="confirmPassword" />
          </view>
          <view class="form-item">
            <input class="form-input" placeholder="手机号" value="{{form.phone}}" bindinput="onInput" data-field="phone" />
          </view>
          <view class="form-item">
            <input class="form-input" placeholder="企业地址" value="{{form.address}}" bindinput="onInput" data-field="address" />
          </view>
        </view>

        <view class="agree-section" bindtap="toggleAgree">
          <view class="agree-checkbox {{agreed ? 'checked' : ''}}">
            <text wx:if="{{agreed}}">✓</text>
          </view>
          <text class="agree-text">我已阅读并同意</text>
          <text class="agree-link">《用户协议》</text>
          <text class="agree-text">和</text>
          <text class="agree-link">《隐私政策》</text>
        </view>
      </scroll-view>
    </view>

    <view class="btn-register" bindtap="handleRegister">
      <text>{{role === 'user' ? '注册个人账号' : '注册企业账号'}}</text>
    </view>

    <view class="login-hint">
      <text>已有账号？</text>
      <text class="login-link" bindtap="goLogin">立即登录</text>
    </view>
  </view>
</view>