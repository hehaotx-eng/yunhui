<view class="page">

<!-- Hero 顶部欢迎 -->
<view class="hero register-hero">
  <view class="hero-title">
    欢迎加入
  </view>
  <view class="hero-desc">
    {{role === 'user' ? '找到心仪工作，开启新的职业机会' : '发布优质职位，招募优秀人才'}}
  </view>
</view>

<!-- 身份选择 -->
<view class="section-title">选择身份</view>
<view class="role-section">
  <view class="role-card {{role === 'user' ? 'active' : ''}}" data-role="user" bindtap="setRole">
    <view class="role-head">
      <view class="role-name">个人用户</view>
      <view wx:if="{{role === 'user'}}" class="role-check">✓</view>
    </view>
    <view class="role-desc">浏览职位 · 投递简历 · 在线沟通</view>
  </view>

  <view class="role-card {{role === 'enterprise' ? 'active' : ''}}" data-role="enterprise" bindtap="setRole">
    <view class="role-head">
      <view class="role-name">企业用户</view>
      <view wx:if="{{role === 'enterprise'}}" class="role-check">✓</view>
    </view>
    <view class="role-desc">发布职位 · 管理人才 · 在线招聘</view>
  </view>
</view>

<!-- 基础信息 -->
<view class="section-title">基础信息</view>
<view class="form-card">

  <view class="form-item">
    <view class="label">用户名</view>
    <input placeholder="请输入用户名" value="{{form.username}}" data-field="username" bindinput="onInput"/>
  </view>

  <view class="form-item">
    <view class="label">手机号</view>
    <input type="number" placeholder="请输入手机号" value="{{form.phone}}" data-field="phone" bindinput="onInput"/>
  </view>

  <block wx:if="{{role === 'user'}}">
    <view class="form-item">
      <view class="label">邮箱</view>
      <input placeholder="选填" value="{{form.email}}" data-field="email" bindinput="onInput"/>
    </view>
  </block>

  <block wx:else>
    <view class="form-item">
      <view class="label">企业 Logo</view>
      <view class="logo-uploader" bindtap="chooseLogo">
        <image wx:if="{{form.logo}}" class="logo-preview" src="{{form.logo}}" mode="aspectFill" />
        <view wx:else class="logo-placeholder">
          <text class="logo-plus">+</text>
          <text class="logo-hint">上传企业Logo</text>
        </view>
      </view>
    </view>
    <view class="form-item">
      <view class="label">企业名称 <text class="required">*</text></view>
      <input placeholder="请输入企业名称" value="{{form.name}}" data-field="name" bindinput="onInput"/>
    </view>
    <view class="form-item">
      <view class="label">联系人 <text class="required">*</text></view>
      <input placeholder="请输入联系人姓名" value="{{form.contactName}}" data-field="contactName" bindinput="onInput"/>
    </view>
    <view class="form-item">
      <view class="label">联系电话 <text class="required">*</text></view>
      <input type="number" placeholder="请输入联系电话" value="{{form.contactPhone}}" data-field="contactPhone" bindinput="onInput"/>
    </view>
    <view class="form-item">
      <view class="label">企业地址</view>
      <input placeholder="请输入企业地址" value="{{form.address}}" data-field="address" bindinput="onInput"/>
    </view>
    <view class="form-item no-border">
      <view class="label">企业规模</view>
      <picker mode="selector" range="{{scaleOptions}}" bindchange="onScaleChange">
        <view class="picker-value {{form.scale ? 'filled' : ''}}">
          <text>{{form.scale || '请选择企业规模'}}</text>
        </view>
      </picker>
    </view>
  </block>

  <view class="form-item">
    <view class="label">登录密码</view>
    <input password placeholder="请输入密码" value="{{form.password}}" data-field="password" bindinput="onInput"/>
  </view>

  <view class="form-item no-border">
    <view class="label">确认密码</view>
    <input password placeholder="再次输入密码" value="{{form.confirmPassword}}" data-field="confirmPassword" bindinput="onInput"/>
  </view>

</view>

<!-- 协议 -->
<view class="agree-row" bindtap="toggleAgree">
  <view class="agree-box {{agreed ? 'checked' : ''}}">✓</view>
  <view class="agree-text">我已阅读并同意《用户协议》与《隐私政策》</view>
</view>

<!-- 悬浮注册按钮 -->
<view class="floating-bar">
  <view class="submit-btn" bindtap="handleRegister">
    {{role === 'user' ? '注册个人账号' : '注册企业账号'}}
  </view>
</view>

<!-- 登录入口 -->
<view class="login-link" bindtap="goLogin">已有账号？立即登录</view>

<view class="safe-bottom"></view>

</view>