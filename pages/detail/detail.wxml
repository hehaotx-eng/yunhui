<view class="page" wx:if="{{job}}">

  <!-- 自定义导航栏 -->
  <view class="navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-content">

      <view class="nav-back" bindtap="goBack">
        ‹
        </view>

          <view class="nav-title">
            {{job.title || '职位详情'}}
          </view>

          <view class="nav-placeholder"></view>

      </view>
    </view>

    <!-- 职位信息 -->
    <view class="hero">

      <view class="title">
        {{job.title}}
      </view>

      <view class="salary">
        {{job.salary || '面议'}}
      </view>

      <view class="meta">
        {{job.area || '地区不限'}} ·
        {{job.experience || '经验不限'}} ·
        {{job.education || '学历不限'}}
      </view>
      <view class="tag-row">

        <view wx:if="{{job.workType}}" class="tag-primary">
          {{job.workType}}
        </view>

        <view wx:for="{{job.tags || job.welfare}}" wx:key="*this" class="tag">
          {{item}}
        </view>

      </view>

    </view>

    <!-- 职位描述 -->
    <view class="section">

      <view class="section-title">
        职位描述
      </view>

      <view class="body-text">
        {{job.description || '暂无职位描述'}}
      </view>

    </view>

    <!-- 任职要求 -->
    <view class="section">

      <view class="section-title">
        任职要求
      </view>

      <view class="body-text">
        {{job.requirements || '暂无任职要求'}}
      </view>

    </view>

    <!-- 企业信息综合卡 -->
    <view class="section">

      <view class="company-card" bindtap="goCompany">

        <view class="logo">
          {{job.enterpriseName ? job.enterpriseName.substring(0,1) : '企'}}
        </view>

        <view class="company-content">

          <view class="company-name">
            {{job.enterpriseName || '企业信息待完善'}}
          </view>

          <view class="company-meta">
            {{job.industry || job.category || '招聘企业'}}
            ·
            {{job.scale || '规模待完善'}}
          </view>

        </view>

        <view class="arrow">
          ›
        </view>

      </view>

      <view class="info-item">
        <view class="info-label">
          工作地点
        </view>

        <view class="info-value">
          {{job.address || job.area || '地址待完善'}}
        </view>
      </view>

      <view class="info-item">
        <view class="info-label">
          联系人
        </view>

        <view class="info-value">
          {{job.contactName || '待完善'}}
        </view>
      </view>

      <view class="info-item">
        <view class="info-label">
          联系电话
        </view>

        <view class="info-value phone" bindtap="callPhone">
          {{job.contactPhone || '待完善'}}
        </view>
      </view>

      <view class="report" bindtap="goReport">
        举报该职位
      </view>

    </view>

    <!-- 企业端 -->
    <view class="bottom-bar" wx:if="{{isEnterprise}}">

      <view class="edit-btn" bindtap="goEdit">
        修改职位
      </view>

      <view class="delete-btn" bindtap="handleDelete">
        删除职位
      </view>

    </view>

    <!-- 求职者端 -->
    <view class="bottom-bar" wx:else>

      <view class="mini-btn" bindtap="toggleCollect">
        {{isCollected ? '已收藏' : '收藏'}}
      </view>

      <view class="chat-btn" bindtap="goChat">
        立即沟通
      </view>

      <view class="apply-btn" bindtap="handleApply">
        投递简历
      </view>

    </view>

  </view>