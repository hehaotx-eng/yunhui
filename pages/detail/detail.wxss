.detail-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  height: 200rpx;
  padding: 0 24rpx;
  background: rgba(255,255,255,.25);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
}
.nav-back { width: 72rpx; height: 72rpx; display: flex; align-items: center; }
.back-icon { font-size: 42rpx; color: #333; }
.nav-title { flex: 1; text-align: center; font-size: 34rpx; font-weight: 700; color: #1a1a2e; letter-spacing: 2rpx; }

.detail-scroll { height: calc(100vh - 200rpx - 120rpx - env(safe-area-inset-bottom)); padding-top: 200rpx; }

.job-header {
  background: #fff;
  padding: 32rpx 24rpx 24rpx;
}
.job-title-row { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20rpx; }
.job-title { font-size: 36rpx; font-weight: 700; color: #1a1a2e; flex: 1; margin-right: 16rpx; line-height: 1.4; }
.job-salary { font-size: 36rpx; font-weight: 700; color: #ff5c39; white-space: nowrap; }
.job-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.tag {
  padding: 8rpx 20rpx; border-radius: 6rpx; background: #f5f5f5;
  font-size: 22rpx; color: #666;
}

.company-card {
  display: flex; align-items: center;
  margin: 16rpx 24rpx; padding: 24rpx;
  background: #fff; border-radius: 16rpx;
}
.company-logo { width: 72rpx; height: 72rpx; border-radius: 12rpx; margin-right: 16rpx; flex-shrink: 0; }
.company-info { flex: 1; }
.company-name { font-size: 28rpx; font-weight: 600; color: #1a1a2e; display: block; margin-bottom: 4rpx; }
.company-meta { font-size: 22rpx; color: #999; }
.company-arrow { font-size: 32rpx; color: #ccc; }

.section {
  margin: 16rpx 24rpx; padding: 24rpx;
  background: #fff; border-radius: 16rpx;
}
.section-title { font-size: 28rpx; font-weight: 700; color: #1a1a2e; display: block; margin-bottom: 16rpx; }
.section-body { font-size: 26rpx; color: #555; line-height: 1.9; white-space: pre-wrap; }

.env-scroll { display: flex; gap: 16rpx; white-space: nowrap; }
.env-img { width: 240rpx; height: 180rpx; border-radius: 12rpx; display: inline-block; margin-right: 16rpx; }

.about-company {
  display: flex; align-items: center;
  padding: 20rpx; border-radius: 12rpx; background: #fafafa;
}
.about-logo { width: 64rpx; height: 64rpx; border-radius: 12rpx; margin-right: 16rpx; flex-shrink: 0; }
.about-info { flex: 1; }
.about-name { font-size: 26rpx; font-weight: 600; color: #1a1a2e; display: block; margin-bottom: 4rpx; }
.about-desc { font-size: 22rpx; color: #999; }
.about-arrow { font-size: 24rpx; color: #0066ff; }

.related-job {
  padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0;
}
.related-job:last-child { border-bottom: none; }
.rj-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.rj-title { font-size: 26rpx; font-weight: 500; color: #1a1a2e; }
.rj-salary { font-size: 26rpx; font-weight: 600; color: #ff5c39; }
.rj-meta { font-size: 22rpx; color: #999; }

.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center;
  padding: 12rpx 24rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,.95);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid #eee;
  z-index: 100;
}
.bar-left { display: flex; gap: 20rpx; }
.bar-action { display: flex; flex-direction: column; align-items: center; gap: 2rpx; }
.bar-icon { font-size: 28rpx; }
.bar-label { font-size: 18rpx; color: #999; }
.bar-right { display: flex; gap: 12rpx; flex: 1; margin-left: 24rpx; }
.bar-chat {
  flex: 1; height: 72rpx; border-radius: 36rpx; background: #1a1a2e;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; font-weight: 600; color: #fff;
}
.bar-apply {
  flex: 1; height: 72rpx; border-radius: 36rpx;
  background: linear-gradient(135deg, #ff5c39, #ff7a5c);
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; font-weight: 600; color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(255,92,57,.25);
}

.bar-manage {
  flex: 1; height: 72rpx; border-radius: 36rpx;
  background: #1a1a2e;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; font-weight: 600; color: #fff;
}

.skeleton-wrap { padding: 24rpx; }
.skeleton-line { height: 20rpx; border-radius: 6rpx; margin-bottom: 12rpx; }
.skeleton-line-lg { width: 80%; }
.skeleton-line-md { width: 60%; }
.skeleton-card { background: #fff; border-radius: 16rpx; }
