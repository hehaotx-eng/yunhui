/* pages/detail/detail.wxss */
/* pages/detail/detail.wxss */
.page {
  background: #f5f5f8;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* 顶部卡片 */
.header {
  position: relative;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, #4a90d9, #357abd);
}

.header-content {
  position: relative;
  padding: 40rpx 36rpx 32rpx;
  z-index: 1;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.job-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #fff;
  flex: 1;
  margin-right: 20rpx;
}

.salary {
  font-size: 38rpx;
  font-weight: 700;
  color: #ffd700;
  white-space: nowrap;
}

.company-name {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 24rpx;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.18);
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
}

.meta-icon {
  font-size: 24rpx;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag {
  font-size: 22rpx;
  color: #4a90d9;
  background: rgba(255, 255, 255, 0.92);
  padding: 8rpx 22rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

/* 发布日期 */
.date-bar {
  padding: 18rpx 36rpx;
  font-size: 24rpx;
  color: #999;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

/* 内容区块 */
.section {
  background: #fff;
  margin-top: 20rpx;
  padding: 32rpx 36rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 24rpx;
  padding-left: 18rpx;
  border-left: 6rpx solid #4a90d9;
}

.section-body {
  padding: 0 12rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.85;
  white-space: pre-wrap;
}

/* 联系方式 */
.contact-section {
  margin-bottom: 20rpx;
}

.contact-info {
  padding: 0 12rpx;
}

.contact-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.contact-row:last-child {
  border-bottom: none;
}

.contact-label {
  font-size: 26rpx;
  color: #999;
  width: 120rpx;
}

.contact-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0; right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.btn-collect {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 130rpx;
  height: 100rpx;
  margin-right: 24rpx;
  color: #666;
}

.btn-collect.active {
  color: #f5a623;
}

.collect-icon {
  font-size: 40rpx;
  margin-bottom: 2rpx;
}

.collect-text {
  font-size: 20rpx;
}

.btn-phone {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #4a90d9, #357abd);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  letter-spacing: 2rpx;
}

.phone-icon {
  font-size: 34rpx;
}
