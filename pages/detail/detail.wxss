page {
  background: #f6f7f9;
}

.page {
  padding: 24rpx;
  padding-bottom: 180rpx;
}

/* =====================
   导航栏
===================== */

.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  background: rgba(246, 247, 249, .96);
  backdrop-filter: blur(20rpx);
}

.navbar-content {
  margin-top: 90rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.nav-back {
  width: 72rpx;
  height: 72rpx;

  background: #fff;
  border-radius: 18rpx;

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 32rpx;
  color: #111827;

  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, .04);
}

.nav-title {
  flex: 1;

  text-align: center;

  font-size: 30rpx;
  font-weight: 600;

  color: #111827;

  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;

  padding: 0 20rpx;
}

.nav-placeholder {
  width: 72rpx;
}

/* =====================
   职位信息
===================== */

.hero {
  margin-top: 200rpx;
  background: #fff;

  border-radius: 24rpx;

  padding: 36rpx;

  margin-bottom: 20rpx;

  overflow: hidden;

  box-shadow:
    0 8rpx 24rpx rgba(15, 23, 42, .03);
}

.title {
  font-size: 40rpx;
  font-weight: 700;

  color: #111827;

  line-height: 1.5;
}

.salary {
  margin-top: 12rpx;

  font-size: 42rpx;
  font-weight: 600;

  color: #ff5c39;

  line-height: 1.3;
}

.meta {
  margin-top: 16rpx;

  font-size: 26rpx;

  color: #6b7280;

  line-height: 1.8;
}

/* =====================
   标签
===================== */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.tag,
.tag-primary {
  padding: 10rpx 18rpx;
  font-size: 26rpx;
  line-height: 1;
  border-radius: 8rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.tag-primary {
  background: #111827;

  color: #fff;

  border-radius: 8rpx;
}

.tag {
  background: #f5f6f8;

  border: 1rpx solid #e8ebf0;

  color: #667085;

  border-radius: 8rpx;
}

/* =====================
   通用卡片
===================== */

.section {
  background: #fff;

  border-radius: 24rpx;

  padding: 32rpx;

  margin-bottom: 20rpx;

  box-shadow:
    0 8rpx 24rpx rgba(15, 23, 42, .03);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;

  color: #111827;

  margin-bottom: 24rpx;
}

.body-text {
  font-size: 28rpx;

  color: #4b5563;

  line-height: 1.9;

  white-space: pre-wrap;
}

/* =====================
   企业信息
===================== */

.company-card {
  display: flex;
  align-items: center;
}

.logo {
  width: 88rpx;
  height: 88rpx;

  background: #f3f4f6;

  border-radius: 18rpx;

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 34rpx;
  font-weight: 700;

  color: #111827;
}

.company-content {
  flex: 1;

  margin-left: 20rpx;
}

.company-name {
  font-size: 30rpx;
  font-weight: 700;

  color: #111827;
}

.company-meta {
  margin-top: 8rpx;

  font-size: 24rpx;

  color: #9ca3af;
}

.arrow {
  font-size: 40rpx;

  color: #d1d5db;
}

/* =====================
   信息项
===================== */

.info-item {
  padding: 24rpx 0;

  border-top: 1rpx solid #f1f3f5;
}

.info-label {
  font-size: 24rpx;

  color: #9ca3af;
}

.info-value {
  margin-top: 8rpx;

  font-size: 28rpx;

  color: #111827;

  line-height: 1.6;
}

.phone {
  font-weight: 600;
}

.report {
  margin-top: 24rpx;

  text-align: center;

  color: #ef4444;

  font-size: 26rpx;
}

/* =====================
   底部按钮
===================== */

.bottom-bar {
  position: fixed;

  left: 24rpx;
  right: 24rpx;
  bottom: 30rpx;

  height: 96rpx;

  background: rgba(255, 255, 255, .96);

  border-radius: 20rpx;

  padding: 10rpx;

  display: flex;
  align-items: center;

  box-shadow:
    0 12rpx 36rpx rgba(0, 0, 0, .08);

  z-index: 999;
}

.mini-btn {
  width: 140rpx;

  height: 100%;

  display: flex;
  align-items: center;
  justify-content: center;

  color: #111827;

  font-size: 28rpx;
}

.chat-btn {
  flex: 1;

  height: 100%;

  margin: 0 10rpx;

  background: #f3f4f6;

  border-radius: 14rpx;

  display: flex;
  align-items: center;
  justify-content: center;

  color: #111827;

  font-size: 28rpx;
  font-weight: 600;
}

.apply-btn {
  flex: 1.3;

  height: 100%;

  background: #ff5c39;

  border-radius: 14rpx;

  color: #fff;

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 28rpx;
  font-weight: 600;
}

.edit-btn,
.delete-btn {
  flex: 1;

  height: 100%;

  border-radius: 14rpx;

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 28rpx;
  font-weight: 600;
}

.edit-btn {
  margin-right: 10rpx;

  background: #111827;

  color: #fff;
}

.delete-btn {
  background: #f3f4f6;

  color: #ef4444;
}