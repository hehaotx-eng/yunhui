<view class="page">
  <view class="body">
    <scroll-view class="tabs" scroll-x enhanced show-scrollbar="{{false}}">
      <view wx:for="{{tabs}}" wx:key="id" class="tab {{activeTab === item.id ? 'active' : ''}}" bindtap="switchTab" data-tab="{{item.id}}">{{item.name}}</view>
    </scroll-view>

    <view class="list">
      <view wx:for="{{jobs}}" wx:key="id" class="card" bindtap="goDetail" data-id="{{item.id}}">
        <view class="card-top">
          <text class="card-title">{{item.title}}</text>
          <view class="status-group">
            <text class="status-tag {{item.status === 'online' ? 'online' : 'offline'}}">{{item.status === 'online' ? '在线' : item.status === 'offline' ? '已下线' : item.status === 'draft' ? '草稿' : item.status}}</text>
            <text wx:if="{{item.audit_status === 'pending'}}" class="audit-tag">审核中</text>
            <text wx:elif="{{item.audit_status === 'rejected'}}" class="audit-tag rejected">未通过</text>
          </view>
        </view>
        <text class="card-salary">{{item.salary || (item.salary_min && item.salary_max ? item.salary_min + '-' + item.salary_max + '元' : '薪资面议')}}</text>
        <view class="card-actions">
          <text class="meta-text">{{item.applicantCount || 0}}人投递</text>
          <view class="action-btns">
            <text class="action-btn" catchtap="goEdit" data-id="{{item.id}}">编辑</text>
            <text wx:if="{{item.audit_status === 'approved'}}" class="action-btn status-btn" catchtap="toggleStatus" data-id="{{item.id}}">{{item.status === 'online' ? '下线' : '上线'}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{showEmpty}}" class="empty">
        <text class="empty-text">暂无职位</text>
        <text class="empty-btn" bindtap="goPostJob">去发布</text>
      </view>
      <view wx:if="{{loading}}" class="loading">加载中...</view>
    </view>
  </view>
</view>

<enterprise-tabbar current="jobs" />
