<view class="page">

<!-- 顶部导航栏 -->
<view class="header">
  <view class="header-content">
    <view class="header-title">岗位管理</view>
    <view class="add-btn" bindtap="goAdd">+</view>
  </view>
</view>

<!-- 内容区 -->
<view class="content">

  <!-- Tabs 横向滚动 -->
  <scroll-view class="tabs-scroll" scroll-x>
    <view wx:for="{{tabs}}" wx:key="id" class="tab {{activeTab === item.id ? 'active' : ''}}" data-id="{{item.id}}" bindtap="switchTab">
      {{item.name}}
    </view>
  </scroll-view>

  <!-- 职位列表 -->
  <view class="job-list">

    <view wx:for="{{jobs}}" wx:key="id" class="job-card" bindtap="goDetail" data-id="{{item.id}}">
      
      <!-- 职位标题 + 状态 -->
      <view class="job-header">
        <view class="job-title">{{item.title}}</view>
        <view wx:if="{{item.status === 'active' || item.status === 'published'}}" class="status-tag active">进行中</view>
        <view wx:elif="{{item.status === 'paused' || item.status === 'offline'}}" class="status-tag paused">已暂停</view>
        <view wx:else class="status-tag">进行中</view>
      </view>

      <!-- 薪资和信息 -->
      <view class="job-salary">{{item.salary}}</view>
      <view class="job-meta">{{item.area}} · {{item.category || '未分类'}}</view>

      <!-- 底部操作 -->
      <view class="job-footer">
        <view class="stats">
          <text class="stat">{{item.applicantCount || 0}}人投递</text>
        </view>
        <view class="actions">
          <view class="action-btn" catchtap="goEdit" data-id="{{item.id}}">编辑</view>
          <view class="action-btn" catchtap="goResume" data-id="{{item.id}}">简历</view>
          <view class="action-btn status-btn" catchtap="toggleStatus" data-id="{{item.id}}">
            {{item.status === 'active' || item.status === 'published' ? '下线' : '发布'}}
          </view>
          <view class="action-btn delete-btn" catchtap="deleteJob" data-id="{{item.id}}">删除</view>
        </view>
      </view>

    </view>

    <!-- 空状态 -->
    <view wx:if="{{showEmpty}}" class="empty-card">
      <image class="empty-icon" src="/images/job-empty.png"/>
      <view class="empty-text">暂无职位</view>
      <view class="empty-btn" bindtap="goAdd">发布职位</view>
    </view>

    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loading">加载中...</view>

  </view>

</view>

<!-- 底部 TabBar -->
<view class="tabbar">
  <view class="tab-item" bindtap="goHome">
    <image class="tab-icon" src="/images/tab-home.png"/>
    <view class="tab-text">首页</view>
  </view>
  <view class="tab-item" bindtap="goCandidates">
    <image class="tab-icon" src="/images/tab-candidates.png"/>
    <view class="tab-text">人才</view>
  </view>
  <view class="tab-item active">
    <image class="tab-icon" src="/images/tab-jobs.png"/>
    <view class="tab-text">岗位</view>
  </view>
  <view class="tab-item" bindtap="goMsg">
    <image class="tab-icon" src="/images/tab-msg.png"/>
    <view class="tab-text">消息</view>
  </view>
  <view class="tab-item" bindtap="goMy">
    <image class="tab-icon" src="/images/tab-my.png"/>
    <view class="tab-text">我的</view>
  </view>
</view>

</view>