.page {
  min-height: 100vh;
  background: #f6f7f9;
  padding-bottom: 160rpx;
}

.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255,255,255,.25);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
}

.nav-logo {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a1a2e;
  flex: 1;
}

.nav-add {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1a1a2e;
  border-radius: 50%;
}

.nav-add-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

.body {
  padding: 0 20rpx 40rpx;
}

.tabs {
  display: flex;
  white-space: nowrap;
  padding: 16rpx 0;
}

.tab {
  display: inline-flex;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #6b7280;
  background: #f3f4f6;
  border-radius: 40rpx;
  font-weight: 500;
}

.tab.active {
  background: #1a1a2e;
  color: #fff;
  font-weight: 600;
}

.list {
  padding-top: 8rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.status-tag.online {
  background: #f0f9eb;
  color: #389e0d;
}

.status-tag.offline {
  background: #f3f4f6;
  color: #9ca3af;
}

.status-group {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.audit-tag {
  font-size: 18rpx;
  padding: 3rpx 10rpx;
  border-radius: 4rpx;
  background: #fef9ee;
  color: #d48806;
  font-weight: 500;
}

.audit-tag.rejected {
  background: #fff2f0;
  color: #cf1322;
}

.card-salary {
  font-size: 28rpx;
  font-weight: 600;
  color: #ff5c39;
  display: block;
  margin-bottom: 16rpx;
}

.card-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f3f4f6;
}

.meta-text {
  font-size: 22rpx;
  color: #9ca3af;
}

.action-btns {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-weight: 500;
}

.action-btn.status-btn {
  background: rgba(255, 92, 57, .1);
  color: #ff5c39;
}

.empty {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
  display: block;
  margin-bottom: 20rpx;
}

.empty-btn {
  font-size: 26rpx;
  color: #299ff0;
  font-weight: 500;
}

.loading {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: #9ca3af;
}
