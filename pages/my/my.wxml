<view class="my-page">
  <view class="top-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <text class="nav-title">我的</text>
    </view>
  </view>

  <view wx:if="{{!isLoggedIn}}" class="login-prompt">
    <view class="login-avatar-circle">
      <text class="login-avatar-text">用</text>
    </view>
    <text class="login-title">登录账号</text>
    <text class="login-desc">求职更高效·简历管理·智能推荐</text>
    <view class="login-btn" bindtap="goLogin">立即登录</view>
    <view class="login-features">
      <view class="login-feature">
        <view class="lf-icon icon-ph"></view>
        <text class="lf-text">简历管理</text>
      </view>
      <view class="login-feature">
        <view class="lf-icon icon-ph"></view>
        <text class="lf-text">智能推荐</text>
      </view>
      <view class="login-feature">
        <view class="lf-icon icon-ph"></view>
        <text class="lf-text">在线沟通</text>
      </view>
    </view>
  </view>

  <block wx:else>
    <view class="page-content" style="padding-top: {{statusBarHeight + 44}}px;">
      <view class="profile-section">
      <view class="profile-card">
        <view class="profile-avatar-wrap" bindtap="goEditProfile">
          <image wx:if="{{userInfo.avatar}}" class="profile-avatar" src="{{userInfo.avatar}}" mode="aspectFill" />
          <view wx:else class="profile-avatar profile-avatar-fallback">{{avatarLetter}}</view>
          <view class="avatar-edit-badge">
            <text class="avatar-edit-icon icon-ph"></text>
          </view>
        </view>
        <view class="profile-info">
          <view class="profile-name-row">
            <text class="profile-name">{{userInfo.nickname || '用户'}}</text>
            <view class="profile-edit-btn" bindtap="goEditProfile">
              <text class="profile-edit-icon">✎</text>
              <text class="profile-edit-text">编辑</text>
            </view>
          </view>
          <text class="profile-phone">{{userInfo.phone || ''}}</text>
          <text class="profile-tag">{{isEnterprise ? '企业用户' : '个人用户'}}</text>
        </view>
      </view>
    </view>

    <!-- VIP 身份标识 -->
    <view class="vip-identity-card" wx:if="{{isVip}}" bindtap="goPage" data-url="/pages/vip/vip">
      <view class="vip-identity-glow"></view>
      <view class="vip-identity-content">
        <view class="vip-identity-left">
          <view class="vip-identity-crown icon-ph"></view>
          <view class="vip-identity-info">
            <text class="vip-identity-title">VIP会员</text>
            <text class="vip-identity-desc">尊享全部AI智能功能</text>
          </view>
        </view>
        <view class="vip-identity-action">
          <text class="vip-identity-action-text">查看权益</text>
        </view>
      </view>
    </view>

    <!-- 非VIP引导 -->
    <view class="vip-guide-card" wx:if="{{!isVip && isLoggedIn}}" bindtap="goPage" data-url="/pages/vip/vip">
      <view class="vip-guide-content">
        <view class="vip-guide-left">
          <view class="vip-guide-icon icon-ph"></view>
          <view class="vip-guide-info">
            <text class="vip-guide-title">开通VIP会员</text>
            <text class="vip-guide-desc">解锁AI推荐、简历优化等特权</text>
          </view>
        </view>
        <view class="vip-guide-action">
          <text class="vip-guide-action-text">立即开通</text>
        </view>
      </view>
    </view>

    <view class="stats-row">
      <view class="stats-item" bindtap="goPage" data-url="/pages/applications/applications">
        <text class="stats-num">{{stats.applicationCount}}</text>
        <text class="stats-label">投递</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item" bindtap="goPage" data-url="/pages/favorites/favorites">
        <text class="stats-num">{{stats.favoriteCount}}</text>
        <text class="stats-label">收藏</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-num">{{stats.resumeCount}}</text>
        <text class="stats-label">简历</text>
      </view>
    </view>

    <view class="section-header">
      <text class="section-title">简历管理</text>
    </view>
    <view class="section-body">
      <view class="resume-card" wx:for="{{resumeList}}" wx:key="id" data-id="{{item.id}}" bindtap="goPreviewResume">
        <view class="resume-icon">
          <view class="resume-icon-text icon-ph"></view>
        </view>
        <view class="resume-info">
          <text class="resume-title">{{item.title || '我的简历'}}</text>
          <text class="resume-time">更新于 {{item.updated_at || ''}}</text>
        </view>
        <text class="resume-arrow">›</text>
      </view>
      <view class="create-resume-card" bindtap="goCreateResume">
        <view class="create-resume-icon">+</view>
        <view class="create-resume-texts">
          <text class="create-resume-title">创建新简历</text>
          <text class="create-resume-desc">完善个人信息，获得更多机会</text>
        </view>
        <text class="resume-arrow">›</text>
      </view>
    </view>

    <view class="section-header">
      <text class="section-title">更多服务</text>
    </view>
    <view class="section-body">
      <view class="menu-list">
        <view wx:for="{{menus}}" wx:key="title" class="menu-item" bindtap="goPage" data-url="{{item.url}}">
          <view class="menu-icon" style="background: {{item.color}}15;">
            <text class="menu-icon-text" style="color: {{item.color}};">{{item.icon}}</text>
          </view>
          <view class="menu-info">
            <text class="menu-item-title">{{item.title}}</text>
            <text class="menu-item-desc">{{item.desc}}</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="logout-btn" bindtap="handleLogout">退出登录</view>
    </view>
  </block>
</view>

<custom-tab-bar />
