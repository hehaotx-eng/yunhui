<view class="my-page">
  <!-- 顶部导航 -->
  <view class="top-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <text class="nav-title">我的</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="login-prompt" style="margin-top: {{statusBarHeight + 44}}px;" bindtap="goLogin">
    <view class="login-avatar">
      <text class="login-avatar-text">用</text>
    </view>
    <text class="login-text">点击登录</text>
    <text class="login-desc">登录后体验更多功能</text>
  </view>

  <!-- 已登录状态 -->
  <block wx:else>
    <!-- 用户信息卡片 -->
    <view class="user-card" style="margin-top: {{statusBarHeight + 44}}px;">
      <view class="user-card-bg"></view>
      <view class="user-card-content">
        <view class="user-avatar-wrap">
          <view class="user-avatar">{{avatarLetter}}</view>
          <view wx:if="{{userInfo.is_vip}}" class="vip-badge">VIP</view>
        </view>
        <view class="user-info">
          <text class="user-name">{{userInfo.nickname || '用户'}}</text>
          <text class="user-phone">{{userInfo.phone || ''}}</text>
          <view class="user-tags">
            <text class="user-tag">{{isEnterprise ? '企业用户' : '个人用户'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 数据统计 -->
    <view class="stats-card">
      <view class="stats-item" bindtap="goPage" data-url="/pages/applications/applications">
        <text class="stats-num">{{stats.applicationCount}}</text>
        <text class="stats-label">我的投递</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item" bindtap="goPage" data-url="/pages/favorites/favorites">
        <text class="stats-num">{{stats.favoriteCount}}</text>
        <text class="stats-label">我的收藏</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-num">{{stats.resumeCount}}</text>
        <text class="stats-label">我的简历</text>
      </view>
    </view>

    <!-- 简历管理 -->
    <view class="section-header">
      <text class="section-title">简历管理</text>
    </view>
    <view class="resume-card" wx:if="{{stats.resumeCount > 0}}" wx:for="{{resumeList}}" wx:key="id">
      <view class="resume-info">
        <text class="resume-title">{{item.title || '我的简历'}}</text>
        <text class="resume-time">更新于 {{item.updated_at || ''}}</text>
      </view>
      <view class="resume-actions">
        <text class="resume-btn" data-id="{{item.id}}" bindtap="goPreviewResume">查看</text>
      </view>
    </view>
    <view class="create-resume-card" bindtap="goCreateResume">
      <view class="create-resume-icon">+</view>
      <view class="create-resume-texts">
        <text class="create-resume-title">创建新简历</text>
        <text class="create-resume-desc">完善个人信息，获得更多机会</text>
      </view>
      <text class="create-resume-arrow">›</text>
    </view>

    <!-- 我的服务 -->
    <view class="section-header">
      <text class="section-title">我的服务</text>
    </view>
    <view class="menu-grid">
      <view wx:for="{{menus}}" wx:key="title" class="menu-item" bindtap="goPage" data-url="{{item.url}}">
        <view class="menu-icon" style="background: {{item.color}}15;">
          <text class="menu-icon-text" style="color: {{item.color}};">{{item.icon}}</text>
        </view>
        <text class="menu-item-title">{{item.title}}</text>
        <text class="menu-item-desc">{{item.desc}}</text>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-btn" bindtap="handleLogout">退出登录</view>
  </block>
</view>

<custom-tab-bar />
