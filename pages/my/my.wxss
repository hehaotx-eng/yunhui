.my-page {
  min-height: 100vh;
  background: var(--c-bg, #f6f7f9);
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
}

/* ── Top Nav ── */
.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255,255,255,.75);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
  border-bottom: 1rpx solid rgba(0,0,0,.03);
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text, #1a1a2e);
}

/* ── Not Logged In ── */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 40rpx 60rpx;
}

.login-avatar-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1a1a2e, #2d2d44);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(26,26,46,.15);
}

.login-avatar-text {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.login-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.login-desc {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 36rpx;
}

.login-btn {
  width: 320rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #1a1a2e, #2d2d44);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 44rpx;
  margin-bottom: 48rpx;
}

.login-features {
  display: flex;
  gap: 40rpx;
}

.login-feature {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.lf-icon {
  font-size: 40rpx;
}

.lf-text {
  font-size: 22rpx;
  color: #9ca3af;
}

/* ── Profile Section ── */
.page-content {
  padding-left: 0;
  padding-right: 0;
}

.profile-section {
  padding: 0 20rpx;
}

.profile-card {
  background: var(--c-card, #fff);
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(15,23,42,.04);
}

.profile-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: block;
}

.profile-avatar-fallback {
  background: linear-gradient(135deg, var(--c-accent, #ff5c39), #ff7a5c);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.avatar-edit-badge {
  position: absolute;
  bottom: -2rpx;
  right: -2rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: var(--c-card, #fff);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,.1);
}

.avatar-edit-icon {
  font-size: 18rpx;
  line-height: 1;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.profile-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--c-text, #1a1a2e);
}

.profile-edit-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  background: var(--c-accent-light, rgba(255,92,57,.08));
}

.profile-edit-icon {
  font-size: 20rpx;
  color: var(--c-accent, #ff5c39);
}

.profile-edit-text {
  font-size: 20rpx;
  color: var(--c-accent, #ff5c39);
  font-weight: 500;
}

.profile-phone {
  font-size: 24rpx;
  color: var(--c-text-3, #9ca3af);
  display: block;
  margin-top: 6rpx;
}

.profile-tag {
  display: inline-block;
  margin-top: 10rpx;
  padding: 4rpx 16rpx;
  background: var(--c-bg, #f3f4f6);
  border-radius: 20rpx;
  font-size: 20rpx;
  color: var(--c-text-2, #6b7280);
}

/* ── VIP Identity Card ── */
.vip-identity-card {
  margin: 16rpx 20rpx 0;
  position: relative;
  background: linear-gradient(135deg, #1a1a2e 0%, #2d2d44 50%, #3d3d5c 100%);
  border-radius: 24rpx;
  overflow: hidden;
  padding: 28rpx;
}

.vip-identity-glow {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255,215,0,.25) 0%, transparent 70%);
}

.vip-identity-content {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.vip-identity-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.vip-identity-crown {
  font-size: 48rpx;
}

.vip-identity-info {
  display: flex;
  flex-direction: column;
}

.vip-identity-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffd700;
}

.vip-identity-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,.6);
  margin-top: 4rpx;
}

.vip-identity-action {
  padding: 10rpx 24rpx;
  background: rgba(255,215,0,.15);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255,215,0,.3);
}

.vip-identity-action-text {
  font-size: 22rpx;
  color: #ffd700;
  font-weight: 600;
}

/* ── VIP Guide Card ── */
.vip-guide-card {
  margin: 16rpx 20rpx 0;
  background: linear-gradient(135deg, #fff7ed 0%, #fef3c7 100%);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  border: 1rpx solid rgba(245,158,11,.15);
}

.vip-guide-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.vip-guide-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.vip-guide-icon {
  font-size: 40rpx;
}

.vip-guide-info {
  display: flex;
  flex-direction: column;
}

.vip-guide-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #92400e;
}

.vip-guide-desc {
  font-size: 22rpx;
  color: #b45309;
  margin-top: 4rpx;
}

.vip-guide-action {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #f59e0b, #d97706);
  border-radius: 20rpx;
}

.vip-guide-action-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

.stats-row {
  display: flex;
  margin: 16rpx 20rpx 0;
  background: var(--c-card, #fff);
  border-radius: 20rpx;
  padding: 24rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-num {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--c-accent, #ff5c39);
  display: block;
  line-height: 1.2;
}

.stats-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--c-text-3, #9ca3af);
  display: block;
}

.stats-divider {
  width: 1rpx;
  background: var(--c-border, #f0f0f0);
  margin: 4rpx 0;
}

/* ── Section ── */
.section-header {
  padding: 32rpx 20rpx 14rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--c-text-2, #6b7280);
  letter-spacing: 1rpx;
}

.section-body {
  padding: 0 20rpx;
}

/* ── Resume Card ── */
.resume-card {
  background: var(--c-card, #fff);
  border-radius: 18rpx;
  padding: 22rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}

.resume-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: var(--c-accent-light, rgba(255,92,57,.08));
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.resume-icon-text {
  font-size: 24rpx;
}

.resume-info {
  flex: 1;
  min-width: 0;
}

.resume-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text, #1a1a2e);
  display: block;
}

.resume-time {
  font-size: 22rpx;
  color: var(--c-text-3, #9ca3af);
  display: block;
  margin-top: 4rpx;
}

.resume-arrow {
  font-size: 32rpx;
  color: var(--c-text-3, #d1d5db);
  flex-shrink: 0;
}

/* ── Create Resume ── */
.create-resume-card {
  background: var(--c-card, #fff);
  border-radius: 18rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 2rpx dashed var(--c-border, #e5e7eb);
}

.create-resume-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, var(--c-accent, #ff5c39), #ff7a5c);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #fff;
  font-weight: 300;
  flex-shrink: 0;
}

.create-resume-texts {
  flex: 1;
  min-width: 0;
}

.create-resume-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text, #1a1a2e);
  display: block;
}

.create-resume-desc {
  font-size: 22rpx;
  color: var(--c-text-3, #9ca3af);
  display: block;
  margin-top: 4rpx;
}

/* ── Menu List ── */
.menu-list {
  background: var(--c-card, #fff);
  border-radius: 18rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 24rpx;
  border-bottom: 1rpx solid var(--c-border, #f3f4f6);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon-text {
  font-size: 26rpx;
  font-weight: 700;
}

.menu-info {
  flex: 1;
  min-width: 0;
}

.menu-item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text, #1a1a2e);
  display: block;
}

.menu-item-desc {
  font-size: 22rpx;
  color: var(--c-text-3, #9ca3af);
  display: block;
  margin-top: 4rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--c-text-3, #d1d5db);
  flex-shrink: 0;
}

/* ── Logout ── */
.logout-btn {
  margin: 40rpx 20rpx;
  height: 88rpx;
  background: var(--c-card, #fff);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-danger, #ef4444);
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}


