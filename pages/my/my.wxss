page{
  background:#f6f7f9;
}
.user-card{
  margin:24rpx;
  margin-top: 100px;
  background:#fff;
  border-radius:28rpx;
  padding:50rpx 32rpx;
  text-align:center;
  box-shadow:
  0 8rpx 24rpx rgba(15,23,42,.03);
}

.avatar{
  width:120rpx;
  height:120rpx;
  margin:auto;

  border-radius:32rpx;

  background:#111827;

  color:#fff;

  display:flex;
  align-items:center;
  justify-content:center;

  font-size:44rpx;
  font-weight:700;
}

.user-name{
  margin-top:24rpx;

  font-size:36rpx;
  font-weight:700;

  color:#111827;
}

.user-role{
  margin-top:10rpx;

  font-size:24rpx;

  color:#9ca3af;
}
.data-card{
  margin:0 24rpx 24rpx;

  background:#fff;

  border-radius:24rpx;

  display:flex;

  padding:28rpx 0;

  box-shadow:
  0 8rpx 24rpx rgba(15,23,42,.03);
}

.data-item{
  flex:1;
  text-align:center;
}

.data-num{
  font-size:40rpx;
  font-weight:700;

  color:#ff5c39;
}

.data-label{
  margin-top:10rpx;

  font-size:24rpx;

  color:#9ca3af;
}
.group-title{
  margin:30rpx 24rpx 16rpx;

  font-size:26rpx;
  font-weight:600;

  color:#6b7280;
}
.menu-group{
  margin:0 24rpx;

  background:#fff;

  border-radius:24rpx;

  overflow:hidden;

  box-shadow:
  0 8rpx 24rpx rgba(15,23,42,.03);
}

.menu-item{
  height:110rpx;

  padding:0 28rpx;

  display:flex;
  align-items:center;
  justify-content:space-between;

  border-bottom:1rpx solid #f3f4f6;
}

.menu-item:last-child{
  border:none;
}

.menu-title{
  font-size:30rpx;

  color:#111827;
}

.menu-desc{
  margin-top:6rpx;

  font-size:22rpx;

  color:#9ca3af;
}

.menu-arrow{
  font-size:34rpx;

  color:#d1d5db;
}
.logout-card{
  margin:24rpx;

  height:96rpx;

  background:#fff;

  border-radius:24rpx;

  display:flex;
  align-items:center;
  justify-content:center;

  color:#ef4444;

  font-size:30rpx;
  font-weight:600;

  box-shadow:
  0 8rpx 24rpx rgba(15,23,42,.03);
}