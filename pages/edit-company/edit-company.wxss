@import '../../styles/tokens.wxss';

.logo-field {
  display: flex;
  flex-direction: column;
}

.logo-uploader {
  display: flex;
  align-items: center;
}

.logo-preview {
  width: 140rpx;
  height: 140rpx;
  border-radius: 20rpx;
  object-fit: cover;
}

.logo-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 20rpx;
  background: var(--c-bg);
  border: 2rpx dashed var(--c-border);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.logo-plus {
  font-size: 40rpx;
  color: var(--c-text-3);
  line-height: 1;
}

.logo-hint {
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-top: 4rpx;
}

.page {
  background: var(--c-bg);
  min-height: 100vh;
  padding: var(--sp-24);
}

.form-card {
  background: var(--c-card);
  border-radius: var(--card-radius);
  padding: 0 var(--sp-24);
  box-shadow: var(--card-shadow);
}
.form-field {
  padding: var(--sp-24) 0;
  border-bottom: 1rpx solid var(--c-border);
}
.form-field:last-child {
  border-bottom: none;
}
.form-label {
  display: block;
  font-size: var(--fs-xs);
  color: var(--c-text-2);
  font-weight: var(--fw-medium);
  margin-bottom: var(--sp-10);
}
.required {
  color: var(--c-accent);
}
.form-input {
  width: 100%;
  font-size: var(--fs-md);
  color: var(--c-text);
  height: 72rpx;
  box-sizing: border-box;
}
.form-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: var(--fs-md);
  color: var(--c-text);
  line-height: 1.6;
  box-sizing: border-box;
}
.char-count {
  display: block;
  text-align: right;
  font-size: var(--fs-xxs);
  color: var(--c-text-3);
  margin-top: var(--sp-6);
}

.save-btn {
  margin-top: 40rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--c-accent), #ff7a5c);
  color: #fff;
  font-size: var(--fs-md);
  font-weight: var(--fw-semibold);
  border-radius: var(--card-radius);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255,92,57,.2);
}
.save-btn.disabled {
  opacity: .6;
}
