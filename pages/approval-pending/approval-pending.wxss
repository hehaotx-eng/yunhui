page { background: #f6f7f9; overflow: hidden; height: 100%; }
.page { height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 0 48rpx; box-sizing: border-box; }

.content { display: flex; flex-direction: column; align-items: center; text-align: center; }
.icon { font-size: 100rpx; margin-bottom: 32rpx; }
.title { font-size: 40rpx; font-weight: 700; color: #111827; margin-bottom: 16rpx; }
.desc { font-size: 28rpx; color: #6b7280; line-height: 1.6; margin-bottom: 40rpx; }
.info { display: flex; align-items: center; gap: 12rpx; padding: 16rpx 32rpx; background: #fff; border-radius: 16rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.04); }
.info-label { font-size: 26rpx; color: #9ca3af; }
.info-value { font-size: 26rpx; font-weight: 600; }
.status-pending { color: #f59e0b; }

.footer { position: fixed; bottom: calc(40rpx + env(safe-area-inset-bottom)); left: 48rpx; right: 48rpx; display: flex; flex-direction: column; gap: 16rpx; }
.btn { height: 96rpx; border-radius: 24rpx; background: #111827; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 600; }
.btn-text { background: none; color: #6b7280; font-weight: 400; }
