/* =========================
   AI招聘推荐页 - 电光紫蓝
========================= */

.ai-page{
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  color: #111827;
  padding-bottom: 160rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

/* =======================
   顶部导航（玻璃态设计）
======================= */
.top-nav{
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(99,102,241,0.06);
}

.nav-content{
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.nav-ai-badge{
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  display:flex;
  align-items:center;
  justify-content:center;
  margin-right: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(99,102,241,0.3);
}

.badge-text{
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}

.nav-title{
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  letter-spacing: 2rpx;
}

/* =======================
   AI状态卡（核心区域）
======================= */
.ai-header{
  padding: 24rpx;
  margin-top: 88rpx;
}

.header-card{
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx;
  border: 1rpx solid rgba(99,102,241,0.06);
  box-shadow: 0 12rpx 40rpx rgba(99,102,241,0.10);
  position: relative;
  overflow: hidden;
}

.header-card::before{
  content: "";
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(99,102,241,0.08) 0%, transparent 70%);
}

.header-glow{
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #6366f1, #8b5cf6, #6366f1);
  background-size: 200% 100%;
  animation: shimmer 3s linear infinite;
}

@keyframes shimmer{
  0%{ background-position: -200% 0; }
  100%{ background-position: 200% 0; }
}

.header-content{
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.header-left{
  flex: 1;
}

.header-title{
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.header-desc{
  font-size: 26rpx;
  color: #64748b;
  margin-top: 12rpx;
  line-height: 1.5;
}

/* 刷新按钮 */
.header-action{
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  background: rgba(99,102,241,0.06);
  border-radius: 16rpx;
  transition: all .2s;
}

.header-action:active{
  background: rgba(99,102,241,0.12);
  transform: scale(0.96);
}

.refresh-icon{
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #6366f1;
  border-radius: 50%;
  position: relative;
}

.refresh-icon::before{
  content: '';
  position: absolute;
  top: -2rpx;
  left: 50%;
  width: 12rpx;
  height: 12rpx;
  background: #6366f1;
  clip-path: polygon(0 0, 100% 0, 50% 100%);
  transform: translateX(-50%) rotate(45deg);
}

.refresh-text{
  font-size: 26rpx;
  color: #6366f1;
  font-weight: 500;
}

.header-action.loading{
  background: rgba(99,102,241,0.06);
}

.header-action.loading .refresh-text{
  color: #94a3b8;
}

.loading-spinner{
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #e2e8f0;
  border-top-color: #6366f1;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin{
  to{ transform: rotate(360deg); }
}

/* =======================
   筛选标签
======================= */
.filter-tags{
  margin-top: 28rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-tag{
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  background: #eef2ff;
  color: #64748b;
  border: 1rpx solid transparent;
  transition: all .2s;
}

.filter-tag:active{
  transform: scale(0.96);
}

.filter-active{
  background: rgba(99,102,241,0.08);
  color: #6366f1;
  border: 1rpx solid rgba(99,102,241,0.2);
  font-weight: 600;
}

/* =======================
   推荐列表
======================= */
.recommend-list{
  padding: 0 24rpx;
}

/* =======================
   推荐卡片
======================= */
ai-recommend-card{
  display: block;
  margin-bottom: 20rpx;
}

/* =======================
   职位信息
======================= */
.job-title{
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.company{
  font-size: 26rpx;
  color: #64748b;
  margin-top: 8rpx;
}

.salary{
  font-size: 30rpx;
  color: #f97316;
  font-weight: 700;
  margin-top: 12rpx;
}

.tags{
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.tag{
  font-size: 24rpx;
  padding: 8rpx 18rpx;
  border-radius: 8rpx;
  background: #f8fafc;
  color: #64748b;
}

/* =======================
   AI推荐理由
======================= */
.ai-reason{
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #eef2ff 0%, #f5f3ff 100%);
  border-left: 4rpx solid #6366f1;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.6;
}

/* =======================
   骨架屏
======================= */
.skeleton-card{
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(99,102,241,0.06);
}

.skeleton-row{
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.skeleton-circle{
  width: 72rpx;
  height: 72rpx;
  background: #e2e8f0;
  border-radius: 16rpx;
}

.skeleton-col{
  flex: 1;
}

.skeleton-line{
  height: 20rpx;
  background: #e2e8f0;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

.skeleton-line:first-child{
  margin-top: 0;
}

.skeleton-line-lg{ width: 70%; }
.skeleton-line-sm{ width: 45%; }

.skeleton-block{
  height: 120rpx;
  background: #eef2ff;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.skeleton-tags{
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.skeleton-tag{
  width: 80rpx;
  height: 36rpx;
  background: #e2e8f0;
  border-radius: 8rpx;
}

@keyframes pulse{
  0%, 100%{ opacity: 0.5; }
  50%{ opacity: 1; }
}

.skeleton-pulse{
  animation: pulse 1.5s ease-in-out infinite;
}

/* =======================
   AI 助手悬浮球
======================= */
.fab-button {
  position: fixed;
  right: 32rpx;
  bottom: 200rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  box-shadow: 0 10rpx 32rpx rgba(99,102,241,0.4);
  z-index: 50;
  transition: all .2s ease;
}

.fab-button:active {
  transform: scale(0.9);
  box-shadow: 0 6rpx 20rpx rgba(99,102,241,0.5);
}

.fab-icon {
  width: 52rpx;
  height: 52rpx;
  position: relative;
}

.fab-icon::before{
  content: '';
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  right: 4rpx;
  height: 22rpx;
  border: 3rpx solid #fff;
  border-radius: 10rpx 10rpx 0 0;
}

.fab-icon::after{
  content: '';
  position: absolute;
  bottom: 8rpx;
  left: 8rpx;
  width: 16rpx;
  height: 16rpx;
  border: 3rpx solid #fff;
  border-radius: 50%;
}

.fab-icon::before, .fab-icon::after{
  box-sizing: border-box;
}

.fab-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}

/* =======================
   空状态提示
======================= */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
}

.empty-icon-wrap {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #eef2ff, #e2e8f0);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(99,102,241,0.10);
}

.empty-icon {
  font-size: 80rpx;
  color: #818cf8;
}

.empty-icon.icon-resume{
  font-size: 0;
  width: 72rpx;
  height: 90rpx;
  position: relative;
}

.empty-icon.icon-resume::before{
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border: 4rpx solid #818cf8;
  border-radius: 8rpx;
}

.empty-icon.icon-resume::after{
  content: '';
  position: absolute;
  top: 18rpx;
  left: 14rpx;
  right: 14rpx;
  height: 4rpx;
  background: #818cf8;
  box-shadow: 0 14rpx 0 #818cf8, 0 28rpx 0 #818cf8, 0 42rpx 0 #818cf8;
}

.empty-icon.icon-ph{
  font-size: 0;
  width: 72rpx;
  height: 72rpx;
  position: relative;
}

.empty-icon.icon-ph::before{
  content: '';
  position: absolute;
  top: 12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid #818cf8;
  border-radius: 50%;
}

.empty-icon.icon-ph::after{
  content: '';
  position: absolute;
  top: 46rpx;
  left: 8rpx;
  right: 8rpx;
  height: 16rpx;
  border: 4rpx solid #818cf8;
  border-radius: 0 0 16rpx 16rpx;
  border-top: none;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 20rpx;
}

.empty-subtitle {
  font-size: 28rpx;
  color: #94a3b8;
  text-align: center;
  margin-bottom: 56rpx;
  line-height: 1.6;
}

.empty-btn {
  padding: 28rpx 88rpx;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  border-radius: 56rpx;
  box-shadow: 0 10rpx 32rpx rgba(99,102,241,0.35);
  transition: all .2s;
}

.empty-btn:active {
  transform: scale(0.95);
  box-shadow: 0 6rpx 20rpx rgba(99,102,241,0.4);
}

.empty-btn text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}
