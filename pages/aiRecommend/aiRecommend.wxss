/* =========================
   AI招聘推荐页 - 高级付费版UI
========================= */

.ai-page{
  min-height: 100vh;
  background: #f7f8fb;
  color: #1a1a1a;
  padding-bottom: 160rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC";
}

/* =======================
   顶部导航（高级白 + 极轻阴影）
======================= */
.top-nav{
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(0,0,0,0.04);
}

.nav-content{
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.nav-ai-badge{
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg,#2f6bff,#5b8cff);
  display:flex;
  align-items:center;
  justify-content:center;
  margin-right: 14rpx;
  box-shadow: 0 6rpx 20rpx rgba(47,107,255,0.25);
}

.badge-text{
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.nav-title{
  font-size: 34rpx;
  font-weight: 700;
  color: #111;
  letter-spacing: 1rpx;
}

/* =======================
   AI状态卡（核心“专业感”）
======================= */
.ai-header{
  padding: 24rpx;
  margin-top: 88rpx;
}

.header-card{
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  border: 1px solid rgba(0,0,0,0.06);
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.04);
  position: relative;
}

/* AI角标（关键：增强“专业系统感”） */
.header-card::before{
  content: "AI SMART MATCH";
  position: absolute;
  top: 0;
  right: 0;
  background: linear-gradient(135deg,#2f6bff,#6a8dff);
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 0 20rpx 0 16rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.header-title{
  font-size: 34rpx;
  font-weight: 700;
  color: #111;
}

.header-desc{
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
  line-height: 1.4;
}

/* 刷新按钮（克制但高级） */
.header-action{
  position: absolute;
  right: 28rpx;
  top: 28rpx;
  font-size: 24rpx;
  color: #2f6bff;
  font-weight: 500;
}

/* =======================
   筛选标签（产品级设计）
======================= */
.filter-tags{
  margin-top: 22rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.filter-tag{
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: #f4f6f9;
  color: #555;
  border: 1px solid transparent;
  transition: all .2s;
}

.filter-active{
  background: rgba(47,107,255,0.08);
  color: #2f6bff;
  border: 1px solid rgba(47,107,255,0.2);
  font-weight: 500;
}

/* =======================
   推荐列表（信息密度优化）
======================= */
.recommend-list{
  padding: 24rpx;
}

/* =======================
   AI推荐卡片（重点：付费感来源）
======================= */
ai-recommend-card{
  display: block;
  background: #fff;
  border-radius: 18rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1px solid rgba(0,0,0,0.06);
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.04);
  transition: all .2s ease;
}

ai-recommend-card:active{
  transform: scale(0.985);
}

/* =======================
   职位标题（核心权重）
======================= */
.job-title{
  font-size: 32rpx;
  font-weight: 700;
  color: #111;
}

/* 公司信息 */
.company{
  font-size: 24rpx;
  color: #666;
  margin-top: 6rpx;
}

/* 薪资（增强吸引力） */
.salary{
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: 700;
  margin-top: 10rpx;
}

/* 标签 */
.tags{
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.tag{
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  background: #f5f7fa;
  color: #666;
}

/* =======================
   AI推荐理由（关键：信任感）
======================= */
.ai-reason{
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  background: #f7faff;
  border-left: 3rpx solid #2f6bff;
  font-size: 22rpx;
  color: #555;
  line-height: 1.5;
}

/* =======================
   骨架屏（专业版）
======================= */
.skeleton-card{
  background: #fff;
  border-radius: 18rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1px solid rgba(0,0,0,0.05);
}

.skeleton-line{
  height: 18rpx;
  background: #eee;
  border-radius: 6rpx;
  margin-top: 12rpx;
}

.skeleton-line-lg{ width: 65%; }
.skeleton-line-sm{ width: 45%; }

@keyframes pulse{
  0%{opacity: .6;}
  50%{opacity: 1;}
  100%{opacity: .6;}
}

.skeleton-pulse{
  animation: pulse 1.2s infinite;
}

/* =======================
   底部安全区
======================= */
.custom-tabbar-placeholder{
  height: 140rpx;
}

/* =======================
   AI 助手悬浮球
======================= */
.fab-button {
  position: fixed;
  right: 32rpx;
  bottom: 200rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6d5efc, #8b7cf8);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(109,94,252,.4);
  z-index: 50;
  transition: transform .2s ease;
}

.fab-button:active {
  transform: scale(.9);
}

.fab-icon {
  font-size: 36rpx;
}

.fab-text {
  font-size: 18rpx;
  color: #fff;
  font-weight: 600;
}

/* =======================
   空状态提示（登录/简历）
======================= */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f5f7fa, #e8ecf0);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.empty-icon {
  font-size: 72rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.empty-subtitle {
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.6;
}

.empty-btn {
  padding: 24rpx 80rpx;
  background: linear-gradient(135deg, #6d5efc, #8b7cf8);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(109,94,252,.3);
}

.empty-btn:active {
  transform: scale(.95);
}

.empty-btn text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}