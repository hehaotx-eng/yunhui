.ai-page {
  min-height: 100vh;
  background: var(--c-bg, #f6f7f9);
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255,255,255,.92);
  backdrop-filter: blur(20rpx);
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.nav-ai-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  background: linear-gradient(135deg, #6d5efc, #8b7cf8);
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-text {
  font-size: 20rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text, #1a1a2e);
}

.ai-header { padding: 20rpx 24rpx; }

.header-card {
  position: relative;
  background: linear-gradient(135deg, #1a1a2e 0%, #2d2d44 50%, #3d3d5c 100%);
  border-radius: 28rpx;
  overflow: hidden;
  padding: 28rpx;
}

.header-glow {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(109,94,252,.3) 0%, transparent 70%);
}

.header-content {
  position: relative;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.header-left { flex: 1; }
.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}
.header-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,.6);
  display: block;
  margin-top: 6rpx;
}

.header-action {
  padding: 12rpx 24rpx;
  background: rgba(255,255,255,.12);
  border-radius: 20rpx;
}

.refresh-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.filter-tags {
  position: relative;
  display: flex;
  gap: 10rpx;
}

.filter-tag {
  padding: 10rpx 22rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,.6);
  background: rgba(255,255,255,.08);
  border: 1rpx solid rgba(255,255,255,.1);
}

.filter-active {
  background: rgba(255,255,255,.2);
  color: #fff;
  border-color: rgba(255,255,255,.3);
  font-weight: 600;
}

.recommend-list { padding: 0 24rpx; }

.skeleton-wrap { padding: 24rpx; }
.skeleton-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}
.skeleton-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.skeleton-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.skeleton-col { flex: 1; }
.skeleton-line { height: 20rpx; margin-bottom: 10rpx; border-radius: 6rpx; }
.skeleton-line-lg { width: 70%; }
.skeleton-line-sm { width: 45%; }
.skeleton-block {
  width: 100%;
  height: 100rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}
.skeleton-tags { display: flex; gap: 10rpx; }
.skeleton-tag {
  width: 120rpx;
  height: 44rpx;
  border-radius: 8rpx;
}

page { padding-bottom: 60px; }
