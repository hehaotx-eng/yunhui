page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.header {
  background: linear-gradient(135deg, #00a2ff 0%, #0080ff 100%);
  padding: 60rpx 32rpx 40rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 24rpx;
}

.tab-item {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #00a2ff;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #00a2ff;
  border-radius: 3rpx;
}

.app-list {
  padding: 24rpx;
}

.app-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.app-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.job-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.app-status {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.status-pending {
  background: #fffbe6;
  color: #faad14;
}

.status-accepted {
  background: #f0f9eb;
  color: #07c160;
}

.status-rejected {
  background: #fff2f0;
  color: #ff4d4f;
}

.company-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.company-logo {
  width: 64rpx;
  height: 64rpx;
  border-radius: 10rpx;
  background: #f5f5f5;
}

.company-name {
  font-size: 26rpx;
  color: #666;
}

.app-time {
  font-size: 24rpx;
  color: #999;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}