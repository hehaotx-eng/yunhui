/* pages/delivery/delivery.wxss */

/* ===== 页面基础 ===== */
.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

/* ===== Tab切换 ===== */
.tabs-scroll {
  display: flex;
  background: #ffffff;
  padding: 0 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab {
  position: relative;
  padding: 28rpx 24rpx 24rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
  flex-shrink: 0;
  border-bottom: 4rpx solid transparent;
}

.tab.active {
  color: #4a90d9;
  font-weight: 600;
  border-bottom-color: #4a90d9;
}

.tab-badge {
  position: absolute;
  top: 16rpx;
  right: 4rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: translateX(50%);
}

/* ===== 卡片列表 ===== */
.list {
  padding: 24rpx 24rpx 0;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.card:active {
  transform: scale(0.98);
}

/* ===== 卡片头部 ===== */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f7fa;
}

.header-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.company-logo {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e8edf5, #d5dde8);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
  margin-right: 20rpx;
}
.company-logo image {
  width: 100%;
  height: 100%;
}
.company-logo text {
  font-size: 32rpx;
  font-weight: 600;
  color: #4a6a8a;
}

.job-info {
  flex: 1;
  min-width: 0;
}
.job-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.company-name {
  display: block;
  font-size: 24rpx;
  color: #8c8c8c;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header-right {
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ===== 全局状态徽章 ===== */
.status-badge {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  white-space: nowrap;
}
.status-badge.pending {
  background: #f0f0f0;
  color: #8c8c8c;
}
.status-badge.viewed {
  background: #e6f0ff;
  color: #4a90d9;
}
.status-badge.accepted {
  background: #e6f7e6;
  color: #52c41a;
}
.status-badge.rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

/* ===== 时间轴 ===== */
.timeline {
  padding: 4rpx 0 8rpx;
}

.timeline-item {
  display: flex;
  padding: 12rpx 0;
  position: relative;
}

.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 48rpx;
  flex-shrink: 0;
  position: relative;
}

.node-wrapper {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.node {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  border: 4rpx solid #d9d9d9;
  background: #ffffff;
  color: #bfbfbf;
  position: relative;
  z-index: 2;
}

/* 节点状态 */
.node-done {
  border-color: #52c41a;
  background: #f6ffed;
  color: #52c41a;
}
.node-active {
  border-color: #4a90d9;
  background: #e6f0ff;
  color: #4a90d9;
  transform: scale(1.1);
  box-shadow: 0 0 0 8rpx rgba(74, 144, 217, 0.15);
}
.node-pass {
  border-color: #52c41a;
  background: #52c41a;
  color: #ffffff;
  transform: scale(1.05);
}
.node-fail {
  border-color: #ff4d4f;
  background: #ff4d4f;
  color: #ffffff;
  transform: scale(1.05);
}

.node-icon {
  font-size: 24rpx;
  line-height: 1;
}

/* 脉动动画 */
.node-pulse {
  position: absolute;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(74, 144, 217, 0.3);
  animation: pulse 1.5s ease-in-out infinite;
  z-index: 1;
}
@keyframes pulse {
  0% { transform: scale(0.8); opacity: 0.8; }
  50% { transform: scale(1.4); opacity: 0; }
  100% { transform: scale(1.8); opacity: 0; }
}

/* 连接线 */
.connector {
  width: 4rpx;
  height: 32rpx;
  background: #e8e8e8;
  margin: 2rpx 0;
  transition: all 0.4s;
  flex-shrink: 0;
}
.connector-done {
  background: #52c41a;
}

/* ===== 时间轴右侧内容 ===== */
.timeline-right {
  flex: 1;
  padding-left: 20rpx;
  min-width: 0;
}

.timeline-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.timeline-title {
  font-size: 28rpx;
  color: #4a4a4a;
  font-weight: 500;
  transition: all 0.3s;
}
.title-active {
  color: #4a90d9;
  font-weight: 600;
}
.title-pass {
  color: #52c41a;
}
.title-fail {
  color: #ff4d4f;
}

.mini-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
  background: #f5f5f5;
  color: #8c8c8c;
  flex-shrink: 0;
}
.tag-doing {
  background: #e6f0ff;
  color: #4a90d9;
}
.tag-pass {
  background: #e6f7e6;
  color: #52c41a;
}
.tag-fail {
  background: #fff1f0;
  color: #ff4d4f;
}
.tag-done {
  background: #f0f0f0;
  color: #8c8c8c;
}

.timeline-hint {
  font-size: 24rpx;
  color: #8c8c8c;
  line-height: 1.5;
  display: block;
  margin-top: 2rpx;
}

/* ===== 卡片底部 ===== */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  margin-top: 16rpx;
  border-top: 2rpx solid #f5f7fa;
  font-size: 24rpx;
  color: #8c8c8c;
}

.footer-right {
  display: flex;
  gap: 16rpx;
}
.footer-salary {
  color: #fa8c16;
  font-weight: 500;
}

/* ===== 空状态 ===== */
.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  background: #ffffff;
  border-radius: 20rpx;
}
.empty-icon { font-size: 120rpx; margin-bottom: 32rpx; }
.empty-title { font-size: 32rpx; font-weight: 600; color: #1a1a1a; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: #8c8c8c; margin-bottom: 40rpx; }
.empty-btn {
  padding: 20rpx 80rpx;
  background: linear-gradient(135deg, #4a90d9, #6aa8f0);
  color: #fff;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.empty-btn:active { transform: scale(0.95); opacity: 0.8; }

/* ===== 加载状态 ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e8e8e8;
  border-top-color: #4a90d9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
.loading-text { font-size: 26rpx; color: #8c8c8c; }