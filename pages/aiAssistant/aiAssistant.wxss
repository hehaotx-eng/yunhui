.assistant-page {
  min-height: 100vh;
  background: var(--c-bg, #f6f7f9);
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255,255,255,.95);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid var(--c-border, #f0f0f0);
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: var(--c-text, #1a1a2e);
}

.nav-title-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.ai-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  background: linear-gradient(135deg, var(--c-ai, #6d5efc), #8b7cf8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 800;
  color: #fff;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text, #1a1a2e);
}

/* 聊天区域 */
.chat-area {
  flex: 1;
  height: 100vh;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

/* 消息样式 */
.message {
  display: flex;
  margin-bottom: 24rpx;
  gap: 12rpx;
}

.message.user {
  justify-content: flex-end;
}

.message.assistant {
  justify-content: flex-start;
}

.msg-avatar {
  flex-shrink: 0;
}

.avatar-ai {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, var(--c-ai, #6d5efc), #8b7cf8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
  color: #fff;
}

.msg-content {
  max-width: 80%;
}

.msg-bubble {
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: var(--c-card, #fff);
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.06);
}

.message.user .msg-bubble {
  background: linear-gradient(135deg, var(--c-ai, #6d5efc), #8b7cf8);
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--c-text, #1a1a2e);
  white-space: pre-wrap;
}

.message.user .msg-text {
  color: #fff;
}

/* 分析卡片 */
.analysis-card {
  background: var(--c-card, #fff);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.06);
}

.analysis-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--c-border, #f0f0f0);
}

.analysis-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--c-text, #1a1a2e);
}

.confidence-badge {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background: var(--c-ai-light, rgba(109,94,252,.06));
  color: var(--c-ai, #6d5efc);
  border-radius: 20rpx;
}

.analysis-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.analysis-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.analysis-item .label {
  font-size: 24rpx;
  color: var(--c-text-3, #9ca3af);
  width: 120rpx;
  flex-shrink: 0;
}

.analysis-item .value {
  font-size: 24rpx;
  color: var(--c-text, #1a1a2e);
  font-weight: 500;
}

.analysis-reason {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--c-border, #f0f0f0);
}

.reason-icon {
  font-size: 24rpx;
  flex-shrink: 0;
}

.reason-text {
  font-size: 24rpx;
  color: var(--c-text-2, #6b7280);
  line-height: 1.6;
}

/* 职位列表 */
.job-list {
  margin-top: 16rpx;
}

.job-list-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text, #1a1a2e);
  margin-bottom: 12rpx;
  display: block;
}

.job-card {
  display: flex;
  align-items: center;
  background: var(--c-card, #fff);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(15,23,42,.04);
}

.job-card:active {
  background: var(--c-bg, #f6f7f9);
}

.job-main {
  flex: 1;
  min-width: 0;
}

.job-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.job-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text, #1a1a2e);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-salary {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--c-accent, #ff5c39);
  flex-shrink: 0;
}

.job-company {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.company-name {
  font-size: 24rpx;
  color: var(--c-text-2, #6b7280);
}

.job-location {
  font-size: 22rpx;
  color: var(--c-text-3, #9ca3af);
}

.job-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.job-match {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.match-score {
  font-size: 22rpx;
  color: var(--c-ai, #6d5efc);
  font-weight: 600;
}

.match-reason {
  font-size: 22rpx;
  color: var(--c-text-2, #6b7280);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: var(--c-bg, #f6f7f9);
  color: var(--c-text-2, #6b7280);
  border-radius: 8rpx;
}

.job-arrow {
  font-size: 32rpx;
  color: var(--c-text-3, #d1d5db);
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 无结果 */
.no-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.no-result-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.no-result-text {
  font-size: 28rpx;
  color: var(--c-text, #1a1a2e);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.no-result-tip {
  font-size: 24rpx;
  color: var(--c-text-3, #9ca3af);
}

/* 加载动画 */
.loading-card {
  background: var(--c-card, #fff);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.06);
}

.loading-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--c-border, #f0f0f0);
}

.loading-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid var(--c-border, #e5e7eb);
  border-top-color: var(--c-ai, #6d5efc);
  border-radius: 50%;
  animation: spin .8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-ai, #6d5efc);
}

.loading-steps {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.loading-step {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.loading-step .step-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: var(--c-success, #22c55e);
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-step .step-text {
  font-size: 24rpx;
  color: var(--c-text-2, #6b7280);
}

.loading-step.running .step-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid var(--c-border, #e5e7eb);
  border-top-color: var(--c-ai, #6d5efc);
  border-radius: 50%;
  animation: spin .8s linear infinite;
}

.loading-step.running .step-text {
  color: var(--c-ai, #6d5efc);
  font-weight: 500;
}

/* 输入区域 */
.input-area {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: var(--c-card, #fff);
  border-top: 1rpx solid var(--c-border, #f0f0f0);
}

.input-wrap {
  flex: 1;
  height: 72rpx;
  background: var(--c-bg, #f6f7f9);
  border-radius: 36rpx;
  padding: 0 24rpx;
}

.input {
  width: 100%;
  height: 100%;
  font-size: 28rpx;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  background: #e0e6ed;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.send-btn.active {
  background: linear-gradient(135deg, var(--c-ai, #6d5efc), #8b7cf8);
}
