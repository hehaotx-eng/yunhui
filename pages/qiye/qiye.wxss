page {
  background: #f6f7f9;
}

.page {
  min-height: 100vh;
}

/* ======================
   Header
====================== */

.header {
  padding: 120rpx 24rpx 24rpx;
}

.header-text {
  font-size: 48rpx;
  font-weight: 700;

  color: #111827;
}

/* ======================
   Search
====================== */

.search-bar {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.search-wrapper {
  height: 88rpx;

  background: #fff;

  border-radius: 20rpx;

  display: flex;
  align-items: center;

  padding: 0 24rpx;

  box-shadow:
    0 6rpx 20rpx rgba(15,23,42,.03);
}

.icon-search {
  width: 34rpx;
  height: 34rpx;
}

.search-input {
  flex: 1;

  margin-left: 16rpx;

  font-size: 28rpx;

  color: #111827;
}

/* ======================
   Filter
====================== */

.filter-scroll {
  white-space: nowrap;

  padding: 0 24rpx;

  margin-bottom: 20rpx;
}

.filter-item {
  display: inline-flex;

  align-items: center;
  justify-content: center;

  height: 64rpx;

  padding: 0 24rpx;

  margin-right: 16rpx;

  background: #fff;

  border-radius: 12rpx;

  font-size: 26rpx;

  color: #6b7280;

  box-shadow:
    0 4rpx 12rpx rgba(15,23,42,.03);
}

.filter-item.active {
  background: #111827;
  color: #fff;
}

/* ======================
   Company List
====================== */

.company-list {
  padding: 0 24rpx 40rpx;
}

/* ======================
   Company Card
====================== */

.company-card {
  background: #fff;

  border-radius: 24rpx;

  padding: 24rpx;

  margin-bottom: 20rpx;

  display: flex;
  align-items: flex-start;

  box-shadow:
    0 8rpx 24rpx rgba(15,23,42,.03);
}

/* ======================
   Logo
====================== */

.logo,
.logo-text {
  width: 96rpx;
  height: 96rpx;

  border-radius: 20rpx;

  flex-shrink: 0;
}

.logo {
  background: #f3f4f6;
}

.logo-text {
  background: #f3f4f6;

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 36rpx;
  font-weight: 700;

  color: #111827;
}

/* ======================
   Content
====================== */

.content {
  flex: 1;

  margin-left: 20rpx;

  overflow: hidden;
}

/* 企业名称 */

.name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.name {
  font-size: 32rpx;

  font-weight: 700;

  color: #111827;
}

/* 已认证 */

.verify {
  margin-left: 12rpx;

  padding: 4rpx 10rpx;

  background: #ecfdf3;

  color: #10b981;

  font-size: 20rpx;

  border-radius: 6rpx;
}

/* 行业规模 */

.meta {
  margin-top: 10rpx;

  font-size: 24rpx;

  color: #6b7280;
}

/* 企业介绍 */

.desc {
  margin-top: 12rpx;

  font-size: 24rpx;

  color: #4b5563;

  line-height: 1.7;

  overflow: hidden;

  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 地址 */

.address {
  margin-top: 12rpx;

  font-size: 24rpx;

  color: #9ca3af;
}

/* 箭头 */

.arrow {
  margin-left: 16rpx;

  font-size: 40rpx;

  color: #d1d5db;

  line-height: 96rpx;
}

/* ======================
   Empty
====================== */

.empty-card {
  background: #fff;

  border-radius: 24rpx;

  padding: 120rpx 0;

  text-align: center;

  box-shadow:
    0 8rpx 24rpx rgba(15,23,42,.03);
}

.empty-icon {
  font-size: 90rpx;
}

.empty-text {
  margin-top: 20rpx;

  font-size: 28rpx;

  color: #9ca3af;
}

/* ======================
   Loading
====================== */

.loading {
  text-align: center;

  padding: 40rpx 0;

  font-size: 26rpx;

  color: #9ca3af;
}

/* ======================
   Badge
====================== */

.badge {
  margin-left: 8rpx;
  padding: 2rpx 10rpx;
  background: #ef4444;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  min-width: 32rpx;
  text-align: center;
}

/* ======================
   Audit Actions
====================== */

.audit-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.audit-btn {
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
  min-width: 80rpx;
}

.audit-btn.approve {
  background: #10b981;
  color: #fff;
}

.audit-btn.reject {
  background: #fff;
  color: #ef4444;
  border: 2rpx solid #ef4444;
}