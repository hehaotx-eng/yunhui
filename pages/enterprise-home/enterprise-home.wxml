<wxs src="../../utils/wxs.wxs" module="wxs" />
<view class="page">
  <view class="body">
    <view class="welcome">
      <text class="welcome-greeting">欢迎回来</text>
      <text class="welcome-name">{{companyName}}</text>
    </view>

    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-value">{{stats.jobs}}</text>
        <text class="stat-label">发布职位</text>
      </view>
      <view class="stat-card">
        <text class="stat-value online">{{stats.online}}</text>
        <text class="stat-label">在线中</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{stats.applicants}}</text>
        <text class="stat-label">收到投递</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{stats.candidates}}</text>
        <text class="stat-label">候选人</text>
      </view>
    </view>

    <view class="quick-actions">
      <view class="action-item" bindtap="goPostJob">
        <view class="action-icon add">+</view>
        <text class="action-text">发布职位</text>
      </view>
      <view class="action-item" bindtap="goJobs">
        <view class="action-icon list">≡</view>
        <text class="action-text">我的岗位</text>
      </view>
      <view class="action-item" bindtap="goApplications">
        <view class="action-icon search">◉</view>
        <text class="action-text">投递管理</text>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <text class="section-title">最近投递</text>
      </view>
      <view wx:if="{{recentApps.length === 0}}" class="empty">暂无投递记录</view>
      <view wx:for="{{recentApps}}" wx:key="id" class="app-row">
        <view class="app-avatar">{{wxs.firstChar(item.user_name)}}</view>
        <view class="app-info">
          <text class="app-name">{{item.user_name || '匿名'}}</text>
          <text class="app-job">{{item.job_title || ''}}</text>
        </view>
        <text class="app-status status-{{item.status}}" bindtap="onChangeStatus" data-id="{{item.id}}" data-status="{{item.status}}">{{item.status === 'pending' ? '待处理' : item.status === 'viewed' ? '已查看' : item.status === 'accepted' ? '已通过' : item.status === 'rejected' ? '已拒绝' : item.status}}</text>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <text class="section-title">我的职位</text>
        <text class="section-more" bindtap="goJobs">查看全部</text>
      </view>
      <view wx:if="{{myJobs.length === 0}}" class="empty">暂无职位，去发布一个吧</view>
      <view wx:for="{{myJobs}}" wx:key="id" class="job-card" bindtap="goDetail" data-id="{{item.id}}">
        <view class="job-top">
          <text class="job-title">{{item.title}}</text>
          <text class="job-status status-{{item.status}}">{{item.status === 'online' ? '在线' : item.status === 'offline' ? '已下线' : item.status === 'draft' ? '草稿' : item.status}}</text>
        </view>
        <text class="job-salary">{{item.salary || (item.salary_min && item.salary_max ? item.salary_min + '-' + item.salary_max + '元' : '薪资面议')}}</text>
      </view>
    </view>
  </view>
</view>

<enterprise-tabbar current="home" />
