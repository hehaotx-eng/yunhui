<wxs src="../../utils/wxs.wxs" module="wxs" />

<view class="page">

  <!-- 🧠 1. 顶部信息 -->
  <view class="header">
    <view class="title">欢迎回来</view>
    <view class="sub">{{companyName}}</view>
  </view>

  <!-- 📊 2. 核心数据（最重要） -->
  <view class="metrics">
    <view class="metric">
      <text class="num">{{stats.jobs}}</text>
      <text class="label">职位</text>
    </view>

    <view class="metric">
      <text class="num blue">{{stats.online}}</text>
      <text class="label">在线</text>
    </view>

    <view class="metric">
      <text class="num">{{stats.applicants}}</text>
      <text class="label">投递</text>
    </view>

    <view class="metric">
      <text class="num">{{stats.candidates}}</text>
      <text class="label">候选</text>
    </view>
  </view>

  <!-- ⚡ 3. 操作入口（重点优化） -->
  <view class="actions">

    <view class="action" bindtap="goPostJob">
      <view class="icon add">＋</view>
      <text>发布职位</text>
    </view>

    <view class="action" bindtap="goJobs">
      <view class="icon list">≡</view>
      <text>我的岗位</text>
    </view>

    <view class="action" bindtap="goApplications">
      <view class="icon msg">◎</view>
      <text>投递管理</text>
    </view>

  </view>

  <!-- 4. 内容区 -->
  <view class="section">

    <view class="section-title">最近投递</view>

    <view wx:if="{{recentApps.length === 0}}" class="empty">
      暂无投递记录
    </view>

    <view wx:for="{{recentApps}}" wx:key="id" class="row">

      <view class="avatar">{{wxs.firstChar(item.user_name)}}</view>

      <view class="info">
        <view class="name">{{item.user_name}}</view>
        <view class="sub">{{item.job_title}}</view>
      </view>

      <view class="status status-{{item.status}}">
        {{item.status}}
      </view>

    </view>

  </view>

  <!-- 5. 我的职位 -->
  <view class="section">

    <view class="section-head">
      <text class="section-title">我的职位</text>
      <text class="more" bindtap="goJobs">更多</text>
    </view>

    <view wx:for="{{myJobs}}" wx:key="id" class="job">

      <view class="job-title">{{item.title}}</view>

      <view class="job-bottom">
        <text class="salary">{{item.salary || '薪资面议'}}</text>
        <text class="job-status">{{item.status}}</text>
      </view>

    </view>

  </view>

  <enterprise-tabbar current="home" />

</view>