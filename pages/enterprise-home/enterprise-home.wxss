.page {
  background: #f6f7fb;
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 140rpx;
}

/* ===== header ===== */
.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 28rpx;
  color: #888;
}

.sub {
  font-size: 44rpx;
  font-weight: 700;
  color: #111;
}

/* ===== 📊 核心数据（重点：像大屏） ===== */
.metrics {
  display: flex;
  justify-content: space-between;
  background: #fff;
  padding: 24rpx;
  border-radius: 18rpx;
  margin-bottom: 20rpx;
}

.metric {
  text-align: center;
  flex: 1;
}

.num {
  font-size: 40rpx;
  font-weight: 700;
  color: #111;
}

.num.blue {
  color: #3b82f6;
}

.label {
  font-size: 22rpx;
  color: #999;
}

/* ===== ⚡ 操作区（关键优化） ===== */
.actions {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.action {
  flex: 1;
  background: #fff;
  border-radius: 14rpx;
  padding: 22rpx 0;
  text-align: center;
  border: 1px solid #eee;
}

.icon {
  width: 54rpx;
  height: 54rpx;
  margin: 0 auto 8rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.add { background:#e8f3ff; color:#3b82f6; }
.list { background:#f3f4f6; color:#111; }
.msg { background:#ecfdf5; color:#10b981; }

/* ===== section ===== */
.section {
  background: #fff;
  border-radius: 18rpx;
  padding: 20rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.more {
  font-size: 24rpx;
  color: #3b82f6;
}

/* ===== list ===== */
.row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1px solid #f2f2f2;
}

.row:last-child {
  border-bottom: none;
}

.avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg,#3b82f6,#60a5fa);
  color: #fff;
  display:flex;
  align-items:center;
  justify-content:center;
  margin-right: 12rpx;
}

.info {
  flex: 1;
}

.name {
  font-size: 28rpx;
}

.sub {
  font-size: 22rpx;
  color: #999;
}

.status {
  font-size: 22rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
}

/* ===== job ===== */
.job {
  padding: 16rpx;
  border: 1px solid #f0f0f0;
  border-radius: 14rpx;
  margin-bottom: 12rpx;
}

.job-title {
  font-size: 28rpx;
  font-weight: 600;
}

.job-bottom {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
}

.salary {
  font-size: 24rpx;
  color: #666;
}

.job-status {
  font-size: 22rpx;
  color: #999;
}

/* ===== empty ===== */
.empty {
  text-align: center;
  padding: 30rpx 0;
  color: #bbb;
}