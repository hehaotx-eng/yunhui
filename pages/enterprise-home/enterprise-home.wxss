/* 页面背景 */
.page {
  background-color: #f6f7f9;
  min-height: 100vh;
  font-family: "PingFang SC","Microsoft YaHei",sans-serif;
}

/* 顶部 */
.header {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
}

.header-content {
  flex: 1;
  display: flex;
  justify-content: center;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #111827;
}

/* 内容区域 */
.content {
  padding: 16rpx;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 38rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.stat-divider {
  width: 1rpx;
  background-color: #e5e7eb;
  margin: 0 16rpx;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.action-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  margin: 0 8rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
  cursor: pointer;
}

.action-icon {
  width: 48rpx;
  height: 48rpx;
  background-color: #f3f4f6;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-text {
  font-size: 28rpx;
  color: #111827;
}

/* 分区标题 */
.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.section-more {
  font-size: 24rpx;
  color: #ff5c39;
}

/* 职位列表 */
.job-list {
}

.job-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.job-tag {
  display: inline-block;
  font-size: 24rpx;
  color: #ffffff;
  background-color: #ff5c39;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.job-tag.paused {
  background-color: #9ca3af;
}

.job-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 12rpx;
}

.job-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.job-salary {
  font-size: 28rpx;
  font-weight: 600;
  color: #ff5c39;
}

.job-time {
  font-size: 24rpx;
  color: #9ca3af;
}

.welfare-list {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.welfare-tag {
  font-size: 24rpx;
  color: #667085;
  background-color: #f5f6f8;
  border-radius: 8rpx;
  padding: 4rpx 8rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.job-footer {
  display: flex;
  justify-content: flex-start;
  font-size: 24rpx;
  color: #9ca3af;
}

.empty-tip {
  text-align: center;
  padding: 48rpx 0;
  font-size: 28rpx;
  color: #9ca3af;
}

/* TabBar */
.tabbar {
  height: 88rpx;
  background-color: #ffffff;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -8rpx 24rpx rgba(15,23,42,.03);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tab-item.active .tab-text {
  color: #ff5c39;
}

.tab-icon {
  width: 32rpx;
  height: 32rpx;
  margin-bottom: 4rpx;
  background-color: #f3f4f6;
  border-radius: 8rpx;
}

.tab-text {
  font-size: 24rpx;
  color: #4b5563;
}