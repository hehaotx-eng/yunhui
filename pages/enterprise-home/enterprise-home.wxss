.page {
  min-height: 100vh;
  background: #f6f7f9;
  padding-bottom: 120rpx;
}

.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255,255,255,.25);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
}

.nav-logo {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a1a2e;
}

.body {
  padding: 0 20rpx 40rpx;
}

.welcome {
  padding: 32rpx 8rpx 24rpx;
}

.welcome-greeting {
  font-size: 28rpx;
  color: #9ca3af;
  display: block;
}

.welcome-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a1a2e;
  margin-top: 6rpx;
  display: block;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 800;
  color: #1a1a2e;
  line-height: 1.1;
}

.stat-value.online {
  color: #22c55e;
}

.stat-label {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

.quick-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.action-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}

.action-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
}

.action-icon.add { background: linear-gradient(135deg, #299ff0, #5ab8f5); }
.action-icon.list { background: linear-gradient(135deg, #1a1a2e, #3d3d5c); }
.action-icon.search { background: linear-gradient(135deg, #22c55e, #4ade80); }

.action-text {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 500;
}

.section {
  margin-bottom: 28rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.section-more {
  font-size: 24rpx;
  color: #299ff0;
  font-weight: 500;
}

.app-row {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 20rpx;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}

.app-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #299ff0, #5ab8f5);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.app-info {
  flex: 1;
  min-width: 0;
}

.app-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
}

.app-job {
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.app-status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.status-pending { background: #fef9ee; color: #d48806; }
.status-viewed { background: #e6f4ff; color: #1677ff; }
.status-accepted { background: #f0f9eb; color: #389e0d; }
.status-rejected { background: #fff2f0; color: #cf1322; }
.status-online { background: #f0f9eb; color: #389e0d; }
.status-draft { background: #f3f4f6; color: #6b7280; }
.status-offline { background: #f3f4f6; color: #9ca3af; }

.job-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}

.job-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.job-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.job-salary {
  font-size: 26rpx;
  color: #ff5c39;
  font-weight: 600;
}

.empty {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #9ca3af;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}
