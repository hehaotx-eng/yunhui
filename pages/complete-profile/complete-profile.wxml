<view class="page">
  <view class="hero">
    <view class="hero-title">欢迎加入</view>
    <view class="hero-desc">请选择你的身份</view>
  </view>

  <!-- 步骤1：选角色 -->
  <view wx:if="{{step === 1}}" class="role-group">
    <view class="role-card {{role === 'user' ? 'active' : ''}}" bindtap="selectRole" data-role="user">
      <view class="role-icon"></view>
      <view class="role-info">
        <text class="role-title">我要找工作</text>
        <text class="role-desc">浏览职位、投递简历、在线沟通</text>
      </view>
      <view class="role-check" wx:if="{{role === 'user'}}">✓</view>
    </view>
    <view class="role-card {{role === 'enterprise' ? 'active' : ''}}" bindtap="selectRole" data-role="enterprise">
      <view class="role-icon"></view>
      <view class="role-info">
        <text class="role-title">我要招人</text>
        <text class="role-desc">发布职位、管理投递、人才筛选</text>
      </view>
      <view class="role-check" wx:if="{{role === 'enterprise'}}">✓</view>
    </view>
  </view>

  <!-- 步骤2：填信息 -->
  <view wx:if="{{step === 2}}" class="form-card">
    <view class="form-item">
      <view class="label">昵称 <text class="required">*</text></view>
      <input class="input-field" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameInput" maxlength="20" />
    </view>
    <view class="form-item">
      <view class="label">手机号</view>
      <input class="input-field" placeholder="请输入手机号（选填）" value="{{phone}}" bindinput="onPhoneInput" type="number" maxlength="11" />
    </view>
    <view wx:if="{{role === 'enterprise'}}" class="form-item">
      <view class="label">公司名称 <text class="required">*</text></view>
      <input class="input-field" placeholder="请输入公司名称" value="{{companyName}}" bindinput="onCompanyInput" />
    </view>
    <view wx:if="{{role === 'enterprise'}}" class="form-item">
      <view class="label">联系人 <text class="required">*</text></view>
      <input class="input-field" placeholder="请输入联系人" value="{{contactName}}" bindinput="onContactNameInput" />
    </view>
    <view wx:if="{{role === 'enterprise'}}" class="form-item">
      <view class="label">联系电话 <text class="required">*</text></view>
      <input class="input-field" placeholder="请输入联系电话" value="{{contactPhone}}" bindinput="onContactPhoneInput" type="number" />
    </view>
  </view>

  <view class="floating-bar">
    <view wx:if="{{step === 1}}" class="submit-btn {{!role ? 'disabled' : ''}}" bindtap="nextStep">下一步</view>
    <view wx:if="{{step === 2}}" class="submit-btn-row">
      <view class="submit-btn-outline" bindtap="prevStep">上一步</view>
      <view class="submit-btn {{saving ? 'disabled' : ''}}" bindtap="save">{{saving ? '保存中...' : '进入首页'}}</view>
    </view>
  </view>
</view>
