page {
  background: #f6f7f9;
}

.page {
  min-height: 100vh;
}

/* =====================
   顶部
===================== */

.header {
  padding: 120rpx 24rpx 24rpx;
}

.header-text {
  font-size: 48rpx;
  font-weight: 700;

  color: #111827;
}

/* =====================
   列表
===================== */

.notification-list {
  margin-top: 30rpx;
  padding: 0 24rpx 40rpx;
}

/* =====================
   通知卡片
===================== */

.notification-card {
  background: #ffffff;

  border-radius: 24rpx;

  padding: 28rpx;

  margin-bottom: 20rpx;

  display: flex;
  align-items: flex-start;

  box-shadow:
    0 8rpx 24rpx rgba(15, 23, 42, .03);

  position: relative;

  transition: all .2s ease;
}

/* 未读状态 */

.notification-card.unread::before {
  content: "";

  position: absolute;

  top: 32rpx;
  left: 16rpx;

  width: 12rpx;
  height: 12rpx;

  border-radius: 50%;

  background: #ff5c39;
}

/* =====================
   图标
===================== */

.notify-icon {
  width: 80rpx;
  height: 80rpx;

  border-radius: 18rpx;

  background: #fff3ee;

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 38rpx;

  flex-shrink: 0;
}

/* =====================
   内容
===================== */

.notify-content {
  flex: 1;

  margin-left: 20rpx;

  overflow: hidden;
}

.notify-title {
  font-size: 30rpx;
  font-weight: 700;

  color: #111827;

  line-height: 1.4;
}

.notify-desc {
  margin-top: 12rpx;

  font-size: 26rpx;

  color: #6b7280;

  line-height: 1.8;

  word-break: break-all;
}

.notify-time {
  margin-top: 16rpx;

  font-size: 22rpx;

  color: #9ca3af;
}

/* =====================
   空状态
===================== */

.empty-card {
  background: #ffffff;

  border-radius: 24rpx;

  padding: 120rpx 0;

  text-align: center;

  box-shadow:
    0 8rpx 24rpx rgba(15, 23, 42, .03);
}

.empty-icon {
  font-size: 96rpx;
}

.empty-text {
  margin-top: 24rpx;

  font-size: 28rpx;

  color: #9ca3af;
}

/* =====================
   加载中
===================== */

.loading {
  text-align: center;

  padding: 60rpx 0;

  color: #9ca3af;

  font-size: 26rpx;
}