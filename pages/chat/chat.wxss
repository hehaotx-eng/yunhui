.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f7fa;
}

.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255,255,255,.95);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid #e8ecf0;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.back-icon {
  font-size: 40rpx;
  color: #1a1a2e;
}

.nav-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.nav-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.nav-placeholder {
  width: 60rpx;
  flex-shrink: 0;
}

.body {
  flex: 1;
  overflow: hidden;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  gap: 16rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e8ecf0;
  border-top-color: #299ff0;
  border-radius: 50%;
  animation: spin .8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #8a9aa8;
}

.msg-list {
  height: 100%;
  box-sizing: border-box;
  padding: 20rpx 24rpx;
}

.top-safe {
  height: 10rpx;
}

.msg-item {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.msg-item.mine {
  justify-content: flex-end;
}

.msg-item.other {
  justify-content: flex-start;
}

.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e0e6ed, #c8d0d8);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.mine-avatar {
  background: linear-gradient(135deg, #299ff0, #1a8fe0);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}

.msg-content {
  max-width: 70%;
  margin: 0 16rpx;
  display: flex;
  flex-direction: column;
}

.job-card-wrapper,
.resume-card-wrapper {
  max-width: none;
  width: 520rpx;
}

.msg-item.mine .msg-content {
  align-items: flex-end;
}

.msg-item.other .msg-content {
  align-items: flex-start;
}

.msg-bubble {
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  position: relative;
  word-wrap: break-word;
}

.msg-item.mine .msg-bubble {
  background: linear-gradient(135deg, #299ff0, #1a8fe0);
  border-radius: 20rpx 4rpx 20rpx 20rpx;
}

.msg-item.other .msg-bubble {
  background: #ffffff;
  border-radius: 4rpx 20rpx 20rpx 20rpx;
}

.msg-bubble.sending {
  opacity: 0.7;
}

.msg-bubble.failed {
  border: 2rpx solid #ff4d4f;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #1a2a3a;
}

.msg-item.mine .msg-text {
  color: #ffffff;
}

.msg-status {
  margin-top: 6rpx;
  text-align: right;
}

.status-icon {
  font-size: 20rpx;
}

.failed-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  background: #ff4d4f;
  color: #fff;
  border-radius: 50%;
  font-size: 18rpx;
  font-weight: 700;
}

.msg-time {
  font-size: 20rpx;
  color: #8a9aa8;
  margin-top: 6rpx;
  display: block;
}

.msg-item.mine .msg-time {
  text-align: right;
}

.job-card {
  width: 520rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06);
  padding: 24rpx;
}

.mine-job {
  border-radius: 20rpx 4rpx 20rpx 20rpx;
}

.other-job {
  border-radius: 4rpx 20rpx 20rpx 20rpx;
}

.job-card-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.job-card-icon {
  font-size: 28rpx;
}

.job-card-label {
  font-size: 22rpx;
  color: #8a9aa8;
}

.job-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-card-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.job-card-salary {
  font-size: 30rpx;
  font-weight: 700;
  color: #ff5c39;
}

.job-card-location {
  font-size: 24rpx;
  color: #8a9aa8;
  background: #f5f5f5;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.job-card-company {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.job-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.job-card-tag {
  font-size: 22rpx;
  color: #607d8b;
  background: #e8f5e9;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

.job-card-footer {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.job-card-btn {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.job-card-btn.secondary {
  background: #f5f7fa;
}

.job-card-btn.secondary text {
  color: #666;
}

.job-card-btn.primary {
  background: linear-gradient(135deg, #299ff0, #1a8fe0);
}

.job-card-btn.primary text {
  color: #fff;
}

.job-card-btn.applied {
  background: #e8ecf0;
}

.job-card-btn.applied text {
  color: #8a9aa8;
}

.resume-card {
  width: 520rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06);
  padding: 24rpx;
}

.mine-resume {
  border-radius: 20rpx 4rpx 20rpx 20rpx;
}

.other-resume {
  border-radius: 4rpx 20rpx 20rpx 20rpx;
}

.resume-card-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.resume-card-icon {
  font-size: 28rpx;
}

.resume-card-label {
  font-size: 22rpx;
  color: #8a9aa8;
  flex: 1;
}

.resume-status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.resume-status.unread {
  background: #f5f5f5;
}

.resume-status.unread text {
  color: #8a9aa8;
}

.resume-status.read {
  background: #e8f5e9;
}

.resume-status.read text {
  color: #4caf50;
}

.resume-card-body {
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.resume-card-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 8rpx;
}

.resume-card-intention {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.resume-card-info {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.resume-card-experience,
.resume-card-education {
  font-size: 22rpx;
  color: #8a9aa8;
  background: #f5f5f5;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.resume-card-action {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  background: linear-gradient(135deg, #299ff0, #1a8fe0);
  border-radius: 32rpx;
}

.resume-card-action text {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}

.input-bar {
  background: #ffffff;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e8ecf0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.location-card-wrapper {
  max-width: none;
  width: 480rpx;
}

.location-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06);
}

.mine-location {
  border-radius: 20rpx 4rpx 20rpx 20rpx;
}

.other-location {
  border-radius: 4rpx 20rpx 20rpx 20rpx;
}

.location-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.location-info {
  flex: 1;
  min-width: 0;
}

.location-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-address {
  font-size: 24rpx;
  color: #8a9aa8;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.input-tools {
  display: flex;
  gap: 12rpx;
}

.tool-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f7fa;
  border-radius: 50%;
  flex-shrink: 0;
}

.tool-btn:active {
  background: #e8ecf0;
}

.tool-icon {
  font-size: 32rpx;
}

.input-wrap {
  flex: 1;
  height: 72rpx;
  background: #f5f7fa;
  border-radius: 36rpx;
  border: 2rpx solid #e8ecf0;
}

.input-wrap:focus-within {
  border-color: #299ff0;
  background: #ffffff;
}

.input {
  width: 100%;
  height: 100%;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  background: #e0e6ed;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-btn.active {
  background: linear-gradient(135deg, #299ff0, #1a8fe0);
  box-shadow: 0 4rpx 16rpx rgba(41, 159, 240, 0.3);
}

.send-btn text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.msg-list::-webkit-scrollbar {
  width: 0;
  height: 0;
  display: none;
}

.quick-phrases-modal-wrap {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
}

.qpm-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.qpm-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 70vh;
}

.qpm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.qpm-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.qpm-close {
  font-size: 40rpx;
  color: #999;
  padding: 8rpx;
}

.qpm-list {
  padding: 16rpx;
  max-height: calc(70vh - 80rpx);
  overflow-y: auto;
}

.qpm-item {
  padding: 24rpx;
  margin-bottom: 12rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
}

.qpm-item:active {
  background: #e8ecf0;
}