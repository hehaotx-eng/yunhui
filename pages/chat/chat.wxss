.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f7fa;
}

/* ===== 顶部导航 ===== */
.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255,255,255,.95);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid #e8ecf0;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.back-icon {
  font-size: 40rpx;
  color: #1a1a2e;
}

.nav-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.nav-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.nav-placeholder {
  width: 60rpx;
  flex-shrink: 0;
}

/* ===== 消息区 ===== */
.body {
  flex: 1;
  overflow: hidden;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  gap: 16rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e8ecf0;
  border-top-color: #299ff0;
  border-radius: 50%;
  animation: spin .8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #8a9aa8;
}

.msg-list {
  height: 100%;
  box-sizing: border-box;
  padding: 20rpx 24rpx;
}

.top-safe {
  height: 10rpx;
}

/* ===== 消息项 ===== */
.msg-item {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.msg-item.mine {
  justify-content: flex-end;
}

.msg-item.other {
  justify-content: flex-start;
}

/* 头像 */
.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e0e6ed, #c8d0d8);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.mine-avatar {
  background: linear-gradient(135deg, #299ff0, #1a8fe0);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}

/* 消息内容 */
.msg-content {
  max-width: 65%;
  margin: 0 16rpx;
}

.msg-item.mine .msg-content {
  align-items: flex-end;
}

.msg-item.other .msg-content {
  align-items: flex-start;
}

/* 气泡 */
.msg-bubble {
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  position: relative;
  word-wrap: break-word;
}

.msg-item.mine .msg-bubble {
  background: linear-gradient(135deg, #299ff0, #1a8fe0);
  border-radius: 20rpx 4rpx 20rpx 20rpx;
}

.msg-item.other .msg-bubble {
  background: #ffffff;
  border-radius: 4rpx 20rpx 20rpx 20rpx;
}

.msg-bubble.sending {
  opacity: 0.7;
}

.msg-bubble.failed {
  border: 2rpx solid #ff4d4f;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #1a2a3a;
}

.msg-item.mine .msg-text {
  color: #ffffff;
}

.msg-status {
  margin-top: 6rpx;
  text-align: right;
}

.status-icon {
  font-size: 20rpx;
}

.failed-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  background: #ff4d4f;
  color: #fff;
  border-radius: 50%;
  font-size: 18rpx;
  font-weight: 700;
}

/* 时间 */
.msg-time {
  font-size: 20rpx;
  color: #8a9aa8;
  margin-top: 6rpx;
  display: block;
}

.msg-item.mine .msg-time {
  text-align: right;
}

/* ===== 输入栏 ===== */
.input-bar {
  background: #ffffff;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e8ecf0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.input-wrap {
  flex: 1;
  height: 72rpx;
  background: #f5f7fa;
  border-radius: 36rpx;
  border: 2rpx solid #e8ecf0;
}

.input-wrap:focus-within {
  border-color: #299ff0;
  background: #ffffff;
}

.input {
  width: 100%;
  height: 100%;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input-placeholder {
  color: #a0b0c0;
}

/* 发送按钮 */
.send-btn {
  width: 120rpx;
  height: 72rpx;
  background: #e0e6ed;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-btn.active {
  background: linear-gradient(135deg, #299ff0, #1a8fe0);
  box-shadow: 0 4rpx 16rpx rgba(41, 159, 240, 0.3);
}

.send-btn text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 隐藏滚动条 */
.msg-list::-webkit-scrollbar {
  width: 0;
  height: 0;
  display: none;
}
