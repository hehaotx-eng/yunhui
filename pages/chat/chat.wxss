.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fff;
}

.msg-list {
  flex: 1;
  height: calc(100vh - env(safe-area-inset-bottom) - 120rpx);
}


.msg-list-inner {
  padding: 40rpx 28rpx;
}

.job-hint {
  text-align: center;
  font-size: 22rpx;
  color: #b0b0b0;
  margin-bottom: 48rpx;
}

.msg-item {
  margin-bottom: 44rpx;
}

.time-text {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: #ccc;
  margin-bottom: 16rpx;
}

/* 对方消息行：头像左，气泡右 */
.msg-row {
  display: flex;
  align-items: flex-start;
}

/* 我的消息行：气泡左，头像右 */
.msg-row-me {
  justify-content: flex-end;
}

/* 头像 */
.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 26rpx;
  color: #fff;
}

/* 对方头像在左，右边留间距 */
.avatar-other {
  background: #d0d0d0;
  margin-right: 18rpx;
}

/* 我的头像在右，左边留间距 */
.avatar-me {
  background: #1a1a1a;
  margin-left: 18rpx;
}

/* 气泡 */
.bubble {
  display: inline-block;
  padding: 24rpx 30rpx;
  border-radius: 24rpx;
  word-break: break-all;
  max-width: 60%;
}

.bubble-other {
  background: #f8f8f8;
  border-bottom-left-radius: 6rpx;
}

.bubble-me {
  background: #f2f2f2;
  border-bottom-right-radius: 6rpx;
}

.bubble-text {
  font-size: 30rpx;
  line-height: 1.65;
  color: #1a1a1a;
}

/* 输入栏 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.input {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #1a1a1a;
}

.ph {
  color: #ccc;
  font-size: 28rpx;
}

.send {
  width: 120rpx;
  height: 80rpx;
  background: #e8e8e8;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  transition: background 0.2s;
}

.send-on {
  background: #1a1a1a;
}

.send text {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
}

.send-on text {
  color: #fff;
}

.send:active {
  transform: scale(0.96);
}
