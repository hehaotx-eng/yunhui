page {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #00a2ff 0%, #0080ff 100%);
  padding: 60rpx 32rpx 24rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.chat-content {
  padding: 24rpx;
  padding-bottom: 160rpx;
  height: calc(100vh - 200rpx);
  overflow-y: auto;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.message-item {
  display: flex;
}

.message-item.right {
  justify-content: flex-end;
}

.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.message-content {
  max-width: 70%;
  margin: 0 16rpx;
}

.message-bubble {
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.message-item.left .message-bubble {
  background: #fff;
  color: #333;
  border-radius: 0 20rpx 20rpx 20rpx;
}

.message-item.right .message-bubble {
  background: #00a2ff;
  color: #fff;
  border-radius: 20rpx 0 20rpx 20rpx;
}

.message-time {
  font-size: 20rpx;
  color: #ccc;
  margin-top: 8rpx;
}

.message-item.left .message-time {
  text-align: left;
}

.message-item.right .message-time {
  text-align: right;
}

.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.06);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.input-field {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 100rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #00a2ff;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #fff;
}