<view class="page">
  <scroll-view class="message-list" scroll-y scroll-into-view="bottom" enhanced show-scrollbar="false">
    <view wx:for="{{messages}}" wx:key="id" class="message-item {{item.senderId == myUserId || item.sender_id == myUserId ? 'mine' : ''}}">
      <view class="avatar">{{getAvatarLetter(item)}}</view>
      <view class="bubble-wrap">
        <view wx:if="{{!(item.senderId == myUserId || item.sender_id == myUserId)}}" class="sender-name">{{item.enterpriseName || item.username || '对方'}}</view>
        <view class="bubble">{{item.content}}</view>
      </view>
    </view>
    <view id="bottom"></view>
  </scroll-view>
  <view class="input-bar">
    <input value="{{inputValue}}" bindinput="onInput" placeholder="输入消息" confirm-type="send" bindconfirm="sendMessage" />
    <view class="send-btn" bindtap="sendMessage">发送</view>
  </view>
</view>