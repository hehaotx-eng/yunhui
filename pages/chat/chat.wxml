<view class="chat-page">
  <scroll-view class="msg-list" scroll-y scroll-top="{{scrollTop}}" scroll-with-animation>

    <view class="msg-list-inner">
      <view class="job-hint" wx:if="{{conversation.jobTitle}}">
        <text>💼 {{conversation.jobTitle}}</text>
      </view>

      <view class="msg-item" wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}">
        <text class="time-text" wx:if="{{item.showTime}}">{{item.timeText}}</text>

        <!-- 对方消息：头像在左 -->
        <view class="msg-row" wx:if="{{item.sender_id != myUserId}}">
          <view class="msg-avatar avatar-other">
            <text>{{conversation.enterpriseName[0] || '企'}}</text>
          </view>
          <view class="bubble bubble-other">
            <text class="bubble-text">{{item.content}}</text>
          </view>
        </view>

        <!-- 我的消息：头像在右 -->
        <view class="msg-row msg-row-me" wx:if="{{item.sender_id == myUserId}}">
          <view class="bubble bubble-me">
            <text class="bubble-text">{{item.content}}</text>
          </view>
          <view class="msg-avatar avatar-me">
            <text>我</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="input-bar">
    <input class="input" placeholder="说点什么..." placeholder-class="ph" value="{{inputValue}}" bindinput="onInput" bindconfirm="sendMessage" confirm-type="send" />
    <view class="send {{inputValue ? 'send-on' : ''}}" bindtap="sendMessage">
      <text>发送</text>
    </view>
  </view>
</view>