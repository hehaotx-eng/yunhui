<!--pages/home/home.wxml-->
<view class="header">
  <view class="header-text">在线招聘</view>
</view>

<view class="search-bar">
  <view class="search-wrapper" style="width: 625rpx; display: flex; box-sizing: border-box; left: 15rpx; top: 0rpx">
    <image class="icon-search" src="/pages/image/sousuo.png" />
    <input class="search-input" placeholder="搜索职位/企业" />
  </view>
  <view class="search-extra" style="width: 110rpx; box-sizing: border-box">
    <image style="position: relative; left: 41rpx; top: 0rpx" class="icon-switch" src="/pages/image/qiehuan.png" mode="" />
    <view style="font-size: 20rpx; position: relative; left: 25rpx; color:#17abe3; top: 0rpx">招人才</view>
  </view>
</view>

<!-- 轮播 -->
<view class="banner">
  <swiper indicator-dots="true" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#fff" circular autoplay interval="4000">
    <swiper-item>
      <image src="https://developer.qcloudimg.com/http-save/yehe-100000/50c65ad280db00897342d3619066be8b.png"></image>
    </swiper-item>
    <swiper-item>
      <image src="https://developer.qcloudimg.com/http-save/yehe-100000/50c65ad280db00897342d3619066be8b.png"></image>
    </swiper-item>
  </swiper>
</view>

<!-- 快捷入口 -->
<view class="quick-nav">
  <view class="quick-nav-item">全部职位</view>
  <view class="quick-nav-item">简历库</view>
  <view class="quick-nav-item">商超零售</view>
  <view class="quick-nav-item">普工技工</view>
  <view class="quick-nav-item">联系客服</view>
</view>

<!-- 通知 -->
<view class="notice-bar" bindtap="goNotice">
  <view class="notice-icon">📢</view>
  <swiper 
    class="notice-swiper" 
    vertical 
    autoplay 
    interval="3000" 
    duration="500" 
    circular
  >
    <swiper-item wx:for="{{notices}}" wx:key="id">
      <view class="notice-text">{{item.title}}</view>
    </swiper-item>
  </swiper>
  <view class="notice-more">更多</view>
</view>

<!-- 分类 -->
<scroll-view class="category-scroll" scroll-x>
  <view 
    wx:for="{{categories}}" 
    wx:key="id"
    class="category-item {{activeId === item.id ? 'active' : ''}}"
    bindtap="switchCategory"
    data-id="{{item.id}}"
  >
    <text>{{item.name}}</text>
  </view>
</scroll-view>

<!-- 招聘卡片列表 -->
<view class="job-list">
  <view 
    wx:for="{{jobs}}" 
    wx:key="id" 
    class="job-card"
    bindtap="goDetail"
    data-id="{{item.id}}"
  >
    <!-- 右上角标签 -->
    <view wx:if="{{item.tag}}" class="job-tag">{{item.tag}}</view>
    
    <!-- 职位标题 -->
    <view class="job-title">{{item.title}}</view>
    
    <!-- 薪资和时间 -->
    <view class="job-meta">
      <view class="job-salary">{{item.salary}} <text class="salary-unit">元/月</text></view>
      <view class="job-time">{{item.time}}</view>
    </view>
    
    <!-- 福利标签 -->
    <view class="welfare-list">
      <view wx:for="{{item.tags}}" wx:for-item="w" wx:key="*this" class="welfare-tag">{{w}}</view>
      <view wx:if="{{item.tags && item.tags.length > 3}}" class="welfare-tag more">...</view>
    </view>
    
    <!-- 底部信息 -->
    <view class="job-footer">
      <view class="company-info">
        <image class="company-logo" src="{{item.logo}}" mode="aspectFit"/>
        <view class="company-detail">
          <view class="company-contact">{{item.contactName}}</view>
          <view class="company-name">
            {{item.enterpriseName}}
            <image wx:if="{{item.verified}}" class="verify-icon" src="/images/verify.png" mode="aspectFit"/>
          </view>
        </view>
      </view>
      <view class="btn-call" catchtap="callPhone" data-phone="{{item.phone}}">拨打电话</view>
    </view>
  </view>
</view>