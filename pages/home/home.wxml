<view class="page">

  <!-- 顶部 -->
  <view class="header">
    <view class="header-text">在线招聘</view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-wrapper" bindtap="goSearch">
      <image class="icon-search" src="/pages/image/sousuo.png" />
      <text class="search-placeholder">搜索职位/企业</text>
    </view>
    <view class="search-extra" bindtap="goEnterpriseSwitch">
      <image class="icon-switch" src="/pages/image/qiehuan.png" mode="aspectFit" />
      <view class="switch-text">招人才</view>
    </view>
  </view>

  <!-- Banner -->
  <view class="banner">
    <swiper indicator-dots="true" indicator-color="rgba(0,0,0,0.2)" indicator-active-color="#111827" circular autoplay interval="4000">
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <image src="{{item.image || '/pages/image/default-banner.png'}}" mode="aspectFill" />
      </swiper-item>
    </swiper>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-nav">
    <view class="quick-nav-item" bindtap="goAllJobs">
      <view class="nav-icon"></view>
      <view class="nav-text">全部职位</view>
    </view>
    <view class="quick-nav-item" bindtap="goResumeLibrary">
      <view class="nav-icon"></view>
      <view class="nav-text">简历库</view>
    </view>
    <view class="quick-nav-item" bindtap="goRetail">
      <view class="nav-icon"></view>
      <view class="nav-text">商超零售</view>
    </view>
    <view class="quick-nav-item" bindtap="goFactory">
      <view class="nav-icon"></view>
      <view class="nav-text">普工技工</view>
    </view>
    <view class="quick-nav-item" bindtap="goContact">
      <view class="nav-icon"></view>
      <view class="nav-text">联系客服</view>
    </view>
  </view>

  <!-- 通知 -->
  <view class="notice-bar" bindtap="goNotice" >
    <view class="notice-icon"></view>
    <swiper wx:if="{{notices.length > 0}}" class="notice-swiper" vertical autoplay interval="3000" duration="500" circular>
      <swiper-item wx:for="{{notices}}" wx:key="id" >
        <view class="notice-text">{{item.title || item.content}}</view>
      </swiper-item>
    </swiper>
    <view wx:else class="notice-empty">暂无通知</view>
    <view class="notice-more">更多</view>
  </view>

  <!-- 分类横向滚动 -->
  <scroll-view class="category-scroll" scroll-x>
    <view wx:for="{{categories}}" wx:key="id" class="category-item {{activeId === item.id ? 'active' : ''}}" bindtap="switchCategory" data-id="{{item.id}}">
      <text>{{item.name}}</text>
    </view>
  </scroll-view>

  <!-- 职位列表 -->
  <view class="job-list">
    <view wx:if="{{loading}}" class="loading">加载中...</view>

    <view wx:for="{{jobs}}" wx:key="id" class="job-card" bindtap="goDetail" data-id="{{item.id}}">
      <view wx:if="{{item.tag}}" class="job-tag">{{item.tag}}</view>

      <view class="job-title">{{item.title}}</view>

      <view class="job-meta">
        <view class="job-salary">
          <text class="salary-num">{{item.salary}}</text>
          <text class="salary-unit">{{item.salary && item.salary.includes('元') ? '' : '元/月'}}</text>
        </view>
        <view class="job-time">{{item.time || item.createdAt ? (item.createdAt.length > 10 ? item.createdAt.substring(0, 10) : item.createdAt) : '刚刚'}}</view>
      </view>

      <view class="welfare-list">
        <view wx:for="{{item.tags || item.welfare || []}}" wx:for-item="w" wx:key="*this" class="welfare-tag">{{w}}</view>
      </view>

      <view class="job-footer">
        <view class="company-info">
          <view wx:if="{{item.logo}}" class="company-logo" style="background-image: url({{item.logo}});"></view>
          <view wx:else class="company-logo-placeholder">{{item.enterpriseName ? item.enterpriseName.substring(0, 1) : ''}}</view>
          <view class="company-detail">
            <view class="company-contact">{{item.contactName || item.contact}}</view>
            <view class="company-name">
              {{item.enterpriseName || item.companyName}}
              <image wx:if="{{item.verified}}" class="verify-icon" src="/images/verify.png" mode="aspectFit" />
            </view>
          </view>
        </view>
        <view class="btn-call" catchtap="callPhone" data-phone="{{item.phone || item.contactPhone}}">拨打电话</view>
      </view>
    </view>

    <view wx:if="{{!loading && jobs.length === 0}}" class="empty-card">
      <view class="empty-icon"></view>
      <view class="empty-text">暂无职位</view>
    </view>

  </view>

</view>