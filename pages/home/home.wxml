<view class="feed-page">
  <dynamic-page wx:if="{{useDynamicPage}}" pagePath="home" />
  <block wx:else>
    <!-- 顶部导航 -->
    <view class="top-nav" style="padding-top: {{statusBarHeight}}px;">
      <view class="nav-content">
        <text class="nav-logo">发现</text>
        <view class="nav-search" bindtap="goSearch">
          <image class="search-icon" src="/pages/image/sousuo.png" />
          <text class="search-text">搜索职位、企业、技能...</text>
        </view>
      </view>
    </view>

    <!-- 轮播图 -->
    <view class="banner-wrap" style="margin-top: {{statusBarHeight + 44}}px;">
      <swiper class="banner-swiper" indicator-dots="{{true}}" indicator-color="rgba(255,255,255,.3)" indicator-active-color="#fff" autoplay circular interval="4000" bindchange="onBannerChange">
        <swiper-item wx:for="{{banners}}" wx:key="id">
          <view class="banner-item" bindtap="goSearch">
            <image wx:if="{{item.image_url}}" class="banner-img" src="{{item.image_url}}" mode="aspectFill" />
            <view wx:else class="banner-bg banner-bg-{{index}}"></view>
            <view class="banner-content">
              <text class="banner-title">{{item.title}}</text>
              <text class="banner-subtitle">{{item.subtitle}}</text>
            </view>
          </view>
        </swiper-item>
      </swiper>
      <!-- 快捷图标导航 -->
      <view class="quick-links" wx:if="{{quickLinks.length > 0}}">
        <view class="ql-item" wx:for="{{quickLinks}}" wx:key="id" data-link="{{item.link}}" bindtap="onQuickLinkTap">
          <image class="ql-icon" src="{{item.icon}}" mode="aspectFit" />
          <text class="ql-label">{{item.title}}</text>
        </view>
      </view>
    </view>

    <!-- 通知公告 -->
    <view class="notice-bar" wx:if="{{notices && notices.length > 0}}" bindtap="goNotifications">
      <image class="notice-icon" src="/pages/image/tongzhi.png" mode="aspectFit" />
      <swiper class="notice-swiper" vertical autoplay circular interval="3000" display-multiple-items="{{1}}">
        <swiper-item wx:for="{{notices}}" wx:key="id">
          <text class="notice-text line-clamp-1">{{item.title}}</text>
        </swiper-item>
      </swiper>
      <text class="notice-more">更多 ›</text>
    </view>

    <!-- 分类标签 -->
    <scroll-view class="cat-scroll {{catSticky ? 'cat-sticky' : ''}}" style="{{stickyStyle}}" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="cat-inner">
        <view wx:for="{{categories}}" wx:key="id" class="cat-item {{activeCategory === item.id ? 'cat-active' : ''}}" data-id="{{item.id}}" bindtap="onCategoryTap">{{item.name}}</view>
      </view>
    </scroll-view>
    <view wx:if="{{catSticky}}" style="height: 88rpx;"></view>

    <view class="container">
        <!-- VIP 卡片 -->
      <view class="card card-vip" bindtap="goVip">
        <view class="vip-card-glow"></view>
        <view class="vip-card-inner">
          <view class="vip-left">
            <!-- <text class="vip-crown">👑</text> -->
            <view class="vip-info">
              <text class="vip-title" wx:if="{{!isVip}}">开通 AI 智能求职会员</text>
              <text class="vip-title" wx:else>VIP会员</text>
              <text class="vip-desc" wx:if="{{!isVip}}">简历优化 + AI 推荐 + AI 面试</text>
              <text class="vip-desc" wx:else>全部 AI 功能已解锁</text>
            </view>
          </view>
          <view class="vip-action">
            <text wx:if="{{!isVip}}">立即开通</text>
            <text wx:else>查看权益</text>
          </view>
        </view>
      </view>
      <!-- 创建简历 -->
      <view class="card card-blue" bindtap="goCreateResume">
        <view class="icon-box">
          <view class="icon"></view>
        </view>
        <view class="text-box">
          <text class="title">创建简历</text>
        </view>
        <view class="arrow">›</view>
      </view>
    </view>

    <!-- 信息流 -->
    <view class="feed-list" wx:if="{{!skeleton}}">
      <view class="ai-banner" wx:if="{{!activeCategory && aiCount > 0}}" bindtap="goAiRecommend">
        <view class="ai-banner-bg"></view>
        <view class="ai-banner-content">
          <view class="ai-icon-wrap"><text class="ai-icon-text">AI</text></view>
          <view class="ai-banner-info">
            <text class="ai-banner-title">发现 {{aiCount}} 个适合你的机会</text>
            <text class="ai-banner-desc">基于你的偏好智能匹配</text>
          </view>
          <view class="ai-banner-arrow"><text>→</text></view>
        </view>
      </view>
      <block wx:for="{{feedList}}" wx:key="id">
        <feed-card wx:if="{{item.type === 'job'}}" item="{{item.payload}}" type="job" bind:tap="goDetail" bind:company="goCompany" bind:action="onFeedAction" />
        <ai-recommend-card wx:if="{{item.type === 'ai_recommend'}}" item="{{item.payload}}" bind:tap="goDetail" bind:company="goCompany" bind:action="onAiAction" />
        <company-post-card wx:if="{{item.type === 'company_post'}}" item="{{item.payload}}" bind:tap="goDetail" bind:company="goCompany" bind:action="onPostAction" />
      </block>
      <empty-state wx:if="{{feedList.length === 0 && !loading}}" title="还没有内容" subtitle="关注企业获取最新动态" />
      <load-more loading="{{loadingMore}}" hasMore="{{hasMore}}" />
    </view>

    <!-- 骨架屏 -->
    <view wx:if="{{skeleton}}" class="skeleton-wrap">
      <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="skeleton-header">
          <view class="skeleton-avatar skeleton-pulse"></view>
          <view class="skeleton-lines">
            <view class="skeleton-line skeleton-line--lg skeleton-pulse"></view>
            <view class="skeleton-line skeleton-line--sm skeleton-pulse"></view>
          </view>
        </view>
        <view class="skeleton-img skeleton-pulse"></view>
        <view class="skeleton-text skeleton-pulse"></view>
      </view>
    </view>
  </block>
</view>

<custom-tab-bar />