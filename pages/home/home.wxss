/* 全局背景 */
.page {
  background-color: #f6f7f9;
  min-height: 100vh;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

/* 顶部 */
.header {
  padding: 120rpx 24rpx 24rpx;
}

.header-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #111827;
}
/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  margin: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
}

.search-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #f3f4f6;
  border-radius: 16rpx;
  padding: 0 16rpx;
  height: 64rpx;
}

.icon-search {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.search-placeholder {
  color: #9ca3af;
  font-size: 28rpx;
}

/* 搜索栏右侧切换 */
.search-extra {
  display: flex;
  align-items: center;
  margin-left: 16rpx;
}

.icon-switch {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

.switch-text {
  font-size: 28rpx;
  color: #111827;
}

/* Banner */
.banner {
  margin: 16rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner image {
  width: 100%;
  height: 270rpx;
}

/* 快捷入口 */
.quick-nav {
  display: flex;
  justify-content: space-between;
  padding: 16rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  margin: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
}

.quick-nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 48rpx;
  height: 48rpx;
  background-color: #f3f4f6;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-text {
  font-size: 24rpx;
  color: #111827;
}

/* 通知栏 */
.notice-bar {
  height: 72rpx;
  background: #ffffff;
  margin: 16rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);

  display: flex;
  align-items: center;
}

.notice-icon {
  width: 28rpx;
  height: 28rpx;
  background: #ff5c39;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.notice-swiper {
  flex: 1;
  height: 40rpx;
  line-height: 40rpx;
}

.notice-text {
  height: 40rpx;
  line-height: 40rpx;

  font-size: 24rpx;
  color: #4b5563;

  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notice-empty {
  flex: 1;
  font-size: 24rpx;
  color: #9ca3af;
}

.notice-more {
  font-size: 24rpx;
  color: #ff5c39;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.notice-text {
  font-size: 28rpx;
  color: #4b5563;
}

.notice-more {
  font-size: 24rpx;
  color: #ff5c39;
  margin-left: 12rpx;
}

/* 分类横向滚动 */
.category-scroll {
  padding: 16rpx;
}

.category-item {
  padding: 8rpx 16rpx;
  margin-right: 12rpx;
  font-size: 28rpx;
  color: #4b5563;
  background-color: #f5f6f8;
  border-radius: 16rpx;
}

.category-item.active {
  background-color: #ff5c39;
  color: #ffffff;
}

/* 职位列表 */
.job-list {
  padding: 16rpx;
}

.loading {
  text-align: center;
  font-size: 28rpx;
  color: #9ca3af;
}

/* 职位卡片 */
.job-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
}

.job-tag {
  display: inline-block;
  background-color: #ff5c39;
  color: #ffffff;
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.job-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.job-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.job-salary {
  font-size: 42rpx;
  font-weight: 600;
  color: #ff5c39;
}

.salary-unit {
  font-size: 28rpx;
  color: #ff5c39;
}

.job-time {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 福利标签 */
.welfare-list {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.welfare-tag {
  font-size: 24rpx;
  color: #667085;
  background-color: #f5f6f8;
  border-radius: 8rpx;
  padding: 4rpx 8rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

/* 企业信息 + 底部按钮 */
.job-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.company-info {
  display: flex;
  align-items: center;
}

.company-logo {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background-size: cover;
  background-position: center;
  margin-right: 12rpx;
}

.company-logo-placeholder {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background-color: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4b5563;
  font-size: 28rpx;
  margin-right: 12rpx;
}

.company-detail {
  display: flex;
  flex-direction: column;
}

.company-contact {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 4rpx;
}

.company-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  display: flex;
  align-items: center;
}

.verify-icon {
  width: 24rpx;
  height: 24rpx;
  margin-left: 4rpx;
}

/* 拨打电话按钮 */
.btn-call {
  padding: 8rpx 16rpx;
  font-size: 28rpx;
  color: #ffffff;
  background-color: #ff5c39;
  border-radius: 16rpx;
}

/* 空状态 */
.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
  color: #9ca3af;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  background-color: #f3f4f6;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
}