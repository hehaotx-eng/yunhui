.feed-page {
  min-height: 100vh;
  background: var(--c-bg, #f6f7f9);
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
}

.cat-scroll {
  background: #fff;
  white-space: nowrap;
  padding: 16rpx 24rpx;
  z-index: 100;
  transition: box-shadow .2s;
}

.cat-scroll.cat-sticky {
  position: fixed;
  left: 0;
  right: 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, .06);
}

.cat-inner {
  display: inline-flex;
  gap: 16rpx;
}

.cat-item {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  transition: all .2s;
}

.cat-item.cat-active {
  color: #fff;
  background: #1a1a2e;
  font-weight: 600;
}

.notice-bar {
  display: flex;
  align-items: center;
  background: #fff8f0;
  padding: 14rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.notice-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.notice-swiper {
  flex: 1;
  height: 32rpx;
}

.notice-swiper swiper-item {
  display: flex;
  align-items: center;
}

.notice-text {
  font-size: 24rpx;
  color: #b8860b;
  line-height: 32rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  vertical-align: middle;
}

.notice-more {
  font-size: 22rpx;
  color: #b8860b;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255,255,255,.25);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  gap: 20rpx;
}

.nav-logo {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--c-text, #1a1a2e);
  flex-shrink: 0;
}

.nav-search {
  flex: 1;
  max-width: 440rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #f3f4f6;
  border-radius: 32rpx;
  padding: 0 20rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.search-text {
  font-size: 24rpx;
  color: var(--c-text-3, #9ca3af);
}

.banner-wrap {
  min-height: 450rpx;
  background: linear-gradient(135deg, rgba(41, 159, 240, 0.16) 0%, rgba(41, 159, 240, 0.04) 60%, rgba(41, 159, 240, 0) 100%), linear-gradient(180deg, rgba(246, 247, 249, 0) 0%, #F6F7F9 150px);
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.banner-swiper {
  height: 330rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-item {
  margin-top: 20rpx;
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
}

.banner-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
}

.banner-bg {
  position: absolute;
  inset: 0;
  border-radius: 24rpx;
}

.banner-bg-0 {
  background: linear-gradient(135deg, #6d5efc 0%, #8b7cf8 50%, #a78bfa 100%);
}

.banner-bg-1 {
  background: linear-gradient(135deg, #ff5c39 0%, #ff7a5c 50%, #ff9a85 100%);
}

.banner-bg-2 {
  background: linear-gradient(135deg, #1a1a2e 0%, #2d2d44 50%, #3d3d5c 100%);
}

.banner-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  height: 100%;
  padding: 0 48rpx;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 12rpx;
}

.banner-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, .7);
}

.quick-links {
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding: 20rpx 0 10rpx;
  gap: 24rpx;
}

.ql-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex: 1;
}

.ql-icon {
  width: 56rpx;
  height: 56rpx;
}

.ql-label {
  font-size: 24rpx;
  color: #333;
}

.ai-banner {
  margin: 20rpx 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
}

.ai-banner-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #1a1a2e 0%, #2d2d44 50%, #3d3d5c 100%);
}

.ai-banner-content {
  position: relative;
  display: flex;
  align-items: center;
  padding: 28rpx;
  gap: 16rpx;
}

.ai-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #6d5efc, #8b7cf8);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-icon-text {
  font-size: 24rpx;
  font-weight: 800;
  color: #fff;
}

.ai-banner-info {
  flex: 1;
}

.ai-banner-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.ai-banner-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, .6);
  display: block;
  margin-top: 4rpx;
}

.ai-banner-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, .5);
}

.feed-list {
  padding: 20rpx 0;
}

.container {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  width: 98%;
}
.container {
  display: flex;
  gap: 12px;
  padding: 14px;
}

/* 基础卡片 */
.card {
  flex: 1;
  height: 90px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  padding: 12px;
  position: relative;
  overflow: hidden;
}

/* 橙色卡（发布岗位） */
.card-orange {
  background: linear-gradient(135deg, #ff7a45, #ffb26b);
}

/* 蓝色卡（创建简历） */
.card-blue {
  background: linear-gradient(135deg, #4f7cff, #6aa7ff);
}

/* 左侧图标容器 */
.icon-box {
  width: 38px;
  height: 38px;
  border-radius: 10px;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10px;
}

/* 纯 CSS 图标（替代图片核心点） */
.icon {
  width: 18px;
  height: 18px;
  border-radius: 4px;
  background: #fff;
  position: relative;
}

/* 轻微装饰线（提升质感） */
.icon::after {
  content: "";
  position: absolute;
  width: 10px;
  height: 2px;
  background: rgba(255,255,255,0.8);
  top: 6px;
  left: 4px;
}

/* 文字 */
.text-box {
  flex: 1;
  color: #fff;
}

.title {
  font-size: 14px;
  font-weight: 600;
}

.desc {
  font-size: 11px;
  opacity: 0.85;
  margin-top: 2px;
}

/* 右箭头 */
.arrow {
  color: rgba(255,255,255,0.8);
  font-size: 18px;
  font-weight: bold;
}



.block {
  width: 95%;
  margin-left: 2.5%;
  height: 100px;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  border-radius: 16rpx;
  /* box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, .06); */
  border: 1rpx solid rgba(255, 255, 255, .3);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.block::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  /* background-color: rgba(0, 0, 0, .3); */
  z-index: 1;
}

.block-text {
  position: relative;
  z-index: 2;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  background: rgba(255, 255, 255, .2);
  backdrop-filter: blur(8rpx);
  padding: 8rpx 24rpx;
  border-radius: 40rpx;
}

.block:first-child {
  margin-left: 2.5%;
}

.block:last-child {
  margin-left: 2.5%;
}

.skeleton-wrap {
  padding: 24rpx;
}

.skeleton-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.skeleton-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.skeleton-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
}

.skeleton-lines {
  flex: 1;
}

.skeleton-line {
  height: 20rpx;
  margin-bottom: 8rpx;
  border-radius: 6rpx;
}

.skeleton-line-md {
  width: 60%;
}

.skeleton-line-sm {
  width: 40%;
}

.skeleton-img {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.skeleton-text {
  width: 80%;
  height: 20rpx;
  border-radius: 6rpx;
}

page {
  padding-bottom: 60px;
}