page {
  background-color: #eeeeee;
}

.title {
  width: 100%;
  height: 200rpx;
  background: linear-gradient(#00a2ff 20%, #eeeeee 100%);
}

.text {
  position: relative;
  top: 110rpx;
  left: 3%;
  width: 90%;
  color: black;
  font-size: 40rpx;
}

.sou {
  border-radius: 10rpx;
  background-color: rgb(156, 156, 255);
  position: relative;
  width: 95%;
  left: 2.5%;
  height: 60rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.search-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  width: 0%;
  position: relative;
  left: 2%;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 0 20rpx;
}

.body {
  display: flex;
}

.right {
  width: 20%;
}

.icon-qiehuan {
  width: 30rpx;
  height: 30rpx;
  position: relative;
  left: 20px;
}


.icon-search {
  width: 30rpx;
  height: 30rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
}

.icon-mic,
.icon-clear {
  width: 36rpx;
  height: 36rpx;
  padding: 8rpx;
}

.search-actions {
  display: flex;
  align-items: center;
  margin-left: 16rpx;
}

.icon-scan {
  width: 40rpx;
  height: 40rpx;
  filter: brightness(0) invert(1);
}

.cancel-btn {
  color: #fff;
  font-size: 28rpx;
  margin-left: 20rpx;
}

/* 轮播 */
.banner {
  margin-top: 10px;
  border-radius: 10px;
  margin-left: 2.5%;
  width: 95%;
  height: 350rpx;
}

.banner swiper {
  border-radius: 10px;
  width: 100%;
  height: 100%;
}

.banner image {
  border-radius: 10px;
  width: 100%;
  height: 350rpx;
}

.tb-3{
  margin-top: 10px;
  display: flex;
  width: 95%;
  height: 100rpx;
  border-radius: 10px;
  /* background-color: #00a2ff; */
  margin-left: 2.5%;
}

.tb-3-1{
  margin-top: 30px;
  width: 25%;
  text-align: center;
}


/* 通知 */
.notice-bar {
  margin-top: 10px;
  display: flex;
  align-items: center;
  height: 60rpx; /* 约20px */
  padding: 0 20rpx;
  background: #fff8f0;
  border-radius: 8rpx;
}

.icon {
  font-size: 24rpx;
  margin-right: 12rpx;
}

.notice-swiper {
  flex: 1;
  height: 40rpx;
}

.notice-text {
  height: 40rpx;
  line-height: 40rpx;
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow {
  font-size: 28rpx;
  color: #999;
  margin-left: 8rpx;
}

/* 分类 */
.category-scroll {
  white-space: nowrap;
  margin-top: 10px;
  height: 20px;
  padding: 20rpx;
  background: #fff;
}

.cat-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
  font-size: 24rpx;
  color: #666;
}

.cat-item.active {
  color: #ff6b6b;
  font-weight: bold;
}

.cat-item.active .cat-icon {
  background: #fff0f0;
}

.cat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f5f5f5;
  margin-bottom: 8rpx;
}

/* 推荐 */
.job-list {
  padding: 20rpx;
}

.job-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
}

/* 右上角标签 */
.tag {
  position: absolute;
  top: 0;
  right: 0;
  background: linear-gradient(90deg, #ff7e5f, #feb47b);
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 0 20rpx 0 20rpx;
}

/* 标题 */
.title-1 {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-right: 120rpx;
}

/* 薪资行 */
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.salary {
  font-size: 40rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.unit {
  font-size: 26rpx;
  color: #ff6b6b;
  font-weight: normal;
}

.time {
  font-size: 26rpx;
  color: #999;
}

/* 福利标签 */
.welfare-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.welfare {
  background: #f5f5f5;
  color: #666;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
}

.welfare.more {
  background: transparent;
  padding: 10rpx;
}

/* 底部 */
.footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.company {
  display: flex;
  align-items: center;
}

.logo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #1890ff;
  margin-right: 16rpx;
}

.info {
  display: flex;
  flex-direction: column;
}

.name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.firm {
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
  margin-top: 4rpx;
}

.verify {
  width: 28rpx;
  height: 28rpx;
  margin-left: 8rpx;
}

/* 拨打电话按钮 */
.btn {
  background: #fff5f0;
  color: #ff6b6b;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
}