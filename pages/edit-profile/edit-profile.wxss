@import '../../styles/tokens.wxss';

.page {
  background: var(--c-bg);
  min-height: 100vh;
  padding: var(--sp-24);
}

.avatar-section {
  display: flex;
  justify-content: center;
  padding: 40rpx 0 32rpx;
}
.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid var(--c-border);
}
.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f5f5f5;
  border: 4rpx dashed var(--c-border);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}
.avatar-icon {
  font-size: 48rpx;
}
.avatar-hint {
  font-size: var(--fs-xxs);
  color: var(--c-text-3);
}

.form-card {
  background: var(--c-card);
  border-radius: var(--card-radius);
  padding: 0 var(--sp-24);
  box-shadow: var(--card-shadow);
}
.form-field {
  padding: var(--sp-24) 0;
  border-bottom: 1rpx solid var(--c-border);
}
.form-field:last-child {
  border-bottom: none;
}
.form-label {
  display: block;
  font-size: var(--fs-xs);
  color: var(--c-text-2);
  font-weight: var(--fw-medium);
  margin-bottom: var(--sp-10);
}
.form-input {
  width: 100%;
  font-size: var(--fs-md);
  color: var(--c-text);
  height: 72rpx;
  box-sizing: border-box;
}

.save-btn {
  margin-top: 40rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--c-accent), #ff7a5c);
  color: #fff;
  font-size: var(--fs-md);
  font-weight: var(--fw-semibold);
  border-radius: var(--card-radius);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255,92,57,.2);
}
.save-btn.disabled {
  opacity: .6;
}
