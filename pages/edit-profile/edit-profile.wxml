<view class="page">
  <view class="avatar-section">
    <image wx:if="{{form.avatar}}" class="avatar-img" src="{{form.avatar}}" mode="aspectFill" bindtap="chooseAvatar" />
    <view wx:else class="avatar-placeholder" bindtap="chooseAvatar">
      <text class="avatar-icon icon-ph"></text>
      <text class="avatar-hint">点击更换头像</text>
    </view>
  </view>

  <view class="form-card">
    <view class="form-field">
      <text class="form-label">昵称</text>
      <input class="form-input" value="{{form.nickname}}" bindinput="onInput" data-field="nickname" placeholder="请输入昵称" maxlength="20" />
    </view>
    <view class="form-field">
      <text class="form-label">手机号</text>
      <input class="form-input" value="{{form.phone}}" bindinput="onInput" data-field="phone" placeholder="请输入手机号" type="number" maxlength="11" />
    </view>
  </view>

  <view class="save-btn {{saving ? 'disabled' : ''}}" bindtap="save">
    {{saving ? '保存中...' : '保存'}}
  </view>
</view>
