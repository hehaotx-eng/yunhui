page {
  background: var(--c-bg, #f6f7f9);
  min-height: 100vh;
}

.search-page {
  min-height: 100vh;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid var(--c-border, #f0f0f0);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: #f3f4f6;
  border-radius: 36rpx;
  padding: 0 24rpx;
  gap: 12rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
}

.search-clear {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--c-text-3, #9ca3af);
  border-radius: 50%;
  color: #fff;
  font-size: 20rpx;
  flex-shrink: 0;
}

/* 搜索建议 */
.suggest-wrap {
  padding: 20rpx 24rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--c-text, #1a1a2e);
}

.section-clear {
  font-size: 24rpx;
  color: var(--c-text-3, #9ca3af);
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.suggest-tag {
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--c-text-2, #6b7280);
  box-shadow: 0 2rpx 8rpx rgba(15,23,42,.03);
}

/* 搜索结果 */
.results-wrap {
  padding: 12rpx 0;
}

.result-section {
  margin-bottom: 16rpx;
}

.result-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx 8rpx;
}

.label-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.label-dot--exact {
  background: #007aff;
}

.label-dot--recommend {
  background: var(--c-text-3, #9ca3af);
}

.label-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text, #1a1a2e);
}

.label-count {
  font-size: 22rpx;
  color: var(--c-text-3, #9ca3af);
  margin-left: 4rpx;
}

.loading-text {
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  color: var(--c-text-3, #9ca3af);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-title {
  font-size: 30rpx;
  color: var(--c-text-3, #9ca3af);
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: var(--c-text-3, #9ca3af);
}

.no-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: var(--c-text-3, #9ca3af);
}
