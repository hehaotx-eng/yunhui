page {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  padding: 60rpx 24rpx 24rpx;
  background: #fff;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  padding: 0 32rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.search-btn {
  width: 100rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #00a2ff;
  border-radius: 40rpx;
  color: #fff;
  font-size: 28rpx;
}

.content {
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.hot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-item {
  padding: 16rpx 28rpx;
  background: #fff;
  border-radius: 29rpx;
  font-size: 26rpx;
  color: #666;
}

.history-list {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-clear {
  font-size: 24rpx;
  color: #999;
}

.history-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-item {
  padding: 16rpx 28rpx;
  background: #f5f5f5;
  border-radius: 29rpx;
  font-size: 26rpx;
  color: #666;
}

.result-section {
  padding-top: 24rpx;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.result-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}