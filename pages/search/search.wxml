<view class="page">
  <view class="header">
    <view class="back-btn" bindtap="goBack">‹</view>
    <view class="search-wrapper">
      <image class="icon-search" src="/pages/image/sousuo.png" />
      <input 
        class="search-input" 
        placeholder="搜索职位/企业" 
        value="{{keyword}}"
        bindinput="onInput"
        bindconfirm="onConfirm"
        focus
      />
    </view>
    <view class="cancel-btn" bindtap="goBack">取消</view>
  </view>

  <view wx:if="{{!showResults}}" class="search-content">
    <view wx:if="{{hotKeywords.length > 0}}" class="section">
      <view class="section-header">
        <text class="section-title">热门搜索</text>
      </view>
      <view class="keyword-list">
        <view 
          wx:for="{{hotKeywords}}" 
          wx:key="*this" 
          class="keyword-item"
          bindtap="selectKeyword"
          data-keyword="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </view>

    <view wx:if="{{historyKeywords.length > 0}}" class="section">
      <view class="section-header">
        <text class="section-title">搜索历史</text>
        <text class="section-action" bindtap="clearHistory">清除</text>
      </view>
      <view class="keyword-list">
        <view 
          wx:for="{{historyKeywords}}" 
          wx:key="*this" 
          class="keyword-item"
          bindtap="selectKeyword"
          data-keyword="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showResults}}" class="results-content">
    <view wx:if="{{loading}}" class="loading">搜索中...</view>
    
    <view wx:if="{{!loading && searchResults.length > 0}}" class="job-list">
      <view 
        wx:for="{{searchResults}}" 
        wx:key="id" 
        class="job-card"
        bindtap="goDetail"
        data-id="{{item.id}}"
      >
        <view class="job-title">{{item.title}}</view>
        <view class="job-salary">{{item.salary}}{{item.salary && !item.salary.includes('元') ? '元/月' : ''}}</view>
        <view class="job-meta">{{item.area}} · {{item.experience}} · {{item.education}}</view>
        <view class="welfare-list">
          <view wx:for="{{item.tags || item.welfare || []}}" wx:for-item="w" wx:key="*this" class="welfare-tag">{{w}}</view>
        </view>
        <view class="company-info">
          <view class="company-logo-placeholder">{{item.enterpriseName ? item.enterpriseName.substring(0, 1) : '企'}}</view>
          <view class="company-name">{{item.enterpriseName}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{!loading && searchResults.length === 0}}" class="empty-card">
      <view class="empty-icon">🔍</view>
      <view class="empty-text">未找到相关职位</view>
      <view class="empty-tip">换个关键词试试吧</view>
    </view>
  </view>
</view>