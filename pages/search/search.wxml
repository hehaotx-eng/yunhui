<view class="search-page">
  <!-- 搜索输入框 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <image class="search-icon" src="/pages/image/sousuo.png" />
      <input
        class="search-input"
        placeholder="输入职位关键词搜索"
        value="{{keyword}}"
        bindinput="onInput"
        bindconfirm="onConfirm"
        focus
      />
      <view wx:if="{{keyword}}" class="search-clear" bindtap="clearKeyword">x</view>
    </view>
  </view>

  <!-- 搜索建议 -->
  <view class="suggest-wrap" wx:if="{{!showResults}}">
    <view class="section" wx:if="{{hotKeywords.length > 0}}">
      <view class="section-header">
        <text class="section-title">热门搜索</text>
      </view>
      <view class="tag-list">
        <view class="suggest-tag" wx:for="{{hotKeywords}}" wx:key="*this" bindtap="selectKeyword" data-keyword="{{item}}">{{item}}</view>
      </view>
    </view>

    <view class="section" wx:if="{{historyKeywords.length > 0}}">
      <view class="section-header">
        <text class="section-title">搜索历史</text>
        <text class="section-clear" bindtap="clearHistory">清除</text>
      </view>
      <view class="tag-list">
        <view class="suggest-tag" wx:for="{{historyKeywords}}" wx:key="*this" bindtap="selectKeyword" data-keyword="{{item}}">{{item}}</view>
      </view>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view class="results-wrap" wx:if="{{showResults}}">
    <view wx:if="{{loading}}" class="loading-text">搜索中...</view>

    <!-- 精确匹配 -->
    <view wx:if="{{exactResults.length > 0}}" class="result-section">
      <view class="result-label">
        <view class="label-dot label-dot--exact"></view>
        <text class="label-text">精确匹配</text>
        <text class="label-count">{{exactResults.length}}个结果</text>
      </view>
      <feed-card wx:for="{{exactResults}}" wx:key="job_id" item="{{item}}" bind:tap="goDetail" />
    </view>

    <!-- 推荐职位 -->
    <view wx:if="{{recommendResults.length > 0}}" class="result-section">
      <view class="result-label">
        <view class="label-dot label-dot--recommend"></view>
        <text class="label-text">相关推荐</text>
      </view>
      <feed-card wx:for="{{recommendResults}}" wx:key="job_id" item="{{item}}" bind:tap="goDetail" />
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && exactResults.length === 0 && recommendResults.length === 0}}" class="empty-state">
      <text class="empty-title">未找到相关职位</text>
      <text class="empty-sub">换个关键词试试</text>
    </view>
  </view>
</view>
