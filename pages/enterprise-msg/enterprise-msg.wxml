<wxs src="../../utils/wxs.wxs" module="wxs" />
<view class="page">
  <view class="body">
    <view wx:if="{{loading}}" class="loading">加载中...</view>

    <view wx:elif="{{showEmpty}}" class="empty">
      <view class="empty-icon icon-ph"></view>
      <text class="empty-text">暂无消息</text>
    </view>

    <view wx:else class="list">
      <view wx:for="{{conversations}}" wx:key="id" class="card" bindtap="goChat" data-id="{{item.id}}" data-name="{{item.other_name || item.company_name}}" data-avatar="{{item.company_logo || item.target_user_avatar}}">
        <view class="card-left">
          <image wx:if="{{item.target_user_avatar}}" class="avatar-img" src="{{item.target_user_avatar}}" mode="aspectFill" />
          <view wx:else class="avatar">{{wxs.firstChar(item.other_name)}}</view>
          <view wx:if="{{item.unread_count > 0}}" class="unread-badge">{{item.unread_count > 99 ? '99+' : item.unread_count}}</view>
        </view>
        <view class="card-body">
          <view class="card-top">
            <text class="card-name">{{item.other_name || '对方'}}</text>
            <text class="card-time">{{wxs.formatTime(item.last_message_at)}}</text>
          </view>
          <text class="card-preview {{item.unread_count > 0 ? 'unread' : ''}}">{{item.last_message || '暂无消息'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>

<enterprise-tabbar id="tabbar" current="msg" />
