/* 页面背景 */
.page {
  background-color: #f6f7f9;
  min-height: 100vh;
  font-family: "PingFang SC","Microsoft YaHei",sans-serif;
}

/* 顶部 */
.header {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #111827;
}

/* 内容区 */
.content {
  padding: 16rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

/* 搜索框 */
.search-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 0 16rpx;
  height: 64rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
}

.icon-search {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #111827;
}

/* 通知入口 */
.notice-entry {
  width: 72rpx;
  height: 64rpx;
  margin-left: 12rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
}

.notice-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 会话列表 */
.conversation-list {
  display: flex;
  flex-direction: column;
}

/* 会话卡片 */
.conversation-card {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
  position: relative;
}

/* 头像 */
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #111827;
  margin-right: 16rpx;
}

.avatar image {
  width: 100%;
  height: 100%;
}

/* 内容 */
.content-inner {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* 顶部行 */
.top-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.name {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.time {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 最后一条消息 */
.last {
  font-size: 24rpx;
  color: #4b5563;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 未读角标 */
.badge {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 16rpx;
  background-color: #ff5c39;
  color: #ffffff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: absolute;
  right: 16rpx;
  top: 16rpx;
}

/* 空状态 */
.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 加载 */
.loading {
  text-align: center;
  font-size: 28rpx;
  color: #9ca3af;
  padding: 32rpx 0;
}

/* TabBar */
.tabbar {
  height: 88rpx;
  background-color: #ffffff;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -8rpx 24rpx rgba(15,23,42,.03);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-icon {
  width: 32rpx;
  height: 32rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 24rpx;
  color: #4b5563;
}

.tab-item.active .tab-text {
  color: #ff5c39;
}