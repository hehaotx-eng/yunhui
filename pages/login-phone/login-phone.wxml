<view class="page">

<!-- 自定义导航栏 -->

<view class="navbar">

  <view class="navbar-content">

    <view
      class="nav-back"
      bindtap="goBack"
    >
      ←
    </view>

    <view class="nav-title">
      登录
    </view>

    <view class="nav-placeholder"></view>

  </view>

</view>

<!-- Hero -->

<view class="hero">

  <view class="hero-title">
    欢迎回来
  </view>

  <view class="hero-desc">
    登录后查看职位、投递简历与在线沟通
  </view>

</view>

<!-- 登录卡片 -->

<view class="form-card">

  <view class="form-item">

    <view class="label">
      手机号
    </view>

    <input
      class="input-field"
      placeholder="请输入手机号"
      value="{{phone}}"
      bindinput="onPhoneInput"
      type="number"
      maxlength="11"
    />

  </view>

  <view class="form-item">

    <view class="label">
      登录密码
    </view>

    <input
      class="input-field"
      password
      placeholder="请输入密码"
      value="{{password}}"
      bindinput="onPasswordInput"
    />

  </view>

</view>

<!-- 提示 -->

<view class="tips">
  新用户首次登录将自动创建账号
</view>

<!-- 悬浮按钮 -->

<view class="floating-bar">

  <view
    class="submit-btn"
    bindtap="handleLogin"
  >
    登录
  </view>

</view>

</view>