page{
  background:#f6f7f9;
}

.page{
  min-height:100vh;

  padding-bottom:180rpx;
}

/* =======================
   Navbar
======================= */

.navbar{
  position:fixed;

  top:0;
  left:0;
  right:0;

  z-index:999;

  background:rgba(246,247,249,.92);

  backdrop-filter:blur(24rpx);
}

.navbar-content{
  margin-top:88rpx;

  height:88rpx;

  display:flex;

  align-items:center;

  padding:0 24rpx;
}

.nav-back{
  width:72rpx;
  height:72rpx;

  background:#fff;

  border-radius:18rpx;

  display:flex;
  align-items:center;
  justify-content:center;

  font-size:30rpx;

  color:#111827;

  box-shadow:
  0 4rpx 12rpx rgba(0,0,0,.04);
}

.nav-title{
  flex:1;

  text-align:center;

  font-size:30rpx;
  font-weight:600;

  color:#111827;
}

.nav-placeholder{
  width:72rpx;
}

/* =======================
   Hero
======================= */

.hero{
  padding:
  240rpx 32rpx 60rpx;
}

.hero-title{
  font-size:58rpx;
  font-weight:700;

  color:#111827;
}

.hero-desc{
  margin-top:14rpx;

  font-size:28rpx;

  color:#6b7280;

  line-height:1.6;
}

/* =======================
   Form
======================= */

.form-card{
  margin:0 24rpx;

  background:#fff;

  border-radius:24rpx;

  overflow:hidden;

  box-shadow:
  0 8rpx 24rpx rgba(15,23,42,.03);
}

.form-item{
  padding:28rpx 32rpx;

  border-bottom:1rpx solid #f3f4f6;
}

.form-item:last-child{
  border:none;
}

.label{
  margin-bottom:10rpx;

  font-size:24rpx;

  color:#9ca3af;
}

.input-field{
  width:100%;

  font-size:30rpx;

  color:#111827;
}

.input-field::placeholder{
  color:#c4c7ce;
}

/* =======================
   Tips
======================= */

.tips{
  text-align:center;

  margin-top:28rpx;

  font-size:24rpx;

  color:#9ca3af;
}

/* =======================
   Floating Button
======================= */

.floating-bar{
  position:fixed;

  left:24rpx;
  right:24rpx;

  bottom:24rpx;

  z-index:999;
}

.submit-btn{
  height:96rpx;

  border-radius:24rpx;

  background:#111827;

  color:#fff;

  display:flex;
  align-items:center;
  justify-content:center;

  font-size:30rpx;
  font-weight:600;

  box-shadow:
  0 16rpx 40rpx rgba(17,24,39,.16);
}