/* ==================== 全局变量 ==================== */
page {
  --primary: #2563EB;
  --primary-light: #EFF6FF;
  --primary-dark: #1D4ED8;
  --primary-gradient: linear-gradient(135deg, #2563EB 0%, #3B82F6 100%);
  
  --wechat-green: #07C160;
  --gray-1: #F8FAFC;
  --gray-2: #E2E8F0;
  --gray-3: #CBD5E1;
  --gray-4: #94A3B8;
  --gray-5: #64748B;
  --gray-6: #475569;
  --gray-7: #1E293B;
  
  --radius-sm: 10rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;
  
  --shadow-sm: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  --shadow-md: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
  --shadow-primary: 0 8rpx 28rpx rgba(37, 99, 235, 0.30);
  
  --font-base: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", "Helvetica Neue", sans-serif;
  
  background: #F0F4FF;
}

.page {
  height: 100vh;
  background: #FFFFFF;
  font-family: var(--font-base);
  padding: 0 48rpx 0;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* ==================== 装饰性背景元素 ==================== */
.page::before {
  content: '';
  position: absolute;
  top: -160rpx;
  right: -120rpx;
  width: 460rpx;
  height: 460rpx;
  background: radial-gradient(circle, rgba(37, 99, 235, 0.06) 0%, transparent 70%);
  border-radius: 50%;
  z-index: 0;
  pointer-events: none;
}

.page::after {
  content: '';
  position: absolute;
  bottom: 200rpx;
  left: -100rpx;
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle, rgba(37, 99, 235, 0.04) 0%, transparent 70%);
  border-radius: 50%;
  z-index: 0;
  pointer-events: none;
}

/* ==================== Hero 区域 ==================== */
.hero {
  position: relative;
  z-index: 1;
  padding-top: 100rpx;
  padding-bottom: 48rpx;
  animation: fadeUp 0.6s ease forwards;
}

.hero-title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: var(--gray-7);
  letter-spacing: -0.5rpx;
  line-height: 1.2;
  margin-bottom: 12rpx;
  position: relative;
  padding-left: 24rpx;
}

.hero-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 44rpx;
  background: var(--primary-gradient);
  border-radius: 4rpx;
}

.hero-desc {
  display: block;
  font-size: 28rpx;
  color: var(--gray-4);
  font-weight: 400;
  padding-left: 24rpx;
  letter-spacing: 0.3rpx;
}

.hero::after {
  content: '';
  display: block;
  width: 60rpx;
  height: 4rpx;
  background: var(--primary-gradient);
  border-radius: 4rpx;
  margin-top: 28rpx;
  margin-left: 24rpx;
  opacity: 0.25;
}

/* ==================== 表单卡片 ==================== */
.form-card {
  position: relative;
  width: 90%;
  z-index: 1;
  background: var(--gray-1);
  border-radius: var(--radius-lg);
  padding: 8rpx 0;
  margin-bottom: 20rpx;
  animation: fadeUp 0.6s ease 0.08s both;
}

.form-item {
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-6);
  flex-shrink: 0;
  width: 100rpx;
}

.input-field {
  flex: 1;
  height: 56rpx;
  font-size: 28rpx;
  color: var(--gray-7);
  background: transparent;
  border: none;
  outline: none;
  padding: 0;
  font-weight: 500;
}

.input-field::placeholder {
  color: var(--gray-4);
  font-weight: 400;
}

.input-field:focus {
  color: var(--gray-7);
}

/* ==================== 提示文字 ==================== */
.tips {
  position: relative;
  z-index: 1;
  font-size: 24rpx;
  color: var(--gray-4);
  text-align: left;
  padding-left: 24rpx;
  margin-bottom: 32rpx;
  animation: fadeUp 0.6s ease 0.12s both;
}

.tips::before {
  content: '•';
  margin-right: 8rpx;
  color: var(--primary);
  font-weight: 700;
}

/* ==================== 底部悬浮登录按钮 ==================== */
.floating-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  padding: 20rpx 48rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 50;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.04);
}

.submit-btn {
  width: 100%;
  height: 100rpx;
  background: var(--primary-gradient);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  box-shadow: var(--shadow-primary);
  transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  cursor: pointer;
}

.submit-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.20);
}

/* ==================== 弹窗遮罩 ==================== */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.50);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: fadeIn 0.3s ease;
}

/* ==================== 弹窗主体 ==================== */
.dialog {
  background: #FFFFFF;
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  width: 100%;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  overflow: hidden;
}

.dialog-body {
  padding: 32rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  max-height: 70vh;
}

.dialog-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--gray-7);
  text-align: center;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid var(--gray-1);
  margin-bottom: 20rpx;
  position: relative;
}

.dialog-title::before {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: var(--primary-gradient);
  border-radius: 4rpx;
}

/* ==================== 企业列表 ==================== */
.company-list {
  flex: 1;
  max-height: 400rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.company-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 16rpx;
  border-radius: var(--radius-md);
  transition: background 0.2s ease;
  margin-bottom: 6rpx;
}

.company-item:active {
  background: var(--gray-1);
}

.ci-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.ci-logo {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  background: var(--primary-gradient);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.15);
}

.ci-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.ci-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-7);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ci-meta {
  font-size: 22rpx;
  color: var(--gray-4);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ci-arrow {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--primary);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
  background: var(--primary-light);
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.ci-arrow:active {
  background: var(--primary);
  color: #FFFFFF;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  font-size: 26rpx;
  color: var(--gray-4);
  padding: 48rpx 0;
}

/* ==================== 弹窗底部按钮 ==================== */
.dialog-footer {
  display: flex;
  gap: 16rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid var(--gray-1);
  margin-top: 16rpx;
}

.df-btn {
  flex: 1;
  height: 80rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-5);
  background: var(--gray-1);
  transition: all 0.2s ease;
}

.df-btn:active {
  transform: scale(0.96);
}

.df-btn.primary {
  background: var(--primary-gradient);
  color: #FFFFFF;
  box-shadow: var(--shadow-primary);
}

.df-btn.primary:active {
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.20);
}

/* ==================== 创建表单 ==================== */
.create-form {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 8rpx 0 4rpx;
}

.cf-item {
  background: var(--gray-1);
  border-radius: var(--radius-md);
  padding: 0 20rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
}

.cf-item:focus-within {
  border-color: var(--primary);
  background: #FFFFFF;
  box-shadow: 0 0 0 6rpx rgba(37, 99, 235, 0.06);
}

.cf-item input {
  width: 100%;
  font-size: 28rpx;
  color: var(--gray-7);
  background: transparent;
  border: none;
  outline: none;
  height: 100%;
}

.cf-item input::placeholder {
  color: var(--gray-4);
}

/* ==================== 动画 ==================== */
@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

/* ==================== 滚动条隐藏 ==================== */
::-webkit-scrollbar {
  width: 0;
  height: 0;
}

/* ==================== 适配 ==================== */
@media screen and (max-width: 375px) {
  .page {
    padding: 0 32rpx 0;
  }
  .hero {
    padding-top: 72rpx;
  }
  .hero-title {
    font-size: 44rpx;
  }
  .hero-title::before {
    height: 36rpx;
  }
  .floating-bar {
    padding: 16rpx 32rpx;
    padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  }
  .submit-btn {
    height: 88rpx;
    font-size: 28rpx;
  }
  .dialog {
    max-height: 80vh;
  }
}

@media screen and (min-width: 768px) {
  .page {
    max-width: 560rpx;
    margin: 0 auto;
    border-radius: var(--radius-lg);
    box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.06);
    margin-top: 60rpx;
    margin-bottom: 60rpx;
    min-height: 75vh;
  }
  .floating-bar {
    max-width: 560rpx;
    left: 50%;
    transform: translateX(-50%);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }
  .dialog {
    max-width: 560rpx;
    border-radius: var(--radius-xl);
    margin-bottom: 40rpx;
    max-height: 60vh;
  }
  .dialog-mask {
    align-items: center;
  }
}

/* ==================== 暗色模式 ==================== */
@media (prefers-color-scheme: dark) {
  page {
    background: #0F172A;
  }
  .page {
    background: #1E293B;
  }
  .page::before {
    background: radial-gradient(circle, rgba(37, 99, 235, 0.12) 0%, transparent 70%);
  }
  .page::after {
    background: radial-gradient(circle, rgba(37, 99, 235, 0.08) 0%, transparent 70%);
  }
  .hero-title {
    color: #F1F5F9;
  }
  .hero-desc {
    color: #94A3B8;
  }
  .form-card {
    background: #0F172A;
  }
  .form-item {
    border-bottom-color: rgba(255, 255, 255, 0.04);
  }
  .label {
    color: #94A3B8;
  }
  .input-field {
    color: #F1F5F9;
  }
  .input-field::placeholder {
    color: #64748B;
  }
  .tips {
    color: #64748B;
  }
  .floating-bar {
    background: rgba(30, 41, 59, 0.92);
    border-top-color: rgba(255, 255, 255, 0.04);
  }
  .dialog {
    background: #1E293B;
  }
  .dialog-title {
    color: #F1F5F9;
    border-bottom-color: #334155;
  }
  .ci-name {
    color: #F1F5F9;
  }
  .ci-meta {
    color: #64748B;
  }
  .ci-arrow {
    background: rgba(37, 99, 235, 0.15);
  }
  .df-btn {
    background: #0F172A;
    color: #94A3B8;
  }
  .cf-item {
    background: #0F172A;
  }
  .cf-item:focus-within {
    background: #1E293B;
  }
  .cf-item input {
    color: #F1F5F9;
  }
  .cf-item input::placeholder {
    color: #64748B;
  }
  .dialog-footer {
    border-top-color: #334155;
  }
  .empty-tip {
    color: #64748B;
  }
}