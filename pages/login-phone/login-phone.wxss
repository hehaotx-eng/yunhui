/* pages/login-phone/login-phone.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #e8f4fd 100%);
}

.content {
  padding: 0 40rpx 40rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 0 40rpx;
}

.back-btn {
  font-size: 56rpx;
  color: #475569;
  width: 80rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e293b;
}

.placeholder {
  width: 80rpx;
}

.form-section {
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.input-item {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  height: 96rpx;
  background: #f8fafc;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid transparent;
}

.input-item:focus-within {
  border-color: #3b82f6;
  background: #fff;
}

.input-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.input-field {
  flex: 1;
  font-size: 32rpx;
  color: #1e293b;
  background: transparent;
}

.input-field::placeholder {
  color: #94a3b8;
}

.btn-primary {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
}

.btn-primary text {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
}

.tips {
  text-align: center;
  font-size: 26rpx;
  color: #94a3b8;
}