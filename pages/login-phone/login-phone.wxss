page { background: #f6f7f9; }
.page { min-height: 100vh; padding-bottom: 180rpx; }

.navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 999; background: rgba(246,247,249,.92); backdrop-filter: blur(24rpx); }
.navbar-content { margin-top: 88rpx; height: 88rpx; display: flex; align-items: center; padding: 0 24rpx; }
.nav-back { width: 72rpx; height: 72rpx; background: #fff; border-radius: 18rpx; display: flex; align-items: center; justify-content: center; font-size: 30rpx; color: #111827; box-shadow: 0 4rpx 12rpx rgba(0,0,0,.04); }
.nav-title { flex: 1; text-align: center; font-size: 30rpx; font-weight: 600; color: #111827; }
.nav-placeholder { width: 72rpx; }

.hero { padding: 240rpx 32rpx 60rpx; }
.hero-title { font-size: 58rpx; font-weight: 700; color: #111827; }
.hero-desc { margin-top: 14rpx; font-size: 28rpx; color: #6b7280; line-height: 1.6; }

.form-card { margin: 0 24rpx; background: #fff; border-radius: 24rpx; overflow: hidden; box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03); }
.form-item { padding: 28rpx 32rpx; border-bottom: 1rpx solid #f3f4f6; }
.form-item:last-child { border: none; }
.label { margin-bottom: 10rpx; font-size: 24rpx; color: #9ca3af; }
.input-field { width: 100%; font-size: 30rpx; color: #111827; }
.input-field::placeholder { color: #c4c7ce; }

.tips { text-align: center; margin-top: 28rpx; font-size: 24rpx; color: #9ca3af; }

.floating-bar { position: fixed; left: 24rpx; right: 24rpx; bottom: 24rpx; z-index: 999; }
.submit-btn { height: 96rpx; border-radius: 24rpx; background: #111827; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 600; box-shadow: 0 16rpx 40rpx rgba(17,24,39,.16); }

/* Dialog */
.dialog-mask { position: fixed; inset: 0; background: rgba(0,0,0,.4); z-index: 1000; display: flex; align-items: flex-end; }
.dialog { width: 100%; background: #fff; border-radius: 32rpx 32rpx 0 0; max-height: 80vh; display: flex; flex-direction: column; }
.dialog-body { padding: 32rpx 24rpx; }
.dialog-title { font-size: 34rpx; font-weight: 700; color: #111827; text-align: center; margin-bottom: 24rpx; }

.company-list { max-height: 500rpx; }
.company-item { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 0; border-bottom: 1rpx solid #f3f4f6; }
.ci-left { display: flex; align-items: center; flex: 1; }
.ci-logo { width: 64rpx; height: 64rpx; border-radius: 14rpx; background: #f3f4f6; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 700; color: #111827; margin-right: 16rpx; flex-shrink: 0; }
.ci-info { display: flex; flex-direction: column; gap: 4rpx; }
.ci-name { font-size: 28rpx; font-weight: 600; color: #111827; }
.ci-meta { font-size: 22rpx; color: #9ca3af; }
.ci-arrow { padding: 10rpx 24rpx; border-radius: 20rpx; background: #111827; color: #fff; font-size: 24rpx; font-weight: 600; flex-shrink: 0; }

.empty-tip { text-align: center; padding: 60rpx 0; color: #9ca3af; font-size: 26rpx; }

.dialog-footer { display: flex; gap: 16rpx; margin-top: 24rpx; }
.df-btn { flex: 1; height: 80rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 600; background: #f3f4f6; color: #111827; }
.df-btn.primary { background: #111827; color: #fff; }

.create-form { display: flex; flex-direction: column; gap: 16rpx; }
.cf-item { padding: 20rpx 24rpx; background: #f6f7f9; border-radius: 16rpx; }
.cf-item input { width: 100%; font-size: 28rpx; color: #111827; }
.cf-item input::placeholder { color: #bbb; }