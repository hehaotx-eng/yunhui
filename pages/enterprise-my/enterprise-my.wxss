/* 页面背景 */
.page {
  background-color: #f6f7f9;
  min-height: 100vh;
  font-family: "PingFang SC","Microsoft YaHei",sans-serif;
  padding-top: 170rpx; /* 顶部预留高度 */
}

/* 顶部信息区 */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 170rpx;
  background-color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
  display: flex;
  align-items: flex-end;
  padding: 24rpx;
  z-index: 10;
}

.header-content {
  display: flex;
  align-items: center;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 24rpx;
}

.avatar image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8rpx;
}

.role {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 内容区 */
.content {
  padding: 16rpx;
}

/* 统计卡片 */
.stats-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
  display: flex;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.stat-divider {
  width: 1rpx;
  background-color: #e5e7eb;
  margin: 0 16rpx;
}

/* 菜单卡片 */
.menu-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,23,42,.03);
  margin-bottom: 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #111827;
}

.menu-arrow {
  width: 24rpx;
  height: 24rpx;
}

/* 危险操作 */
.menu-item.danger .menu-text {
  color: #ef4444;
}

/* Tabbar */
.tabbar {
  height: 88rpx;
  background-color: #ffffff;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -8rpx 24rpx rgba(15,23,42,.03);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-icon {
  width: 32rpx;
  height: 32rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 24rpx;
  color: #4b5563;
}

.tab-item.active .tab-text {
  color: #ff5c39;
}