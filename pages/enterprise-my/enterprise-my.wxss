/* ==================== 全局变量 ==================== */
page {
  --primary: #2563EB;
  --primary-light: #EFF6FF;
  --primary-dark: #1D4ED8;
  --primary-gradient: linear-gradient(135deg, #2563EB 0%, #3B82F6 100%);
  
  --success: #22C55E;
  --warning: #F59E0B;
  --danger: #EF4444;
  --gray-1: #F8FAFC;
  --gray-2: #E2E8F0;
  --gray-3: #CBD5E1;
  --gray-4: #94A3B8;
  --gray-5: #64748B;
  --gray-6: #475569;
  --gray-7: #1E293B;
  
  --radius-sm: 10rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;
  
  --shadow-sm: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  --shadow-md: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 16rpx 48rpx rgba(0, 0, 0, 0.10);
  
  --font-base: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", "Helvetica Neue", sans-serif;
  
  background: #F1F5F9;
}

.page {
  min-height: 100vh;
  background: #F1F5F9;
  font-family: var(--font-base);
  padding-bottom: 140rpx;
}

/* ==================== 主体 ==================== */
.body {
  padding: 24rpx 28rpx 0;
  box-sizing: border-box;
}

/* ==================== 个人信息卡片 ==================== */
.profile-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  gap: 24rpx;
  transition: box-shadow 0.25s ease;
}

.profile-card:active {
  box-shadow: var(--shadow-md);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--primary-gradient);
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.25);
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--gray-7);
  margin-bottom: 6rpx;
  letter-spacing: -0.3rpx;
}

.profile-role {
  display: block;
  font-size: 26rpx;
  font-weight: 400;
  color: var(--gray-4);
  background: var(--gray-1);
  padding: 4rpx 20rpx;
  border-radius: var(--radius-full);
  display: inline-block;
  border: 1rpx solid var(--gray-2);
}

/* ==================== 统计卡片 ==================== */
.stats-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 28rpx 0;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  justify-content: space-around;
  transition: box-shadow 0.25s ease;
}

.stats-card:active {
  box-shadow: var(--shadow-md);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  padding: 8rpx 0;
  transition: background 0.2s ease;
  border-radius: var(--radius-sm);
}

.stat-item:active {
  background: var(--gray-1);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--gray-7);
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: var(--gray-4);
  margin-top: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 56rpx;
  background: var(--gray-2);
}

/* ==================== 菜单卡片 ==================== */
.menu-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  transition: box-shadow 0.25s ease;
}

.menu-card:active {
  box-shadow: var(--shadow-md);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid var(--gray-1);
  transition: background 0.2s ease;
  cursor: pointer;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--gray-1);
}

.menu-icon-text {
  font-size: 36rpx;
  width: 48rpx;
  text-align: center;
  color: var(--gray-5);
  flex-shrink: 0;
  margin-right: 20rpx;
  font-weight: 300;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--gray-7);
}

.menu-badge {
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
  background: var(--danger);
  padding: 2rpx 16rpx;
  border-radius: var(--radius-full);
  margin-right: 12rpx;
  min-width: 32rpx;
  text-align: center;
}

.menu-arrow {
  font-size: 36rpx;
  color: var(--gray-3);
  font-weight: 300;
  margin-left: 8rpx;
}

.menu-count {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--gray-4);
  margin-right: 8rpx;
}

/* 退出登录特殊样式 */
.menu-item.danger .menu-text {
  color: var(--danger);
}

.menu-item.danger .menu-icon-text.logout-icon {
  color: var(--danger);
}

.menu-item.danger:active {
  background: #FEF2F2;
}

/* ==================== 头像图片 ==================== */
.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.25);
}

/* ==================== 适配 ==================== */
@media screen and (max-width: 375px) {
  .profile-card {
    flex-wrap: wrap;
    justify-content: center;
    text-align: center;
  }
  .profile-info {
    text-align: center;
  }
  .profile-role {
    display: inline-block;
  }
  .stats-card {
    flex-wrap: wrap;
    padding: 16rpx 0;
  }
  .stat-item {
    padding: 12rpx 0;
    flex: 0 0 50%;
  }
  .stat-divider:nth-child(2) {
    display: none;
  }
  .stat-divider:last-child {
    display: none;
  }
}

@media screen and (min-width: 768px) {
  .page {
    max-width: 720rpx;
    margin: 0 auto;
  }
}

/* ==================== 滚动条隐藏 ==================== */
::-webkit-scrollbar {
  width: 0;
  height: 0;
}