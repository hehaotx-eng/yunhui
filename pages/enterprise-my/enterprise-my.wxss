.page {
  min-height: 100vh;
  background: #f6f7f9;
  padding-bottom: 160rpx;
}

.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255,255,255,.25);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
}

.nav-logo {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a1a2e;
}

.body {
  padding: 0 20rpx 40rpx;
}

.profile-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
  margin-top: 16rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #299ff0, #5ab8f5);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
}

.profile-role {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 4rpx;
  display: block;
}

.stats-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 38rpx;
  font-weight: 800;
  color: #1a1a2e;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.stat-divider {
  width: 1rpx;
  background: #e5e7eb;
  margin: 0 24rpx;
}

.menu-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-text {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #299ff0;
  font-weight: 500;
  margin-right: 16rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a2e;
  font-weight: 500;
}

.menu-arrow {
  font-size: 32rpx;
  color: #c0c4cc;
  font-weight: 300;
}

.menu-item.danger .menu-text {
  color: #ef4444;
}

.menu-item.danger .menu-icon-text {
  color: #ef4444;
}
